{
  "name": "@ivanli-cn/blog",
  "version": "1.0.0",
  "description": "Ivan's Blog - A modern personal blog system built with Next.js",
  "type": "module",
  "private": true,
  "author": {
    "name": "Ivan Li",
    "email": "ivanli2048@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "ssh://gitea@git.ivanli.cc:7018/Ivan/blog-astrowind.git"
  },
  "homepage": "https://git.ivanli.cc/Ivan/blog-astrowind",
  "bugs": {
    "url": "https://git.ivanli.cc/Ivan/blog-astrowind/issues"
  },
  "license": "MIT",
  "keywords": [
    "blog",
    "nextjs",
    "react",
    "typescript",
    "tailwindcss",
    "sqlite",
    "ai",
    "vector-search",
    "comments",
    "admin"
  ],
  "engines": {
    "bun": "^1.0.0"
  },
  "scripts": {
    "dev": "concurrently --names \"WebDAV,Next.js\" --prefix-colors \"cyan,magenta\" \"bun run webdav:dev\" \"bun --bun next dev --turbopack\"",
    "dev:next": "bun --bun next dev --turbopack",
    "dev:proxy": "bun ./scripts/local-proxy.ts",
    "build": "bun run prebuild && bun --bun next build",
    "prebuild": "bun scripts/generate-version.ts",
    "start": "bun --bun next start",
    "lint": "bun --bun next lint",
    "check": "biome check",
    "fix": "biome check --write",
    "docker:build": "bash ./scripts/docker-build.sh",
    "migrate": "bun ./scripts/migrate.ts",
    "seed": "bun ./scripts/seed.ts",
    "seed:clear": "bun ./scripts/seed.ts --clear",
    "seed:check": "bun ./scripts/seed.ts --check",
    "drop-db": "bun ./scripts/drop-db.ts",
    "dev-db:reset": "DB_PATH=./dev-data/sqlite.db bun run drop-db --force && DB_PATH=./dev-data/sqlite.db bun run migrate && DB_PATH=./dev-data/sqlite.db bun run seed",
    "dev-db:check": "DB_PATH=./dev-data/sqlite.db bun ./scripts/db-tools.ts",
    "dev-db:schema": "DB_PATH=./dev-data/sqlite.db bun ./scripts/db-tools.ts schema",
    "dev-db:posts": "DB_PATH=./dev-data/sqlite.db bun ./scripts/db-tools.ts posts",
    "dev-db:comments": "DB_PATH=./dev-data/sqlite.db bun ./scripts/db-tools.ts comments",
    "test-db:reset": "DB_PATH=./test-data/sqlite.db bun run drop-db --force && DB_PATH=./test-data/sqlite.db bun run migrate && DB_PATH=./test-data/sqlite.db bun run seed",
    "test-db:check": "DB_PATH=./test-data/sqlite.db bun ./scripts/db-tools.ts",
    "test-db:schema": "DB_PATH=./test-data/sqlite.db bun ./scripts/db-tools.ts schema",
    "test-db:posts": "DB_PATH=./test-data/sqlite.db bun ./scripts/db-tools.ts posts",
    "test-db:comments": "DB_PATH=./test-data/sqlite.db bun ./scripts/db-tools.ts comments",
    "db:which": "echo \"当前数据库路径: ${DB_PATH:-./sqlite.db}\"",
    "webdav:list": "bun ./scripts/webdav-tools.ts list",
    "webdav:check": "bun ./scripts/webdav-tools.ts check",
    "webdav:dev": "bun ./scripts/start-dev-webdav.ts",
    "test-data:generate": "bun ./scripts/generate-test-data.ts",
    "test-data:clean": "bun ./scripts/generate-test-data.ts --clean",
    "test-data:verify": "bun ./scripts/verify-test-data.ts",
    "test-env:clean": "DB_PATH=./test-data/sqlite.db bun run seed:clear && bun run test-data:clean",
    "test-env:reset": "DB_PATH=./test-data/sqlite.db bun run test-env:clean && DB_PATH=./test-data/sqlite.db bun run migrate && DB_PATH=./test-data/sqlite.db bun run seed && bun run test-data:generate && DB_PATH=./test-data/sqlite.db bun run test-sync:trigger",
    "test-sync:trigger": "bun ./scripts/trigger-test-sync.ts",
    "test-server:start": "bun run test-env:reset && concurrently --names \"WebDAV,Next.js\" --prefix-colors \"cyan,magenta\" \"dufs test-data/webdav --port 25091 --allow-all --enable-cors\" \"NODE_ENV=test ADMIN_EMAIL=admin-test@test.local DB_PATH=./test-data/sqlite.db PORT=25090 bun --bun next dev --turbopack\"",
    "dev-data:generate": "bun ./scripts/generate-test-data.ts --dev",
    "dev-data:clean": "bun ./scripts/generate-test-data.ts --dev --clean",
    "test": "bun test src tests/integration tests/lib tests/server --exclude='tests/e2e/**/*'",
    "test:watch": "bun test --watch",
    "test:precommit": "bun ./scripts/run-precommit-tests.ts",
    "test:e2e": "playwright test",
    "test:e2e:headless": "HEADLESS=true playwright test",
    "test:e2e:verify": "bun ./scripts/verify-e2e-data.ts",
    "test:ci": "bun ./scripts/test-ci-workflow.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "HEADLESS=false playwright test --headed",
    "test:e2e:report": "playwright show-report test-results/html-report",
    "pr:create": "bun ./scripts/create-pr.ts"
  },
  "dependencies": {
    "@fingerprintjs/fingerprintjs": "^4.6.2",
    "@fontsource-variable/inter": "^5.2.6",
    "@iconify-json/carbon": "^1.2.10",
    "@iconify-json/lucide": "^1.2.52",
    "@iconify-json/simple-icons": "^1.2.39",
    "@iconify/react": "^6.0.0",
    "@llamaindex/core": "^0.6.11",
    "@llamaindex/env": "^0.1.30",
    "@llamaindex/openai": "^0.4.5",
    "@milkdown/core": "^7.15.3",
    "@milkdown/crepe": "^7.15.3",
    "@milkdown/ctx": "^7.15.3",
    "@milkdown/kit": "^7.15.3",
    "@milkdown/plugin-clipboard": "^7.15.3",
    "@milkdown/plugin-cursor": "^7.15.3",
    "@milkdown/plugin-history": "^7.15.3",
    "@milkdown/plugin-indent": "^7.15.3",
    "@milkdown/plugin-listener": "^7.15.3",
    "@milkdown/plugin-math": "^7.5.9",
    "@milkdown/plugin-prism": "^7.15.3",
    "@milkdown/plugin-trailing": "^7.15.3",
    "@milkdown/prose": "^7.15.3",
    "@milkdown/theme-nord": "^7.15.3",
    "@milkdown/transformer": "^7.15.3",
    "@milkdown/utils": "^7.15.3",
    "@next/mdx": "^15.4.6",
    "@playwright/test": "^1.54.1",
    "@tanstack/react-query": "^5.81.5",
    "@trpc/client": "^11.5.0",
    "@trpc/react-query": "^11.5.0",
    "@trpc/server": "^11.5.0",
    "@types/katex": "^0.16.7",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "clsx": "^2.1.1",
    "daisyui": "^5.0.50",
    "date-fns": "^4.1.0",
    "drizzle-kit": "^0.31.1",
    "drizzle-orm": "^0.44.2",
    "feed": "^4.2.2",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "ioredis": "^5.6.1",
    "jotai": "^2.13.1",
    "katex": "^0.16.22",
    "limax": "4.1.0",
    "llamaindex": "^0.11.9",
    "lodash.merge": "^4.6.2",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.539.0",
    "mermaid": "^11.9.0",
    "nanoid": "^5.1.5",
    "next": "15.4.6",
    "nextjs-toploader": "^3.8.16",
    "nodemailer": "^7.0.3",
    "openai": "^5.6.0",
    "playwright": "^1.54.1",
    "prismjs": "^1.30.0",
    "rate-limiter-flexible": "^7.1.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-markdown": "^10.1.0",
    "refractor": "4.8.1",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "unpic": "^4.1.2",
    "uuid": "^11.1.0",
    "web-vitals": "^5.1.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.4",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/eslintrc": "^3",
    "@iconify-json/flat-color-icons": "^1.2.1",
    "@iconify-json/fluent-emoji-flat": "^1.2.3",
    "@iconify-json/line-md": "^1.2.8",
    "@iconify-json/mingcute": "^1.2.3",
    "@iconify-json/tabler": "^1.2.19",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.1.10",
    "@types/bun": "^1.2.17",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash.merge": "^4.6.9",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "commitlint-plugin-function-rules": "^4.0.2",
    "concurrently": "^9.2.0",
    "eslint": "^9",
    "eslint-config-next": "15.4.6",
    "globals": "^16.2.0",
    "js-yaml": "^4.1.0",
    "lefthook": "^1.12.2",
    "mdast-util-to-string": "^4.0.0",
    "reading-time": "^1.5.0",
    "sharp": "0.34.2",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "unist-util-visit": "^5.0.0"
  },
  "bun": {
    "test": {
      "exclude": [
        "tests/e2e/**/*",
        "**/e2e/**/*",
        "**/*.spec.ts",
        "**/specs/**/*"
      ]
    }
  }
}

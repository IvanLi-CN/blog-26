    "jose": "^6.0.11",
    "jsonwebtoken": "^9.0.2",
    "lefthook": "^1.11.14",
    "limax": "4.1.0",
    "llamaindex": "^0.11.9",
    "lodash.merge": "^4.6.2",
    "lowlight": "^3.3.0",
    "nanoid": "^5.1.5",
    "nodemailer": "^7.0.3",
    "openai": "^5.6.0",
    "playwright": "^1.54.1",
    "rate-limiter-flexible": "^7.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-mermaid": "^3.0.0",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",

  "devDependencies": {
    "@astrojs/check": "0.9.4",
    "@astrojs/mdx": "4.2.6",
    "@astrojs/partytown": "^2.1.4",
    "@biomejs/biome": "1.9.4",
    "@iconify-json/flat-color-icons": "^1.2.1",
    "@iconify-json/fluent-emoji-flat": "^1.2.3",
    "@iconify-json/line-md": "^1.2.8",

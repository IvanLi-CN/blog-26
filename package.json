{
  "name": "@ivanli-cn/blog",
  "version": "1.0.0",
  "description": "Ivan's Blog - A modern personal blog system built with Next.js",
  "type": "module",
  "private": true,
  "author": {
    "name": "Ivan Li",
    "email": "ivanli2048@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "ssh://gitea@git.ivanli.cc:7018/Ivan/blog-astrowind.git"
  },
  "homepage": "https://git.ivanli.cc/Ivan/blog-astrowind",
  "bugs": {
    "url": "https://git.ivanli.cc/Ivan/blog-astrowind/issues"
  },
  "license": "MIT",
  "keywords": [
    "blog",
    "nextjs",
    "react",
    "typescript",
    "tailwindcss",
    "sqlite",
    "ai",
    "vector-search",
    "comments",
    "admin"
  ],
  "browserslist": {
    "production": [
      "chrome >= 112",
      "edge >= 112",
      "firefox >= 113",
      "safari >= 16.4"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "bun": "^1.0.0"
  },
  "scripts": {
    "setup": "bash ./scripts/setup.sh",
    "dev": "bun scripts/generate-version.ts && concurrently --names \"WebDAV,Next.js\" --prefix-colors \"cyan,magenta\" \"bun run webdav:dev\" \"bun --bun next dev --turbopack\"",
    "dev:next": "bun --bun next dev --turbopack",
    "build": "bun run prebuild && bun --bun next build",
    "prebuild": "bun scripts/generate-version.ts",
    "start": "bun --bun next start",
    "check": "biome check",
    "lint": "node ./scripts/next-lint.js",
    "fix": "biome check --write",
    "docker:build": "bash ./scripts/docker-build.sh",
    "migrate": "bun ./scripts/migrate.ts",
    "seed": "bun ./scripts/seed.ts",
    "seed:clear": "bun ./scripts/seed.ts --clear",
    "seed:check": "bun ./scripts/seed.ts --check",
    "drop-db": "bun ./scripts/drop-db.ts",
    "dev-db:reset": "DB_PATH=./dev-data/sqlite.db bun run drop-db --force && DB_PATH=./dev-data/sqlite.db bun run migrate && DB_PATH=./dev-data/sqlite.db bun run seed",
    "dev-db:check": "DB_PATH=./dev-data/sqlite.db bun ./scripts/db-tools.ts",
    "dev-db:schema": "DB_PATH=./dev-data/sqlite.db bun ./scripts/db-tools.ts schema",
    "dev-db:posts": "DB_PATH=./dev-data/sqlite.db bun ./scripts/db-tools.ts posts",
    "dev-db:comments": "DB_PATH=./dev-data/sqlite.db bun ./scripts/db-tools.ts comments",
    "test-db:reset": "DB_PATH=./test-data/sqlite.db bun run drop-db --force && DB_PATH=./test-data/sqlite.db bun run migrate && DB_PATH=./test-data/sqlite.db bun run seed",
    "test-db:check": "DB_PATH=./test-data/sqlite.db bun ./scripts/db-tools.ts",
    "test-db:schema": "DB_PATH=./test-data/sqlite.db bun ./scripts/db-tools.ts schema",
    "test-db:posts": "DB_PATH=./test-data/sqlite.db bun ./scripts/db-tools.ts posts",
    "test-db:comments": "DB_PATH=./test-data/sqlite.db bun ./scripts/db-tools.ts comments",
    "db:which": "echo \"当前数据库路径: ${DB_PATH:-./sqlite.db}\"",
    "webdav:list": "bun ./scripts/webdav-tools.ts list",
    "webdav:check": "bun ./scripts/webdav-tools.ts check",
    "webdav:dev": "bun ./scripts/start-dev-webdav.ts",
    "dev-sync:trigger": "bun ./scripts/trigger-sync.ts dev",
    "content:scan-api-links": "bun ./scripts/content-scan-api-links.ts",
    "content:migrate-api-links": "bun ./scripts/content-migrate-api-links.ts",
    "test-data:generate": "bun ./scripts/generate-test-data.ts",
    "test-data:clean": "bun ./scripts/generate-test-data.ts --clean",
    "test-data:verify": "bun ./scripts/verify-test-data.ts",
    "test-env:clean": "DB_PATH=./test-data/sqlite.db bun run seed:clear && bun run test-data:clean",
    "test-env:reset": "DB_PATH=${DB_PATH:-./test-data/sqlite.db} LOCAL_CONTENT_BASE_PATH=${LOCAL_CONTENT_BASE_PATH:-./test-data/local} WEBDAV_URL=${WEBDAV_URL:-http://localhost:25091} bun run test-env:clean && DB_PATH=${DB_PATH:-./test-data/sqlite.db} LOCAL_CONTENT_BASE_PATH=${LOCAL_CONTENT_BASE_PATH:-./test-data/local} WEBDAV_URL=${WEBDAV_URL:-http://localhost:25091} bun run migrate && DB_PATH=${DB_PATH:-./test-data/sqlite.db} LOCAL_CONTENT_BASE_PATH=${LOCAL_CONTENT_BASE_PATH:-./test-data/local} WEBDAV_URL=${WEBDAV_URL:-http://localhost:25091} bun run seed && bun run test-data:generate && DB_PATH=${DB_PATH:-./test-data/sqlite.db} LOCAL_CONTENT_BASE_PATH=${LOCAL_CONTENT_BASE_PATH:-./test-data/local} WEBDAV_URL=${WEBDAV_URL:-http://localhost:25091} bun run test-sync:trigger && bun scripts/generate-version.ts",
    "test-env:reset-fs-only": "DB_PATH=${DB_PATH:-./test-data/sqlite.db} LOCAL_CONTENT_BASE_PATH=${LOCAL_CONTENT_BASE_PATH:-./test-data/local} CONTENT_SOURCES=local bun run test-env:clean && DB_PATH=${DB_PATH:-./test-data/sqlite.db} LOCAL_CONTENT_BASE_PATH=${LOCAL_CONTENT_BASE_PATH:-./test-data/local} CONTENT_SOURCES=local bun run migrate && DB_PATH=${DB_PATH:-./test-data/sqlite.db} LOCAL_CONTENT_BASE_PATH=${LOCAL_CONTENT_BASE_PATH:-./test-data/local} CONTENT_SOURCES=local bun run seed && bun run test-data:generate && DB_PATH=${DB_PATH:-./test-data/sqlite.db} LOCAL_CONTENT_BASE_PATH=${LOCAL_CONTENT_BASE_PATH:-./test-data/local} CONTENT_SOURCES=local bun run test-sync:trigger && bun scripts/generate-version.ts",
    "test-sync:trigger": "bun ./scripts/trigger-sync.ts test",
    "test-server:start": "bun run test-env:reset && concurrently --names \"WebDAV,Next.js\" --prefix-colors \"cyan,magenta\" \"dufs test-data/webdav --port 25091 --allow-all --enable-cors\" \"NODE_ENV=test ADMIN_EMAIL=admin-test@test.local DB_PATH=./test-data/sqlite.db PORT=25090 bun --bun next dev --turbopack\"",
    "dev-data:generate": "bun ./scripts/generate-test-data.ts --dev",
    "dev-data:clean": "bun ./scripts/generate-test-data.ts --dev --clean",
    "test": "bun test src tests/integration tests/lib tests/server --exclude='tests/e2e/**/*'",
    "test:watch": "bun test --watch",
    "test:precommit": "bun ./scripts/run-precommit-tests.ts",
    "db:migrations:validate": "bun ./scripts/validate-drizzle-journal.ts",
    "test:e2e": "playwright test",
    "test:e2e:headless": "HEADLESS=true playwright test",
    "test:e2e:verify": "bun ./scripts/verify-e2e-data.ts",
    "test:ci": "bun ./scripts/test-ci-workflow.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "HEADLESS=false playwright test --headed",
    "test:e2e:report": "playwright show-report test-results/html-report",
    "pr:create": "bun ./scripts/create-pr.ts"
  },
  "dependencies": {
    "@fingerprintjs/fingerprintjs": "^5.0.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@iconify-json/bxl": "^1.2.2",

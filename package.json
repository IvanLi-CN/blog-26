{
  "name": "@ivanli-cn/blog",
  "version": "0.0.0",
  "description": "Ivan's Blog. Powered by Astro.",
  "type": "module",
  "private": true,
  "engines": {
    "node": "^18.17.1 || ^20.3.0 || >= 21.0.0"
  },
  "scripts": {
    "dev": "ADMIN_MODE=true bunx --bun astro dev --host",
    "start": "bunx --bun astro dev",
    "build": "bunx --bun astro build",
    "preview": "bunx --bun astro preview",
    "astro": "astro",
    "check": "bun --bun run check:astro && bunx biome check",
    "check:astro": "astro check",
    "migrate": "bun ./scripts/migrate.ts",
    "fix": "bunx biome check --write"
  },
  "dependencies": {
    "@astrojs/node": "^9.2.1",
    "@astrojs/react": "^4.2.7",
    "@astrojs/rss": "^4.0.11",

    "@astrolib/analytics": "^0.6.1",
    "@astrolib/seo": "^1.0.0-beta.8",
    "@fontsource-variable/inter": "^5.2.5",
    "@iconify-json/simple-icons": "^1.2.34",
    "@llamaindex/core": "^0.6.5",
    "@llamaindex/env": "^0.1.30",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "astro": "5.7.13",
    "astro-embed": "^0.9.0",
    "astro-icon": "^1.1.5",
    "drizzle-kit": "^0.31.1",
    "drizzle-orm": "^0.43.1",
    "ioredis": "^5.6.1",
    "lefthook": "^1.11.12",
    "limax": "4.1.0",
    "llamaindex": "^0.10.6",
    "lodash.merge": "^4.6.2",
    "openai": "^4.98.0",
    "rate-limiter-flexible": "^7.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "unpic": "^4.1.2"

{
  "name": "@ivanli-cn/blog",
  "version": "1.0.0",
  "description": "Ivan's Blog - A modern personal blog system built with Astro 5.0",
  "type": "module",
  "private": true,
  "author": {
    "name": "Ivan Li",
    "email": "ivanli2048@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "ssh://gitea@git.ivanli.cc:7018/Ivan/blog-astrowind.git"
  },
  "homepage": "https://git.ivanli.cc/Ivan/blog-astrowind",
  "bugs": {
    "url": "https://git.ivanli.cc/Ivan/blog-astrowind/issues"
  },
  "license": "MIT",
  "keywords": [
    "blog",
    "astro",
    "react",
    "typescript",
    "tailwindcss",
    "sqlite",
    "ai",
    "vector-search",
    "comments",
    "admin"
  ],
  "engines": {
    "bun": "^1.0.0"
  },
  "scripts": {
    "dev": "concurrently --names \"WebDAV,Astro\" --prefix-colors \"cyan,magenta\" \"bun run webdav:dev\" \"ADMIN_MODE=true bunx --bun astro dev --host\"",
    "dev:astro": "ADMIN_MODE=true bunx --bun astro dev --host",
    "dev:prod": "bunx --bun astro dev --host",
    "start": "bunx --bun astro dev",
    "prebuild": "bun scripts/generate-version.ts",
    "build": "bunx --bun astro build",
    "preview": "bunx --bun astro preview",
    "astro": "bunx --bun astro",
    "check": "bunx biome check && bun run check:astro",
    "check:astro": "bunx --bun astro check",
    "migrate": "bun ./scripts/migrate.ts",
    "seed": "bun ./scripts/seed.ts",
    "seed:clear": "bun ./scripts/seed.ts --clear",
    "seed:check": "bun ./scripts/seed.ts --check",
    "db:reset": "bun run migrate && bun run seed",
    "db:check": "bun ./scripts/db-tools.ts",
    "db:schema": "bun ./scripts/db-tools.ts schema",
    "db:posts": "bun ./scripts/db-tools.ts posts",
    "db:comments": "bun ./scripts/db-tools.ts comments",
    "webdav:list": "bun ./scripts/webdav-tools.ts list",
    "webdav:check": "bun ./scripts/webdav-tools.ts check",
    "webdav:dev": "bun ./scripts/start-dev-webdav.ts",
    "webdav:test": "bun ./scripts/start-test-webdav-dufs.ts",
    "webdav:legacy": "bun ./scripts/webdav-server.ts",
    "test-data:generate": "bun ./scripts/generate-test-data.ts",
    "test-data:clean": "bun ./scripts/generate-test-data.ts --clean",
    "test-data:verify": "bun ./scripts/verify-test-data.ts",
    "dev-data:generate": "bun ./scripts/generate-test-data.ts --dev",
    "dev-data:clean": "bun ./scripts/generate-test-data.ts --dev --clean",
    "fix": "bunx biome check --write",
    "test": "bun test src tests/integration tests/lib tests/server",
    "test:watch": "bun test --watch",
    "dev:test": "concurrently --names \"WebDAV,Astro\" --prefix-colors \"cyan,magenta\" \"bun ./scripts/start-test-webdav.ts\" \"ADMIN_MODE=true NODE_ENV=test bunx --bun astro dev --host\"",
    "test:e2e": "playwright test",
    "test:e2e:headless": "HEADLESS=true playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "HEADLESS=false playwright test --headed",
    "test:e2e:report": "playwright show-report test-results/html-report"
  },
  "dependencies": {
    "@astrojs/react": "^4.3.0",
    "@astrojs/rss": "^4.0.12",
    "@astrojs/sitemap": "3.4.1",
    "@astrolib/analytics": "^0.6.1",

    "daisyui": "^5.0.35",
    "globals": "^16.1.0",
    "js-yaml": "^4.1.0",
    "mdast-util-to-string": "^4.0.0",
    "reading-time": "^1.5.0",
    "sharp": "0.34.1",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "^4.1.6",
    "typescript": "^5.8.3",
    "unist-util-visit": "^5.0.0"

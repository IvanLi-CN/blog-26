# Database Configuration
DB_PATH=./sqlite.db

# OpenAI Configuration
OPENAI_API_KEY="your-openai-api-key"
OPENAI_API_BASE_URL="https://api.openai.com/v1"

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# WebDAV Configuration
WEBDAV_URL=https://your-webdav-url/
WEBDAV_USERNAME=your-webdav-username
WEBDAV_PASSWORD=your-webdav-password
WEBDAV_BASE_PATH=/
WEBDAV_BLOG_PATH=/blog
WEBDAV_EXCLUDE_PATHS=.git,node_modules,draft

# Model Configuration
EMBEDDING_MODEL_NAME="BAAI/bge-m3"
EMBEDDING_DIMENSION=1024
CHAT_MODEL_NAME="deepseek-v3"

# Site Configuration
SITE_URL="https://yourdomain.com"

# JWT Secret (generate a secure random string)
JWT_SECRET="your-jwt-secret-key"

# SMTP Configuration for sending emails
SMTP_HOST="your-smtp-host"
SMTP_PORT=587
SMTP_USER="your-smtp-user"
SMTP_PASSWORD="your-smtp-password"
SMTP_FROM_NAME="Your Blog Name"
SMTP_FROM_EMAIL="noreply@yourdomain.com"

# Admin Configuration
ADMIN_EMAIL="your-admin-email@example.com"

# Luosimao Captcha Configuration
PUBLIC_LUOSIMAO_SITE_KEY="your-luosimao-site-key"
LUOSIMAO_SECRET_KEY="your-luosimao-secret-key"

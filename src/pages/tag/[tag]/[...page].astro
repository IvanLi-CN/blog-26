---
import BlogList from "~/components/blog/List.astro";
import Pagination from "~/components/blog/Pagination.astro";
import Headline from "~/components/ui/Headline.astro";
import Layout from "~/layouts/PageLayout.astro";
import { blogPostsPerPage, blogTagRobots, fetchPosts } from "~/utils/blog";

export const prerender = false;

// 获取标签和分页参数
const tagSlug = Astro.params.tag;
const pageParam = Astro.params.page;
const currentPage = pageParam ? parseInt(pageParam) : 1;

// 从 Astro.locals 获取管理员状态
const isUserAdmin = Astro.locals.isAdmin || false;

// 获取所有文章并按标签过滤
const allPosts = await fetchPosts(isUserAdmin);
const tagPosts = allPosts.filter((post) =>
  post.tags?.some((tag) => tag.slug === tagSlug),
);

if (tagPosts.length === 0) {
  return Astro.redirect("/404");
}

// 获取标签信息
const tag = tagPosts[0].tags?.find((t) => t.slug === tagSlug)!;

// 计算分页
const postsPerPage = blogPostsPerPage || 10;
const totalPosts = tagPosts.length;
const totalPages = Math.ceil(totalPosts / postsPerPage);
const startIndex = (currentPage - 1) * postsPerPage;
const endIndex = startIndex + postsPerPage;
const posts = tagPosts.slice(startIndex, endIndex);

// 构建分页对象
const page = {
  data: posts,
  start: startIndex,
  end: Math.min(endIndex - 1, totalPosts - 1),
  size: postsPerPage,
  total: totalPosts,
  currentPage: currentPage,
  lastPage: totalPages,
  url: {
    current: Astro.url.pathname,
    prev: currentPage > 1 ? `/tag/${tagSlug}/${currentPage - 1}` : undefined,
    next:
      currentPage < totalPages
        ? `/tag/${tagSlug}/${currentPage + 1}`
        : undefined,
  },
};

const metadata = {
  title: `Posts by tag '${tag.title}'${currentPage > 1 ? ` — Page ${currentPage} ` : ""}`,
  robots: {
    index: blogTagRobots?.index,
    follow: blogTagRobots?.follow,
  },
};
---

<Layout metadata={metadata}>
  <section class="px-4 md:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <Headline>Posts by tag '{tag.title}'</Headline>
    <BlogList posts={page.data} />
    <Pagination prevUrl={page.url.prev} nextUrl={page.url.next} />
  </section>
</Layout>

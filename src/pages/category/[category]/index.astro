---
import BlogList from "~/components/blog/List.astro";
import Pagination from "~/components/blog/Pagination.astro";
import Headline from "~/components/ui/Headline.astro";
import Layout from "~/layouts/PageLayout.astro";
import { blogCategoryRobots, blogPostsPerPage, fetchPosts } from "~/utils/blog";
import { create404Response } from "~/utils/error-handler";

export const prerender = false;

// 获取分类参数
const categorySlug = Astro.params.category;

// 从 Astro.locals 获取管理员状态
const isUserAdmin = Astro.locals.isAdmin || false;

// 获取所有文章并按分类过滤
const allPosts = await fetchPosts(isUserAdmin);
const categoryPosts = allPosts.filter(
  (post) => post.category?.slug === categorySlug,
);

if (categoryPosts.length === 0) {
  return create404Response(Astro.request, "Category not found");
}

// 获取分类信息
const category = categoryPosts[0].category!;

// 计算分页
const postsPerPage = blogPostsPerPage || 10;
const totalPosts = categoryPosts.length;
const totalPages = Math.ceil(totalPosts / postsPerPage);
const posts = categoryPosts.slice(0, postsPerPage);

// 构建分页对象
const page = {
  data: posts,
  start: 0,
  end: Math.min(postsPerPage - 1, totalPosts - 1),
  size: postsPerPage,
  total: totalPosts,
  currentPage: 1,
  lastPage: totalPages,
  url: {
    current: Astro.url.pathname,
    prev: undefined,
    next: totalPages > 1 ? `/category/${categorySlug}/2` : undefined,
  },
};

const metadata = {
  title: `Category '${category.title}'`,
  robots: {
    index: blogCategoryRobots?.index,
    follow: blogCategoryRobots?.follow,
  },
};
---

<Layout metadata={metadata}>
  <section class="px-4 md:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <Headline>{category.title}</Headline>
    <BlogList posts={page.data} />
    <Pagination prevUrl={page.url.prev} nextUrl={page.url.next} />
  </section>
</Layout>

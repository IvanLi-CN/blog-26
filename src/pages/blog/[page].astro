---
import BlogList from "~/components/blog/List.astro";
import Pagination from "~/components/blog/Pagination.astro";
import Headline from "~/components/ui/Headline.astro";
import Layout from "~/layouts/PageLayout.astro";

import {
  blogListRobots,
  blogPostsPerPage,
  fetchPostsPaginated,
} from "~/utils/blog";

export const prerender = false;

// 获取分页参数
const pageParam = Astro.params.page;
const currentPage = pageParam ? parseInt(pageParam) : 1;

// 从 Astro.locals 获取管理员状态
const isUserAdmin = Astro.locals.isAdmin || false;

// 获取分页文章
const postsPerPage = blogPostsPerPage || 10;
const paginationResult = await fetchPostsPaginated({
  page: currentPage,
  limit: postsPerPage,
  isAdmin: isUserAdmin,
  type: "all",
});

// 构建分页对象
const page = {
  data: paginationResult.posts,
  start: (currentPage - 1) * postsPerPage,
  end: Math.min(currentPage * postsPerPage - 1, paginationResult.total - 1),
  size: postsPerPage,
  total: paginationResult.total,
  currentPage: currentPage,
  lastPage: paginationResult.totalPages,
  url: {
    current: Astro.url.pathname,
    prev: paginationResult.hasPrev
      ? currentPage === 2
        ? `/blog`
        : `/blog/${currentPage - 1}`
      : undefined,
    next: paginationResult.hasNext ? `/blog/${currentPage + 1}` : undefined,
  },
};

const metadata = {
  title: `Blog${currentPage > 1 ? ` — Page ${currentPage}` : ""}`,
  robots: {
    index: blogListRobots?.index && currentPage === 1,
    follow: blogListRobots?.follow,
  },
  openGraph: {
    type: "blog",
  },
};
---

<Layout metadata={metadata}>
  <section class="px-6 sm:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <Headline title="文章" subtitle="一些想法、记录、分享"> 文章 </Headline>
    <BlogList posts={page.data} />
    <div class="mt-12 md:mt-16">
      <Pagination prevUrl={page.url.prev} nextUrl={page.url.next} />
    </div>
  </section>
</Layout>

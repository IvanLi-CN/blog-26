---
import BlogList from "~/components/blog/List.astro";
import Pagination from "~/components/blog/Pagination.astro";
import Headline from "~/components/ui/Headline.astro";
import Layout from "~/layouts/PageLayout.astro";

import { blogListRobots, blogPostsPerPage, fetchPosts } from "~/utils/blog";

export const prerender = false;

// 从 Astro.locals 获取管理员状态
const isUserAdmin = Astro.locals.isAdmin || false;

// 获取所有文章
const allPosts = await fetchPosts(isUserAdmin);

// 计算分页
const postsPerPage = blogPostsPerPage || 10;
const totalPosts = allPosts.length;
const totalPages = Math.ceil(totalPosts / postsPerPage);
const posts = allPosts.slice(0, postsPerPage);

// 构建分页对象
const page = {
  data: posts,
  start: 0,
  end: Math.min(postsPerPage - 1, totalPosts - 1),
  size: postsPerPage,
  total: totalPosts,
  currentPage: 1,
  lastPage: totalPages,
  url: {
    current: Astro.url.pathname,
    prev: undefined,
    next: totalPages > 1 ? `/blog/2` : undefined,
  },
};

const metadata = {
  title: "文章",
  description: "这是 Ivan 的个人博客，记录和分享有关技术、生活和想法的内容。",
  keywords: "Ivan, Blog, 文章, 技术, 生活, 想法",
  robots: {
    index: blogListRobots?.index,
    follow: blogListRobots?.follow,
  },
  openGraph: {
    type: "blog",
  },
};
---

<Layout metadata={metadata}>
  <section class="px-6 sm:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <Headline title="文章" subtitle="一些想法、记录、分享"> 文章 </Headline>
    <BlogList posts={page.data} />
    <div class="mt-12 md:mt-16">
      <Pagination prevUrl={page.url.prev} nextUrl={page.url.next} />
    </div>
  </section>
</Layout>

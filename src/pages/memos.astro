---
import { MemosAppWithProviders } from "~/components/memos/MemosApp";
import Headline from "~/components/ui/Headline.astro";
import Layout from "~/layouts/PageLayout.astro";
import { isAdminFromRequest } from "~/lib/auth";

export const prerender = false;

// 检查用户是否为管理员
const isUserAdmin = await isAdminFromRequest(
  Astro.cookies,
  Astro.request.headers,
);

const metadata = {
  title: "闪念",
  description: "记录想法、灵感和日常思考的快速笔记",
  keywords: "Ivan, Blog, 闪念, 笔记, 灵感",
  robots: {
    index: true,
    follow: true,
  },
  openGraph: {
    type: "website",
  },
};
---

<Layout metadata={metadata}>
  <section class="px-6 sm:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <Headline title="Memos" subtitle="记录想法、灵感和日常思考的快速笔记">
      Memos
    </Headline>

    <!-- 直接使用 React 组件 -->
    <MemosAppWithProviders client:load isAdmin={isUserAdmin} />
  </section>
</Layout>

<style>
  /* 确保 React 组件的样式正确加载 */
  #memos-container {
    min-height: 400px;
  }

  /* 时间线样式增强 */
  .timeline-dot {
    box-shadow: 0 0 0 4px hsl(var(--p) / 0.1);
  }

  /* Markdown 内容样式 */
  .prose {
    max-width: none;
  }
</style>

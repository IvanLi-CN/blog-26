---
import { Icon } from "astro-icon/components";

import Button from "~/components/ui/Button.astro";
import Layout from "~/layouts/PageLayout.astro";
import { getCachedMemos } from "~/lib/content-cache";
import type { MetaData } from "~/types";
import { findFeaturedProjects, findLatestPosts } from "~/utils/blog";
import { getBlogPermalink } from "~/utils/permalinks";

export const prerender = false;

// 获取管理员状态
const isUserAdmin = Astro.locals.isAdmin || false;

// 获取最新文章、精选项目和最近闪念
const [latestPosts, featuredProjects, allMemos] = await Promise.all([
  findLatestPosts({ count: 6 }, isUserAdmin),
  findFeaturedProjects({ count: 12 }, isUserAdmin),
  getCachedMemos().catch(() => []),
]);

// 处理闪念数据
const filteredMemos = isUserAdmin
  ? allMemos
  : allMemos.filter((memo) => memo.public === true);

const recentMemos = filteredMemos
  .sort((a, b) => b.publishDate - a.publishDate)
  .slice(0, 5)
  .map((memo) => ({
    id: memo.id,
    slug: memo.slug,
    title: memo.title || "无标题",
    content: memo.body,
    publishDate: new Date(memo.publishDate * 1000),
    tags: memo.tags ? JSON.parse(memo.tags) : [],
  }));

const metadata: MetaData = {
  title: "首页",
  description: "这是 Ivan 的个人博客，记录和分享有关技术、生活和想法的内容。",
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  {/* Hero Section */}
  <section class="relative px-6 py-8 md:py-12 mx-auto max-w-6xl">
    <div class="text-center">
      <h1 class="text-3xl md:text-5xl font-bold mb-4">
        Ivan's <span class="text-accent">Blog</span>
      </h1>
      <p class="text-lg md:text-xl text-muted mb-6 max-w-2xl mx-auto">
        记录技术探索、生活感悟和创意想法的个人空间
      </p>
    </div>
  </section>

  {/* Recent Memos Section - 最近的几篇闪念作为动态 */}
  <section class="px-6 py-12 mx-auto max-w-6xl">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xl md:text-2xl font-bold flex items-center gap-2">
        <Icon name="tabler:bulb" class="w-5 h-5 text-yellow-500" />
        最近闪念 ({recentMemos.length})
      </h2>
      <Button variant="link" href="/memos" class="text-sm"> 查看全部 » </Button>
    </div>

    <div class="space-y-4">
      <div
        class="card bg-base-100 shadow-sm hover:shadow-md transition-shadow duration-200"
      >
        <div class="card-body p-5">
          <div class="flex items-start justify-between mb-3">
            <time class="text-xs text-muted"> 2025/1/15 </time>
            <Icon
              name="tabler:message-circle"
              class="w-4 h-4 text-muted flex-shrink-0"
            />
          </div>

          <div class="prose prose-sm max-w-none">
            <p class="text-sm leading-relaxed line-clamp-2">
              今天学习了 Astro
              的新特性，感觉非常有趣。特别是它的岛屿架构，让我对现代前端开发有了新的认识...
            </p>
          </div>
        </div>
      </div>

      <div
        class="card bg-base-100 shadow-sm hover:shadow-md transition-shadow duration-200"
      >
        <div class="card-body p-5">
          <div class="flex items-start justify-between mb-3">
            <time class="text-xs text-muted"> 2025/1/14 </time>
            <Icon
              name="tabler:message-circle"
              class="w-4 h-4 text-muted flex-shrink-0"
            />
          </div>

          <div class="prose prose-sm max-w-none">
            <p class="text-sm leading-relaxed line-clamp-2">
              正在重构博客系统，希望能提供更好的用户体验。新的设计更加简洁，加载速度也有所提升...
            </p>
          </div>
        </div>
      </div>

      <div
        class="card bg-base-100 shadow-sm hover:shadow-md transition-shadow duration-200"
      >
        <div class="card-body p-5">
          <div class="flex items-start justify-between mb-3">
            <time class="text-xs text-muted"> 2025/1/13 </time>
            <Icon
              name="tabler:message-circle"
              class="w-4 h-4 text-muted flex-shrink-0"
            />
          </div>

          <div class="prose prose-sm max-w-none">
            <p class="text-sm leading-relaxed line-clamp-2">
              分享一个有趣的技术发现：使用 WebDAV
              作为内容管理系统的后端存储，可以实现很灵活的内容同步...
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Latest Posts Section - 最近更新的文章 */}
  <section class="px-6 py-12 mx-auto max-w-6xl">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xl md:text-2xl font-bold flex items-center gap-2">
        <Icon name="tabler:notebook" class="w-5 h-5 text-blue-500" />
        最新文章 ({latestPosts.length})
      </h2>
      <Button variant="link" href={getBlogPermalink()} class="text-sm">
        查看全部 »
      </Button>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      <div
        class="card bg-base-100 shadow-sm hover:shadow-md transition-all duration-200"
      >
        <figure class="aspect-video overflow-hidden">
          <div
            class="w-full h-full bg-gradient-to-br from-blue-100 to-blue-200 flex items-center justify-center"
          >
            <span class="text-blue-600 text-sm">文章封面</span>
          </div>
        </figure>
        <div class="card-body p-4">
          <h3 class="card-title text-base mb-2 line-clamp-2">
            <a
              href="/blog/astro-guide"
              class="hover:text-primary transition-colors"
            >
              Astro 完全指南：构建现代静态网站
            </a>
          </h3>
          <p class="text-sm text-muted line-clamp-2 mb-3">
            深入了解 Astro 框架的核心概念，学习如何构建高性能的静态网站...
          </p>
          <div class="flex items-center justify-between text-xs text-muted">
            <span>2025/1/15</span>
            <span class="badge badge-outline badge-xs">技术</span>
          </div>
        </div>
      </div>

      <div
        class="card bg-base-100 shadow-sm hover:shadow-md transition-all duration-200"
      >
        <figure class="aspect-video overflow-hidden">
          <div
            class="w-full h-full bg-gradient-to-br from-green-100 to-green-200 flex items-center justify-center"
          >
            <span class="text-green-600 text-sm">文章封面</span>
          </div>
        </figure>
        <div class="card-body p-4">
          <h3 class="card-title text-base mb-2 line-clamp-2">
            <a
              href="/blog/webdav-cms"
              class="hover:text-primary transition-colors"
            >
              使用 WebDAV 构建内容管理系统
            </a>
          </h3>
          <p class="text-sm text-muted line-clamp-2 mb-3">
            探索如何使用 WebDAV 协议作为内容管理系统的后端存储方案...
          </p>
          <div class="flex items-center justify-between text-xs text-muted">
            <span>2025/1/14</span>
            <span class="badge badge-outline badge-xs">架构</span>
          </div>
        </div>
      </div>

      <div
        class="card bg-base-100 shadow-sm hover:shadow-md transition-all duration-200"
      >
        <figure class="aspect-video overflow-hidden">
          <div
            class="w-full h-full bg-gradient-to-br from-purple-100 to-purple-200 flex items-center justify-center"
          >
            <span class="text-purple-600 text-sm">文章封面</span>
          </div>
        </figure>
        <div class="card-body p-4">
          <h3 class="card-title text-base mb-2 line-clamp-2">
            <a
              href="/blog/frontend-optimization"
              class="hover:text-primary transition-colors"
            >
              前端性能优化最佳实践
            </a>
          </h3>
          <p class="text-sm text-muted line-clamp-2 mb-3">
            分享一些实用的前端性能优化技巧，帮助提升网站加载速度...
          </p>
          <div class="flex items-center justify-between text-xs text-muted">
            <span>2025/1/13</span>
            <span class="badge badge-outline badge-xs">优化</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Featured Projects Section - 底下用小卡片块显示几个项目 */}
  <section class="px-6 py-8 mx-auto max-w-6xl">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xl md:text-2xl font-bold flex items-center gap-2">
        <Icon name="tabler:code" class="w-5 h-5 text-green-500" />
        精选项目 ({featuredProjects.length})
      </h2>
      <Button variant="link" href="/projects" class="text-sm">
        查看全部 »
      </Button>
    </div>

    <div
      class="grid gap-2 grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6"
    >
      <div
        class="card bg-base-100 shadow-sm hover:shadow-md transition-all duration-200"
      >
        <div class="card-body p-3">
          <h3 class="card-title text-sm mb-1 line-clamp-1">
            <a
              href="/projects/chatbot-platform"
              class="hover:text-primary transition-colors"
            >
              智能聊天机器人平台
            </a>
          </h3>
          <span class="badge badge-outline badge-xs">AI</span>
        </div>
      </div>

      <div
        class="card bg-base-100 shadow-sm hover:shadow-md transition-all duration-200"
      >
        <div class="card-body p-3">
          <h3 class="card-title text-sm mb-1 line-clamp-1">
            <a
              href="/projects/microservices"
              class="hover:text-primary transition-colors"
            >
              微服务架构实践
            </a>
          </h3>
          <span class="badge badge-outline badge-xs">架构</span>
        </div>
      </div>

      <div
        class="card bg-base-100 shadow-sm hover:shadow-md transition-all duration-200"
      >
        <div class="card-body p-3">
          <h3 class="card-title text-sm mb-1 line-clamp-1">
            <a
              href="/projects/blog-system"
              class="hover:text-primary transition-colors"
            >
              个人博客系统
            </a>
          </h3>
          <span class="badge badge-outline badge-xs">前端</span>
        </div>
      </div>

      <div
        class="card bg-base-100 shadow-sm hover:shadow-md transition-all duration-200"
      >
        <div class="card-body p-3">
          <h3 class="card-title text-sm mb-1 line-clamp-1">
            <a
              href="/projects/data-viz"
              class="hover:text-primary transition-colors"
            >
              数据可视化大屏
            </a>
          </h3>
          <span class="badge badge-outline badge-xs">可视化</span>
        </div>
      </div>

      <div
        class="card bg-base-100 shadow-sm hover:shadow-md transition-all duration-200"
      >
        <div class="card-body p-3">
          <h3 class="card-title text-sm mb-1 line-clamp-1">
            <a
              href="/projects/code-review"
              class="hover:text-primary transition-colors"
            >
              AI代码审查工具
            </a>
          </h3>
          <span class="badge badge-outline badge-xs">工具</span>
        </div>
      </div>

      <div
        class="card bg-base-100 shadow-sm hover:shadow-md transition-all duration-200"
      >
        <div class="card-body p-3">
          <h3 class="card-title text-sm mb-1 line-clamp-1">
            <a
              href="/projects/performance"
              class="hover:text-primary transition-colors"
            >
              性能监控系统
            </a>
          </h3>
          <span class="badge badge-outline badge-xs">监控</span>
        </div>
      </div>
    </div>
  </section>
</Layout>

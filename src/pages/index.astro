---
import { Icon } from "astro-icon/components";
import TimelineItem from "~/components/home/TimelineItem.astro";
import Button from "~/components/ui/Button.astro";
import Layout from "~/layouts/PageLayout.astro";
import { getCachedMemos } from "~/lib/content-cache";
import type { MetaData } from "~/types";
import { findFeaturedProjects, findLatestPosts } from "~/utils/blog";

export const prerender = false;

// 获取管理员状态
const isUserAdmin = Astro.locals.isAdmin || false;

// 获取最新文章、精选项目和最近闪念
const [latestPosts, featuredProjects, allMemos] = await Promise.all([
  findLatestPosts({ count: 10 }, isUserAdmin),
  findFeaturedProjects({ count: 12 }, isUserAdmin),
  getCachedMemos().catch(() => []),
]);

// 处理闪念数据
const filteredMemos = isUserAdmin
  ? allMemos
  : allMemos.filter((memo) => memo.public === true);

const processedMemos = filteredMemos
  .sort((a, b) => b.publishDate - a.publishDate)
  .slice(0, 10)
  .map((memo) => ({
    type: "memo" as const,
    id: memo.id,
    slug: memo.slug,
    title: memo.title || "无标题",
    body: memo.body,
    publishDate: new Date(memo.publishDate * 1000),
    tags: memo.tags ? JSON.parse(memo.tags) : [],
  }));

// 处理文章数据
const processedPosts = latestPosts.slice(0, 10).map((post) => ({
  type: "post" as const,
  id: post.id,
  slug: post.slug,
  title: post.title,
  excerpt: post.excerpt,
  publishDate: post.publishDate,
  tags: post.tags?.map((tag) => tag.title) || [],
  image: post.image,
  permalink: post.permalink,
  dataSource: post.dataSource,
}));

// 合并文章和闪念，按时间排序
const timelineItems = [...processedPosts, ...processedMemos]
  .sort((a, b) => b.publishDate.getTime() - a.publishDate.getTime())
  .slice(0, 15); // 显示最新的15条

const metadata: MetaData = {
  title: "首页",
  description: "这是 Ivan 的个人博客，记录和分享有关技术、生活和想法的内容。",
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  {/* Hero Section */}
  <section class="relative px-6 py-8 md:py-12 mx-auto max-w-6xl">
    <div class="text-center">
      <h1 class="text-3xl md:text-5xl font-bold mb-4">
        Ivan's <span class="text-accent">Blog</span>
      </h1>
      <p class="text-lg md:text-xl text-muted mb-6 max-w-2xl mx-auto">
        记录技术探索、生活感悟和创意想法的个人空间
      </p>
    </div>
  </section>

  {/* Timeline Section - 文章和闪念混合时间线 */}
  <section class="px-6 py-12 mx-auto max-w-4xl">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-xl md:text-2xl font-bold flex items-center gap-2">
        <Icon name="tabler:timeline" class="w-5 h-5 text-primary" />
        最新动态 ({timelineItems.length})
      </h2>
      <div class="flex gap-2">
        <!-- 加载状态演示按钮 -->
        <button
          id="toggle-loading"
          class="btn btn-sm btn-outline"
          title="切换加载状态演示"
        >
          <Icon name="tabler:refresh" class="w-4 h-4" />
          演示加载
        </button>
        <Button variant="link" href="/blog" class="text-sm">
          全部文章 »
        </Button>
        <Button variant="link" href="/memos" class="text-sm">
          全部闪念 »
        </Button>
      </div>
    </div>

    <div class="timeline flex flex-col space-y-4">
      {
        timelineItems.length > 0 ? (
          timelineItems.map((item, index) => (
            <TimelineItem
              item={item}
              isLast={index === timelineItems.length - 1}
            />
          ))
        ) : (
          <div class="text-center py-8 text-muted">
            <Icon
              name="tabler:timeline"
              class="w-8 h-8 mx-auto mb-2 opacity-50"
            />
            <p>暂无内容</p>
          </div>
        )
      }
    </div>
  </section>

  {/* Featured Projects Section - 底下用小卡片块显示几个项目 */}
  <section class="px-6 py-8 mx-auto max-w-6xl">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xl md:text-2xl font-bold flex items-center gap-2">
        <Icon name="tabler:code" class="w-5 h-5 text-green-500" />
        精选项目 ({featuredProjects.length})
      </h2>
      <Button variant="link" href="/projects" class="text-sm">
        查看全部 »
      </Button>
    </div>

    <div
      class="grid gap-2 grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6"
    >
      <div
        class="card bg-base-100 shadow-sm hover:shadow-md transition-all duration-200"
      >
        <div class="card-body p-3">
          <h3 class="card-title text-sm mb-1 line-clamp-1">
            <a
              href="/projects/chatbot-platform"
              class="hover:text-primary transition-colors"
            >
              智能聊天机器人平台
            </a>
          </h3>
          <span class="badge badge-outline badge-xs">AI</span>
        </div>
      </div>

      <div
        class="card bg-base-100 shadow-sm hover:shadow-md transition-all duration-200"
      >
        <div class="card-body p-3">
          <h3 class="card-title text-sm mb-1 line-clamp-1">
            <a
              href="/projects/microservices"
              class="hover:text-primary transition-colors"
            >
              微服务架构实践
            </a>
          </h3>
          <span class="badge badge-outline badge-xs">架构</span>
        </div>
      </div>

      <div
        class="card bg-base-100 shadow-sm hover:shadow-md transition-all duration-200"
      >
        <div class="card-body p-3">
          <h3 class="card-title text-sm mb-1 line-clamp-1">
            <a
              href="/projects/blog-system"
              class="hover:text-primary transition-colors"
            >
              个人博客系统
            </a>
          </h3>
          <span class="badge badge-outline badge-xs">前端</span>
        </div>
      </div>

      <div
        class="card bg-base-100 shadow-sm hover:shadow-md transition-all duration-200"
      >
        <div class="card-body p-3">
          <h3 class="card-title text-sm mb-1 line-clamp-1">
            <a
              href="/projects/data-viz"
              class="hover:text-primary transition-colors"
            >
              数据可视化大屏
            </a>
          </h3>
          <span class="badge badge-outline badge-xs">可视化</span>
        </div>
      </div>

      <div
        class="card bg-base-100 shadow-sm hover:shadow-md transition-all duration-200"
      >
        <div class="card-body p-3">
          <h3 class="card-title text-sm mb-1 line-clamp-1">
            <a
              href="/projects/code-review"
              class="hover:text-primary transition-colors"
            >
              AI代码审查工具
            </a>
          </h3>
          <span class="badge badge-outline badge-xs">工具</span>
        </div>
      </div>

      <div
        class="card bg-base-100 shadow-sm hover:shadow-md transition-all duration-200"
      >
        <div class="card-body p-3">
          <h3 class="card-title text-sm mb-1 line-clamp-1">
            <a
              href="/projects/performance"
              class="hover:text-primary transition-colors"
            >
              性能监控系统
            </a>
          </h3>
          <span class="badge badge-outline badge-xs">监控</span>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  // 加载状态演示功能
  document.addEventListener("DOMContentLoaded", () => {
    const toggleButton = document.getElementById("toggle-loading");
    const timeline = document.querySelector(".timeline");
    let isLoading = false;

    if (toggleButton && timeline) {
      toggleButton.addEventListener("click", () => {
        isLoading = !isLoading;

        if (isLoading) {
          // 显示加载状态
          timeline.innerHTML = Array.from(
            { length: 5 },
            (_, index) => `
            <div class="timeline-item relative flex items-start gap-4 pb-8">
              <!-- 时间线主轴和节点 -->
              <div class="flex flex-col items-center relative">
                <!-- 时间线节点（加载状态） -->
                <div class="flex items-center justify-center w-10 h-10 rounded-full bg-base-200 border-2 border-base-300 flex-shrink-0 z-10 relative">
                  <div class="w-5 h-5 bg-base-300 rounded-full animate-pulse"></div>
                </div>

                <!-- 时间线主轴（连接线） -->
                ${index < 4 ? '<div class="w-0.5 h-32 bg-base-300 opacity-30 absolute top-10 left-1/2 transform -translate-x-1/2"></div>' : ""}
              </div>

              <!-- 内容区域（加载状态） -->
              <div class="flex-1 min-w-0">
                <!-- 时间和类型信息（加载状态） -->
                <div class="flex items-center gap-2 mb-2">
                  <div class="h-4 bg-base-300 rounded w-20 animate-pulse"></div>
                  <div class="h-5 bg-base-300 rounded w-12 animate-pulse"></div>
                </div>

                <!-- 内容卡片（加载状态） -->
                <div class="card bg-base-100 shadow-sm border border-base-200">
                  <div class="card-body p-4">
                    <!-- 骨架屏占位内容 -->
                    <div class="h-20 bg-base-200 rounded mb-2 animate-pulse"></div>
                    <div class="h-3 bg-base-300 rounded w-3/4 mb-1 animate-pulse"></div>
                    <div class="h-3 bg-base-300 rounded w-1/2 animate-pulse"></div>
                  </div>
                </div>
              </div>
            </div>
          `,
          ).join("");

          toggleButton.textContent = "显示内容";
        } else {
          // 重新加载页面显示真实内容
          window.location.reload();
        }
      });
    }
  });
</script>

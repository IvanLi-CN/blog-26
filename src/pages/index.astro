---
import { Icon } from "astro-icon/components";
import TimelineItem from "~/components/home/TimelineItem.astro";
import Button from "~/components/ui/Button.astro";
import Layout from "~/layouts/PageLayout.astro";
import { getCachedMemos } from "~/lib/content-cache";
import type { MetaData } from "~/types";
import { findFeaturedProjects, findLatestPosts } from "~/utils/blog";

export const prerender = false;

// 获取管理员状态
const isUserAdmin = Astro.locals.isAdmin || false;

// 获取最新文章、精选项目和最近闪念
const [latestPosts, featuredProjects, allMemos] = await Promise.all([
  findLatestPosts({ count: 10 }, isUserAdmin),
  findFeaturedProjects({ count: 12 }, isUserAdmin),
  getCachedMemos().catch(() => []),
]);

// 处理闪念数据
const filteredMemos = isUserAdmin
  ? allMemos
  : allMemos.filter((memo) => memo.public === true);

const processedMemos = filteredMemos
  .sort((a, b) => b.publishDate - a.publishDate)
  .slice(0, 10)
  .map((memo) => ({
    type: "memo" as const,
    id: memo.id,
    slug: memo.slug,
    title: memo.title || "无标题",
    body: memo.body,
    publishDate: new Date(memo.publishDate * 1000),
    tags: memo.tags ? JSON.parse(memo.tags) : [],
  }));

// 处理文章数据
const processedPosts = latestPosts.slice(0, 10).map((post) => ({
  type: "post" as const,
  id: post.id,
  slug: post.slug,
  title: post.title,
  excerpt: post.excerpt,
  publishDate: post.publishDate,
  tags: post.tags?.map((tag) => tag.title) || [],
  image: post.image,
  permalink: post.permalink,
  dataSource: post.dataSource,
}));

// 合并文章和闪念，按时间排序
const timelineItems = [...processedPosts, ...processedMemos]
  .sort((a, b) => b.publishDate.getTime() - a.publishDate.getTime())
  .slice(0, 15); // 显示最新的15条

const metadata: MetaData = {
  title: "首页",
  description: "这是 Ivan 的个人博客，记录和分享有关技术、生活和想法的内容。",
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  {/* Hero Section */}
  <section
    class="relative px-3 sm:px-4 md:px-6 py-6 md:py-12 mx-auto max-w-6xl"
  >
    <div class="text-center">
      <h1 class="text-3xl md:text-5xl font-bold mb-4">
        Ivan's <span class="text-accent">Blog</span>
      </h1>
      <p class="text-lg md:text-xl text-muted mb-6 max-w-2xl mx-auto">
        记录技术探索、生活感悟和创意想法的个人空间
      </p>
    </div>
  </section>

  {/* Timeline Section - 文章和闪念混合时间线 */}
  <section class="px-3 sm:px-4 md:px-6 py-8 md:py-12 mx-auto max-w-4xl">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-xl md:text-2xl font-bold flex items-center gap-2">
        <Icon name="tabler:timeline" class="w-5 h-5 text-primary" />
        最新动态
      </h2>
      <!-- 简洁的导航链接 -->
      <div class="flex items-center gap-4 text-sm">
        <a
          href="/blog"
          class="flex items-center gap-1 text-muted hover:text-primary transition-colors"
        >
          <Icon name="tabler:article" class="w-4 h-4" />
          文章
        </a>
        <a
          href="/memos"
          class="flex items-center gap-1 text-muted hover:text-primary transition-colors"
        >
          <Icon name="tabler:bulb" class="w-4 h-4" />
          闪念
        </a>
      </div>
    </div>

    <div class="timeline flex flex-col">
      {
        timelineItems.length > 0 ? (
          timelineItems.map((item, index) => (
            <TimelineItem
              item={item}
              isLast={index === timelineItems.length - 1}
            />
          ))
        ) : (
          <div class="text-center py-8 text-muted">
            <Icon
              name="tabler:timeline"
              class="w-8 h-8 mx-auto mb-2 opacity-50"
            />
            <p>暂无内容</p>
          </div>
        )
      }
    </div>
  </section>

  {/* Featured Projects Section - 底下用小卡片块显示几个项目 */}
  <section class="px-3 sm:px-4 md:px-6 py-6 md:py-8 mx-auto max-w-6xl">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xl md:text-2xl font-bold flex items-center gap-2">
        <Icon name="tabler:code" class="w-5 h-5 text-green-500" />
        精选项目 ({featuredProjects.length})
      </h2>
      <Button variant="link" href="/projects" class="text-sm">
        查看全部 »
      </Button>
    </div>

    <div
      class="grid gap-2 grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6"
    >
      <div
        class="card bg-base-100 shadow-sm hover:shadow-md transition-all duration-200"
      >
        <div class="card-body p-2 sm:p-3">
          <h3 class="card-title text-sm mb-1 line-clamp-1">
            <a
              href="/projects/chatbot-platform"
              class="hover:text-primary transition-colors"
            >
              智能聊天机器人平台
            </a>
          </h3>
          <span class="badge badge-outline badge-xs">AI</span>
        </div>
      </div>

      <div
        class="card bg-base-100 shadow-sm hover:shadow-md transition-all duration-200"
      >
        <div class="card-body p-2 sm:p-3">
          <h3 class="card-title text-sm mb-1 line-clamp-1">
            <a
              href="/projects/microservices"
              class="hover:text-primary transition-colors"
            >
              微服务架构实践
            </a>
          </h3>
          <span class="badge badge-outline badge-xs">架构</span>
        </div>
      </div>

      <div
        class="card bg-base-100 shadow-sm hover:shadow-md transition-all duration-200"
      >
        <div class="card-body p-2 sm:p-3">
          <h3 class="card-title text-sm mb-1 line-clamp-1">
            <a
              href="/projects/blog-system"
              class="hover:text-primary transition-colors"
            >
              个人博客系统
            </a>
          </h3>
          <span class="badge badge-outline badge-xs">前端</span>
        </div>
      </div>

      <div
        class="card bg-base-100 shadow-sm hover:shadow-md transition-all duration-200"
      >
        <div class="card-body p-2 sm:p-3">
          <h3 class="card-title text-sm mb-1 line-clamp-1">
            <a
              href="/projects/data-viz"
              class="hover:text-primary transition-colors"
            >
              数据可视化大屏
            </a>
          </h3>
          <span class="badge badge-outline badge-xs">可视化</span>
        </div>
      </div>

      <div
        class="card bg-base-100 shadow-sm hover:shadow-md transition-all duration-200"
      >
        <div class="card-body p-2 sm:p-3">
          <h3 class="card-title text-sm mb-1 line-clamp-1">
            <a
              href="/projects/code-review"
              class="hover:text-primary transition-colors"
            >
              AI代码审查工具
            </a>
          </h3>
          <span class="badge badge-outline badge-xs">工具</span>
        </div>
      </div>

      <div
        class="card bg-base-100 shadow-sm hover:shadow-md transition-all duration-200"
      >
        <div class="card-body p-2 sm:p-3">
          <h3 class="card-title text-sm mb-1 line-clamp-1">
            <a
              href="/projects/performance"
              class="hover:text-primary transition-colors"
            >
              性能监控系统
            </a>
          </h3>
          <span class="badge badge-outline badge-xs">监控</span>
        </div>
      </div>
    </div>
  </section>
</Layout>

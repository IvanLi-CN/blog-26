---
import { Icon } from "astro-icon/components";
import Footer from "~/components/widgets/Footer.astro";
import { footerData } from "~/navigation";
import type { MetaData } from "~/types";
import Header from "../components/widgets/Header.astro";
import Layout from "../layouts/Layout.astro";
import { headerData } from "../navigation";

const metadata: MetaData = {
  title: "首页",
  description: "这是 Ivan 的个人博客，记录和分享有关技术、生活和想法的内容。",
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <div class="flex flex-col min-h-screen">
    <Header showToggleTheme showRssFeed isSticky {...headerData} />
    <main class="flex-grow">
      <div class="container px-4 mx-auto">
        <div role="alert" class="alert alert-vertical sm:alert-horizontal">
          <Icon name="line-md:bell-alert-twotone-loop" class="w-5 h-5 inline" />
          <div>
            <h3 class="font-bold">站点完善中</h3>
            <div class="text-xs">
              <p>
                反正博客页面能用了，剩下的就靠最近能不能挤出时间填这个坑了
                <Icon
                  name="fluent-emoji-flat:face-with-tears-of-joy"
                  class="w-5 h-5 inline"
                />
              </p>
              <p>目前首页和搜索还没做</p>
            </div>
          </div>
        </div>
      </div>
    </main>
    <Footer {...footerData} />
  </div>
</Layout>

---
import merge from "lodash.merge";
import RelatedPosts from "~/components/blog/RelatedPosts.astro";
import SinglePost from "~/components/blog/SinglePost.astro";
import ToBlogLink from "~/components/blog/ToBlogLink.astro";
import MarkdownRenderer from "~/components/common/MarkdownRenderer";
import Layout from "~/layouts/PageLayout.astro";

import type { MetaData } from "~/types";
import { blogPostRobots, getPostBySlug } from "~/utils/blog";
import { create404Response } from "~/utils/error-handler";

import { getCanonical, getPermalink } from "~/utils/permalinks";

export const prerender = false;

const { blog: slug } = Astro.params;

if (!slug) {
  return create404Response(Astro.request, "Blog post not found");
}

// 从 Astro.locals 获取管理员状态
const isUserAdmin = Astro.locals.isAdmin || false;

const post = await getPostBySlug(slug, isUserAdmin);

if (!post) {
  return create404Response(Astro.request, "Blog post not found");
}

// 权限检查：如果文章是私有的或者是草稿，且用户不是管理员，则返回404
if (!isUserAdmin && (post.draft || !post.public)) {
  return create404Response(Astro.request, "Blog post not found");
}

const url = getCanonical(getPermalink(post.permalink, "post"));
// 不使用 findImage，直接传递图片路径和数据源信息
const image = post.image;

const metadata = merge(
  {
    title: post.title,
    description: post.excerpt,
    robots: {
      index: blogPostRobots?.index,
      follow: blogPostRobots?.follow,
    },
    openGraph: {
      type: "article",
      ...(image
        ? {
            images: [
              {
                url: typeof image === "string" ? image : image,
                width: 1200, // 默认宽度
                height: 630, // 默认高度
              },
            ],
          }
        : {}),
    },
  },
  {
    ...(post?.metadata
      ? { ...post.metadata, canonical: post.metadata?.canonical || url }
      : {}),
  },
) as MetaData;
---

<Layout metadata={metadata}>
  <SinglePost post={{ ...post, image: image }} url={url}>
    <MarkdownRenderer
      client:load
      content={post.body || post.content || ""}
      variant="detail"
      className="prose prose-md xl:text-lg dark:prose-invert dark:prose-headings:text-slate-300 prose-headings:font-heading prose-headings:leading-tighter prose-headings:tracking-tighter prose-headings:font-bold prose-a:text-primary dark:prose-a:text-blue-400 prose-img:rounded-md prose-img:shadow-lg prose-headings:scroll-mt-[80px] prose-li:my-0"
    />
  </SinglePost>
  <ToBlogLink />
  <RelatedPosts post={post} />
</Layout>

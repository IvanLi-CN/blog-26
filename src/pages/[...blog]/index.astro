---
import type { ImageMetadata } from "astro";
import merge from "lodash.merge";
import RelatedPosts from "~/components/blog/RelatedPosts.astro";
import SinglePost from "~/components/blog/SinglePost.astro";
import ToBlogLink from "~/components/blog/ToBlogLink.astro";
import Layout from "~/layouts/PageLayout.astro";
import { isAdminFromRequest } from "~/lib/auth";
import type { MetaData } from "~/types";
import { blogPostRobots, getPostBySlug } from "~/utils/blog";
import { create404Response } from "~/utils/error-handler";
import { findImage } from "~/utils/images";
import { getCanonical, getPermalink } from "~/utils/permalinks";

export const prerender = false;

const { blog: slug } = Astro.params;

if (!slug) {
  return create404Response(Astro.request, "Blog post not found");
}

// 检查用户是否为管理员
const isUserAdmin = await isAdminFromRequest(
  Astro.cookies,
  Astro.request.headers,
);

// 如果是管理员，设置 ADMIN_MODE 以获取所有文章（包括私有和草稿）
if (isUserAdmin) {
  process.env.ADMIN_MODE = "true";
}

const post = await getPostBySlug(slug);

if (!post) {
  return create404Response(Astro.request, "Blog post not found");
}

// 权限检查：如果文章是私有的或者是草稿，且用户不是管理员，则返回404
if (!isUserAdmin && (post.draft || !post.public)) {
  return create404Response(Astro.request, "Blog post not found");
}

const url = getCanonical(getPermalink(post.permalink, "post"));
const image = (await findImage(post.image)) as
  | ImageMetadata
  | string
  | undefined;

const metadata = merge(
  {
    title: post.title,
    description: post.excerpt,
    robots: {
      index: blogPostRobots?.index,
      follow: blogPostRobots?.follow,
    },
    openGraph: {
      type: "article",
      ...(image
        ? {
            images: [
              {
                url: image,
                width: (image as ImageMetadata)?.width,
                height: (image as ImageMetadata)?.height,
              },
            ],
          }
        : {}),
    },
  },
  {
    ...(post?.metadata
      ? { ...post.metadata, canonical: post.metadata?.canonical || url }
      : {}),
  },
) as MetaData;
---

<Layout metadata={metadata}>
  <SinglePost post={{ ...post, image: image }} url={url}>
    {
      post.Content ? (
        <post.Content />
      ) : (
        <Fragment set:html={post.content || ""} />
      )
    }
  </SinglePost>
  <ToBlogLink />
  <RelatedPosts post={post} />
</Layout>

---
import type { ImageMetadata } from "astro";
import merge from "lodash.merge";
import CommentSectionWithProvider from "~/components/comments/CommentSectionWithProvider";
import ContentImageHandler from "~/components/common/ContentImageHandler";
import MemoDetailWithEditProvider from "~/components/memos/MemoDetailWithEditProvider";
import MemoReactionsWithProvider from "~/components/memos/MemoReactionsWithProvider";
import Layout from "~/layouts/PageLayout.astro";
import { getCachedMemoBySlug } from "~/lib/content-cache";
import type { MetaData } from "~/types";
import { create404Response } from "~/utils/error-handler";
import { findImage } from "~/utils/images";
import { parseMarkdownToHTML } from "~/utils/markdown";
import { getCanonical, getPermalink } from "~/utils/permalinks";
import { removeTagsFromContent } from "~/utils/utils";

export const prerender = false;

const { slug } = Astro.params;

if (!slug) {
  return create404Response(Astro.request, "Memo not found");
}

// 从 Astro.locals 获取管理员状态
const isUserAdmin = Astro.locals.isAdmin || false;

let memo: any = null;

try {
  memo = await getCachedMemoBySlug(slug);
} catch (error) {
  console.error("Failed to get cached memo:", error);
  return create404Response(Astro.request, "Memo not available");
}

if (!memo) {
  return create404Response(Astro.request, "Memo not found");
}

// 权限检查：如果闪念是私有的，且用户不是管理员，则返回404
if (!isUserAdmin && !memo.public) {
  return create404Response(Astro.request, "Memo not found");
}

// 移除标签并渲染 markdown 内容
const bodyWithoutTags = removeTagsFromContent(memo.body);
const content = await parseMarkdownToHTML(bodyWithoutTags, memo.id);

const url = getCanonical(getPermalink(slug, "memo"));
const image = (await findImage(memo.image)) as
  | ImageMetadata
  | string
  | undefined;

const metadata = merge(
  {
    title: memo.title || "无标题 Memo",
    description: memo.excerpt || memo.body?.substring(0, 160) + "...",
    robots: {
      index: memo.public,
      follow: memo.public,
    },
    openGraph: {
      type: "article",
      ...(image
        ? {
            images: [
              {
                url: image,
                width: (image as ImageMetadata)?.width,
                height: (image as ImageMetadata)?.height,
              },
            ],
          }
        : {}),
    },
  },
  {
    canonical: url,
  },
) as MetaData;

// 转换数据格式
const memoData = {
  id: memo.id,
  slug: memo.slug,
  title: memo.title || "无标题 Memo",
  content,
  body: memo.body,
  publishDate: new Date(memo.publishDate * 1000),
  updateDate: memo.updateDate ? new Date(memo.updateDate * 1000) : undefined,
  public: memo.public,
  attachments: memo.attachments ? JSON.parse(memo.attachments) : [],
  tags: memo.tags ? JSON.parse(memo.tags) : [],
  image: image,
};
---

<Layout metadata={metadata}>
  <article class="px-6 sm:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <!-- 头部信息 -->
    <header class="mb-8">
      <div class="flex items-center gap-2 text-sm text-base-content/60 mb-4">
        <a href="/memos" class="hover:text-primary">闪念</a>
        <span>/</span>
        <span>{memoData.title}</span>
      </div>

      <h1 class="text-3xl md:text-4xl font-bold text-base-content mb-4">
        {memoData.title}
      </h1>

      <div
        class="flex flex-wrap items-center gap-4 text-sm text-base-content/60"
      >
        <time datetime={memoData.publishDate.toISOString()}>
          {
            memoData.publishDate.toLocaleDateString("zh-CN", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })
          }
        </time>

        {
          memoData.updateDate &&
            memoData.updateDate.getTime() !==
              memoData.publishDate.getTime() && (
              <span>
                更新于{" "}
                <time datetime={memoData.updateDate.toISOString()}>
                  {memoData.updateDate.toLocaleDateString("zh-CN", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
              </span>
            )
        }

        {
          !memoData.public && (
            <span class="badge badge-warning badge-sm">私有</span>
          )
        }
      </div>
    </header>

    <!-- 标签 -->
    {
      memoData.tags && memoData.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-6">
          {memoData.tags.map((tag: string) => (
            <span class="badge badge-outline badge-sm">#{tag}</span>
          ))}
        </div>
      )
    }

    <!-- 内容 -->
    <ContentImageHandler client:only="react">
      <MemoDetailWithEditProvider
        client:load
        memoData={memoData}
        isAdmin={isUserAdmin}
      />
    </ContentImageHandler>

    <!-- 附件 -->
    {
      (() => {
        // 过滤掉已经在内容中使用的图片
        const contentImagePaths = new Set();
        const imageRegex = /!\[.*?\]\(([^)]+)\)/g;
        let match: RegExpExecArray | null;
        while ((match = imageRegex.exec(memo.body)) !== null) {
          let imagePath = match[1];
          // 标准化路径格式
          if (imagePath.startsWith("./")) {
            imagePath = imagePath.substring(2);
          }
          if (
            !imagePath.startsWith("assets/") &&
            !imagePath.startsWith("/") &&
            !imagePath.startsWith("http")
          ) {
            imagePath = `assets/${imagePath}`;
          }
          contentImagePaths.add(imagePath);
        }

        // 过滤附件，只显示不在内容中的附件
        const filteredAttachments =
          memoData.attachments?.filter((attachment: any) => {
            let attachmentPath = attachment.path;
            // 标准化附件路径格式
            if (attachmentPath.startsWith("./")) {
              attachmentPath = attachmentPath.substring(2);
            }
            if (attachmentPath.startsWith("/")) {
              attachmentPath = attachmentPath.substring(1);
            }
            return !contentImagePaths.has(attachmentPath);
          }) || [];

        return filteredAttachments.length > 0;
      })() && (
        <div class="mt-8">
          <h3 class="text-lg font-semibold mb-4">附件</h3>
          <ContentImageHandler client:only="react">
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
              {(() => {
                // 重复过滤逻辑（因为 Astro 模板限制）
                const contentImagePaths = new Set();
                const imageRegex = /!\[.*?\]\(([^)]+)\)/g;
                let match: RegExpExecArray | null;
                while ((match = imageRegex.exec(memo.body)) !== null) {
                  let imagePath = match[1];
                  if (imagePath.startsWith("./")) {
                    imagePath = imagePath.substring(2);
                  }
                  if (
                    !imagePath.startsWith("assets/") &&
                    !imagePath.startsWith("/") &&
                    !imagePath.startsWith("http")
                  ) {
                    imagePath = `assets/${imagePath}`;
                  }
                  contentImagePaths.add(imagePath);
                }

                const filteredAttachments =
                  memoData.attachments?.filter((attachment: any) => {
                    let attachmentPath = attachment.path;
                    if (attachmentPath.startsWith("./")) {
                      attachmentPath = attachmentPath.substring(2);
                    }
                    if (attachmentPath.startsWith("/")) {
                      attachmentPath = attachmentPath.substring(1);
                    }
                    return !contentImagePaths.has(attachmentPath);
                  }) || [];

                return filteredAttachments;
              })().map((attachment: any, attachmentIndex: number) => (
                <div
                  class="card bg-base-200 shadow-sm"
                  data-attachment-key={`attachment-${attachmentIndex}-${attachment.filename}`}
                >
                  <div class="card-body p-4">
                    {attachment.isImage ? (
                      <img
                        src={`/api/render-image/${attachment.path.replace(/^\//, "")}?w=300&f=webp&q=85&display-w=300&display-h=300`}
                        alt={attachment.filename}
                        class="w-full h-32 object-cover rounded bg-base-200 content-image cursor-pointer"
                        loading="lazy"
                        data-lightbox="true"
                        data-original-src={`/api/render-image/${attachment.path.replace(/^\//, "")}?f=webp&q=95&s=2048`}
                      />
                    ) : (
                      <div class="flex items-center justify-center h-32 bg-base-300 rounded">
                        <span class="text-2xl">📄</span>
                      </div>
                    )}
                    <div class="mt-2">
                      <p
                        class="text-sm font-medium truncate"
                        title={attachment.filename}
                      >
                        {attachment.filename}
                      </p>
                      {attachment.size && (
                        <p class="text-xs text-base-content/60">
                          {(attachment.size / 1024).toFixed(1)} KB
                        </p>
                      )}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </ContentImageHandler>
        </div>
      )
    }

    <!-- 表情反应 -->
    <div class="mt-8 pt-6 border-t border-base-300">
      <h3 class="text-lg font-semibold mb-4">表情反应</h3>
      <MemoReactionsWithProvider client:load memoSlug={memoData.slug} />
    </div>

    <!-- 评论区域 -->
    <div class="mt-8 pt-6 border-t border-base-300">
      <CommentSectionWithProvider
        client:load
        postSlug={memoData.slug}
        title="评论"
        texts={{
          title: "评论",
          submitSuccess: "评论已提交，正在等待审核。",
          loadingText: "加载中...",
          loadMoreText: "加载更多",
        }}
      />
    </div>

    <!-- 返回链接 -->
    <div class="mt-8 pt-8 border-t border-base-300">
      <a href="/memos" class="btn btn-outline btn-sm"> ← 返回闪念列表 </a>
    </div>
  </article>
</Layout>

<style>
  /* 确保 prose 样式正确应用 */
  .prose {
    color: inherit;
  }

  .prose h1,
  .prose h2,
  .prose h3,
  .prose h4,
  .prose h5,
  .prose h6 {
    color: inherit;
  }

  .prose a {
    color: hsl(var(--p));
  }

  .prose a:hover {
    color: hsl(var(--pf));
  }
</style>

---
import { Icon } from "astro-icon/components";
import ProjectCard from "~/components/project/ProjectCard.astro";
import Headline from "~/components/ui/Headline.astro";
import Layout from "~/layouts/PageLayout.astro";
import type { Post } from "~/types";
import { fetchProjects } from "~/utils/blog";

export const prerender = false;

// 获取所有项目
let allProjects: Post[] = [];
try {
  allProjects = await fetchProjects();
} catch (error) {
  console.error("Failed to load projects:", error);
  allProjects = [];
}

// 显示所有项目
const filteredProjects = allProjects;

// 获取所有标签用于过滤
const allTags = [
  ...new Set(
    allProjects.flatMap((project) =>
      (project.tags || []).map((tag) =>
        typeof tag === "string" ? tag : tag.title,
      ),
    ),
  ),
];
const projectTags = allTags
  .filter((tag) => tag.startsWith("Project/"))
  .map((tag) => tag.replace("Project/", ""));

const metadata = {
  title: "所有项目",
  description:
    "Ivan 的所有个人项目列表，包括硬件设计、软件开发和创意实验项目。",
  robots: {
    index: true,
    follow: true,
  },
};
---

<Layout metadata={metadata}>
  <section class="px-4 md:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-7xl">
    <!-- 页面标题 -->
    <div class="text-center mb-12">
      <Headline>
        <Fragment slot="title">所有项目</Fragment>
        <Fragment slot="subtitle">
          共 {filteredProjects.length} 个项目
        </Fragment>
      </Headline>
    </div>

    <!-- 项目网格 -->
    {
      filteredProjects.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
          {filteredProjects.map((project, index) => (
            <div
              class="animate-fade-in-up"
              style={`animation-delay: ${index * 100}ms`}
            >
              <ProjectCard project={project} />
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <Icon
            name="tabler:folder-open"
            class="w-16 h-16 mx-auto text-base-content/30 mb-4"
          />
          <h3 class="text-xl font-semibold mb-2">暂无项目</h3>
          <p class="text-base-content/70 mb-6">还没有添加任何项目</p>
          <a href="/projects" class="btn btn-primary">
            <Icon name="tabler:arrow-left" class="w-4 h-4" />
            返回项目首页
          </a>
        </div>
      )
    }

    <!-- 项目标签云 -->
    {
      projectTags.length > 0 && (
        <div class="border-t border-base-300 pt-12">
          <h3 class="text-xl font-bold text-center mb-6">项目标签</h3>
          <div class="flex flex-wrap justify-center gap-2">
            {projectTags.map((tag) => (
              <div class="badge badge-outline badge-lg">{tag}</div>
            ))}
          </div>
        </div>
      )
    }

    <!-- 返回按钮 -->
    <div class="text-center mt-12">
      <a href="/projects" class="btn btn-outline">
        <Icon name="tabler:arrow-left" class="w-4 h-4" />
        返回项目首页
      </a>
    </div>
  </section>
</Layout>

<style>
  .animate-fade-in-up {
    animation: fadeInUp 0.6s ease-out forwards;
    opacity: 0;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

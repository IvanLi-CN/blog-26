---
import VectorizeView from "~/components/vectorization/VectorizeView";
import Layout from "~/layouts/PageLayout.astro";

const metadata = {
  title: "向量化管理",
};
---

<Layout metadata={metadata}>
  <div class="max-w-7xl mx-auto py-8 px-4">
    <!-- 页面头部 -->
    <div class="mb-8">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h1 class="text-3xl font-bold">内容向量化管理</h1>
          <p class="text-base-content/70 mt-2">
            管理和监控博客内容的向量化过程，提升智能搜索体验
          </p>
        </div>
        <div class="flex items-center space-x-2">
          <a href="/admin/posts" class="btn btn-outline btn-sm">
            <svg
              class="w-4 h-4 mr-1"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
              ></path>
            </svg>
            文章管理
          </a>
          <a href="/admin" class="btn btn-ghost btn-sm">
            <svg
              class="w-4 h-4 mr-1"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2-2z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M8 5a2 2 0 012-2h2a2 2 0 012 2v0H8v0z"></path>
            </svg>
            管理首页
          </a>
        </div>
      </div>

      <!-- 快速状态概览 -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
        <div class="bg-base-100 border border-base-300 rounded-lg p-4">
          <div class="flex items-center space-x-3">
            <div
              class="w-10 h-10 rounded-full bg-success/10 flex items-center justify-center"
            >
              <div class="w-4 h-4 rounded-full bg-success"></div>
            </div>
            <div class="min-w-0 flex-1">
              <div class="text-xs text-base-content/60 font-medium">已索引</div>
              <div
                id="quickIndexedCount"
                class="text-2xl font-bold text-success"
              >
                -
              </div>
              <div class="text-xs text-base-content/50">可用于搜索</div>
            </div>
          </div>
        </div>

        <div class="bg-base-100 border border-base-300 rounded-lg p-4">
          <div class="flex items-center space-x-3">
            <div
              class="w-10 h-10 rounded-full bg-warning/10 flex items-center justify-center"
            >
              <div class="w-4 h-4 rounded-full bg-warning"></div>
            </div>
            <div class="min-w-0 flex-1">
              <div class="text-xs text-base-content/60 font-medium">需更新</div>
              <div
                id="quickMismatchCount"
                class="text-2xl font-bold text-warning"
              >
                -
              </div>
              <div class="text-xs text-base-content/50">模型已更新</div>
            </div>
          </div>
        </div>

        <div class="bg-base-100 border border-base-300 rounded-lg p-4">
          <div class="flex items-center space-x-3">
            <div
              class="w-10 h-10 rounded-full bg-error/10 flex items-center justify-center"
            >
              <div class="w-4 h-4 rounded-full bg-error"></div>
            </div>
            <div class="min-w-0 flex-1">
              <div class="text-xs text-base-content/60 font-medium">未索引</div>
              <div
                id="quickNotIndexedCount"
                class="text-2xl font-bold text-error"
              >
                -
              </div>
              <div class="text-xs text-base-content/50">待处理</div>
            </div>
          </div>
        </div>

        <div class="bg-base-100 border border-base-300 rounded-lg p-4">
          <div class="flex items-center space-x-3">
            <div
              class="w-10 h-10 rounded-full bg-info/10 flex items-center justify-center"
            >
              <div class="w-4 h-4 rounded-full bg-info"></div>
            </div>
            <div class="min-w-0 flex-1">
              <div class="text-xs text-base-content/60 font-medium">总计</div>
              <div id="quickTotalCount" class="text-2xl font-bold text-info">
                -
              </div>
              <div class="text-xs text-base-content/50">文章数量</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- 向量化控制台 -->
    <VectorizeView client:load />
  </div>

  <script>
    // 快速状态更新
    async function updateQuickStats() {
      try {
        const response = await fetch("/api/trpc/vectorization.getStatus");
        if (!response.ok) return;

        const data = await response.json();
        const statusData = data.result?.data || {};

        let indexed = 0;
        let mismatch = 0;
        let notIndexed = 0;

        // 正确处理API响应格式
        Object.values(statusData).forEach((statusInfo: any) => {
          const status = statusInfo.status || statusInfo;
          switch (status) {
            case "correct":
              indexed++;
              break;
            case "mismatch":
              mismatch++;
              break;
            case "notvectorized":
              notIndexed++;
              break;
          }
        });

        const total = indexed + mismatch + notIndexed;

        document.getElementById("quickIndexedCount")!.textContent =
          indexed.toString();
        document.getElementById("quickMismatchCount")!.textContent =
          mismatch.toString();
        document.getElementById("quickNotIndexedCount")!.textContent =
          notIndexed.toString();
        document.getElementById("quickTotalCount")!.textContent =
          total.toString();
      } catch (error) {
        console.error("获取快速状态失败:", error);
      }
    }

    // 页面加载时更新状态
    document.addEventListener("DOMContentLoaded", () => {
      updateQuickStats();
      setInterval(updateQuickStats, 10000); // 每10秒更新一次
    });
  </script>
</Layout>

---
import PostEditorWrapper from "~/components/editor/PostEditorWrapper.astro";
import Layout from "~/layouts/Layout.astro";
import { isAdminFromRequest, redirectToAdminLogin } from "~/lib/auth";

export const prerender = false;

// Check if user is admin
const isUserAdmin =
  process.env.ADMIN_MODE === "true" ||
  (await isAdminFromRequest(Astro.cookies, Astro.request.headers));

if (!isUserAdmin) {
  return redirectToAdminLogin();
}

// Get post ID from URL params
const url = new URL(Astro.request.url);
const postId = url.searchParams.get("id");
const isNewPost = !postId;

const metadata = {
  title: isNewPost ? "新建文章 - 管理员面板" : "编辑文章 - 管理员面板",
  description: isNewPost ? "创建新的文章" : "编辑现有文章",
  robots: {
    index: false,
    follow: false,
  },
};
---

<Layout metadata={metadata}>
  <div class="min-h-screen bg-gray-50 dark:bg-gray-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- 页面标题 -->
      <div class="mb-8">
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-3xl font-bold text-gray-900 dark:text-white">
              {isNewPost ? "新建文章" : "编辑文章"}
            </h1>
            <p class="mt-2 text-gray-600 dark:text-gray-400">
              {isNewPost ? "创建一篇新的文章" : "编辑现有文章内容"}
            </p>
          </div>
          <div class="flex items-center space-x-4">
            <a
              href="/admin/posts"
              class="inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500"
            >
              返回列表
            </a>
          </div>
        </div>
      </div>

      <!-- 编辑器容器 -->
      <PostEditorWrapper postId={postId || undefined} isNewPost={isNewPost} />
    </div>
  </div>
</Layout>

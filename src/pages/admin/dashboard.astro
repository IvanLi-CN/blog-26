---
import { Icon } from "astro-icon/components";
import Layout from "~/layouts/PageLayout.astro";
import { isAdminFromRequest, redirectToAdminLogin } from "~/lib/auth";

export const prerender = false;

// 权限检查
const isUserAdmin = await isAdminFromRequest(
  Astro.cookies,
  Astro.request.headers,
);

if (!isUserAdmin) {
  return redirectToAdminLogin();
}

const metadata = {
  title: "管理员仪表盘",
  description: "管理员仪表盘 - 统计数据和活动日历",
  robots: {
    index: false,
    follow: false,
  },
};
---

<Layout metadata={metadata}>
  <div class="max-w-7xl mx-auto px-4 py-8">
    <!-- 页面标题 -->
    <div class="mb-8">
      <div class="flex justify-between items-center mb-4">
        <h1 class="text-4xl font-bold">
          <Icon name="tabler:dashboard" class="w-10 h-10 inline-block mr-2" />
          管理员仪表盘
        </h1>
        <div class="flex gap-2">
          <a href="/admin" class="btn btn-outline">
            <Icon name="tabler:arrow-left" class="w-4 h-4 mr-1" />
            返回管理面板
          </a>
          <button id="refresh-btn" class="btn btn-primary">
            <Icon name="tabler:refresh" class="w-4 h-4 mr-1" />
            刷新数据
          </button>
        </div>
      </div>
      <p class="text-muted">查看网站统计数据、活动日历和最近活动</p>
    </div>

    <!-- 加载状态 -->
    <div id="loading-indicator" class="flex justify-center items-center py-12">
      <span class="loading loading-spinner loading-lg"></span>
      <span class="ml-2">正在加载数据...</span>
    </div>

    <!-- 主要内容区域 -->
    <div id="dashboard-content" class="hidden">
      <!-- 总体统计卡片 -->
      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8 dashboard-grid"
      >
        <!-- 内容统计 -->
        <div
          class="card stat-card dashboard-card text-white shadow-xl"
          style="--color-start: #3b82f6; --color-end: #1d4ed8;"
        >
          <div class="card-body">
            <div class="flex items-center justify-between">
              <div>
                <h3 class="text-lg font-semibold opacity-90">总文章数</h3>
                <p id="total-posts" class="text-3xl font-bold">-</p>
                <p class="text-sm opacity-75">
                  已发布: <span id="published-posts">-</span> | 草稿: <span
                    id="draft-posts">-</span
                  >
                </p>
              </div>
              <Icon name="tabler:article" class="w-12 h-12 opacity-80" />
            </div>
          </div>
        </div>

        <div
          class="card stat-card dashboard-card text-white shadow-xl"
          style="--color-start: #10b981; --color-end: #047857;"
        >
          <div class="card-body">
            <div class="flex items-center justify-between">
              <div>
                <h3 class="text-lg font-semibold opacity-90">总闪念数</h3>
                <p id="total-memos" class="text-3xl font-bold">-</p>
                <p class="text-sm opacity-75">
                  公开: <span id="public-memos">-</span> | 私有: <span
                    id="private-memos">-</span
                  >
                </p>
              </div>
              <Icon name="tabler:notes" class="w-12 h-12 opacity-80" />
            </div>
          </div>
        </div>

        <div
          class="card stat-card dashboard-card text-white shadow-xl"
          style="--color-start: #8b5cf6; --color-end: #5b21b6;"
        >
          <div class="card-body">
            <div class="flex items-center justify-between">
              <div>
                <h3 class="text-lg font-semibold opacity-90">总评论数</h3>
                <p id="total-comments" class="text-3xl font-bold">-</p>
                <p class="text-sm opacity-75">
                  待审: <span id="pending-comments">-</span> | 已批准: <span
                    id="approved-comments">-</span
                  >
                </p>
              </div>
              <Icon name="tabler:message-circle" class="w-12 h-12 opacity-80" />
            </div>
          </div>
        </div>

        <div
          class="card stat-card dashboard-card text-white shadow-xl"
          style="--color-start: #f59e0b; --color-end: #d97706;"
        >
          <div class="card-body">
            <div class="flex items-center justify-between">
              <div>
                <h3 class="text-lg font-semibold opacity-90">互动数据</h3>
                <p id="total-reactions" class="text-3xl font-bold">-</p>
                <p class="text-sm opacity-75">
                  用户数: <span id="total-users">-</span>
                </p>
              </div>
              <Icon name="tabler:heart" class="w-12 h-12 opacity-80" />
            </div>
          </div>
        </div>
      </div>

      <!-- 活动日历和趋势图 -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
        <!-- 活动日历 -->
        <div class="card bg-base-100 shadow-xl dashboard-card">
          <div class="card-body">
            <div class="flex items-center justify-between mb-4">
              <h2 class="card-title">
                <Icon name="tabler:calendar" class="w-6 h-6 mr-2" />
                活动日历
              </h2>
              <div class="flex gap-2">
                <select
                  id="calendar-year"
                  class="select select-sm select-bordered min-w-[100px]"
                >
                  <option value="2024">2024年</option>
                  <option value="2023">2023年</option>
                  <option value="2025">2025年</option>
                </select>
                <select
                  id="calendar-month"
                  class="select select-sm select-bordered min-w-[80px]"
                >
                  <option value="">全年</option>
                  <option value="1">1月</option>
                  <option value="2">2月</option>
                  <option value="3">3月</option>
                  <option value="4">4月</option>
                  <option value="5">5月</option>
                  <option value="6">6月</option>
                  <option value="7">7月</option>
                  <option value="8">8月</option>
                  <option value="9">9月</option>
                  <option value="10">10月</option>
                  <option value="11">11月</option>
                  <option value="12">12月</option>
                </select>
              </div>
            </div>
            <div
              id="activity-calendar-container"
              class="min-h-[300px] calendar-grid"
            >
              <!-- 活动日历将通过JavaScript渲染 -->
            </div>
          </div>
        </div>

        <!-- 趋势图 -->
        <div class="card bg-base-100 shadow-xl dashboard-card">
          <div class="card-body">
            <div class="flex items-center justify-between mb-4">
              <h2 class="card-title">
                <Icon name="tabler:chart-line" class="w-6 h-6 mr-2" />
                活动趋势
              </h2>
              <select id="trend-days" class="select select-sm select-bordered">
                <option value="7">最近7天</option>
                <option value="30" selected>最近30天</option>
                <option value="90">最近90天</option>
              </select>
            </div>
            <div id="trend-chart-container" class="min-h-[300px] trend-chart">
              <!-- 趋势图将通过JavaScript渲染 -->
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { createTRPCClient, httpBatchLink } from "@trpc/client";
  import type { AppRouter } from "~/server/router";

  const trpc = createTRPCClient<AppRouter>({
    links: [
      httpBatchLink({
        url: "/api/trpc",
      }),
    ],
  });

  // DOM 元素
  const loadingIndicator = document.getElementById("loading-indicator")!;
  const dashboardContent = document.getElementById("dashboard-content")!;
  const refreshBtn = document.getElementById("refresh-btn")!;

  // 初始化年份选择器
  function initializeYearSelector() {
    const currentYear = new Date().getFullYear();
    const calendarYear = document.getElementById(
      "calendar-year",
    ) as HTMLSelectElement;
    if (calendarYear) {
      calendarYear.innerHTML = "";
      // 扩大年份范围：从2020年到当前年份+2年
      const startYear = 2020;
      const endYear = currentYear + 2;
      for (let year = endYear; year >= startYear; year--) {
        const option = document.createElement("option");
        option.value = year.toString();
        option.textContent = `${year}年`;
        option.selected = year === currentYear;
        calendarYear.appendChild(option);
      }
    }
  }

  // 格式化日期
  function formatDate(timestamp: number): string {
    return new Intl.DateTimeFormat("zh-CN", {
      year: "numeric",
      month: "2-digit",
      day: "2-digit",
      hour: "2-digit",
      minute: "2-digit",
    }).format(new Date(timestamp * 1000));
  }

  // 格式化相对时间
  function formatRelativeTime(timestamp: number): string {
    const now = Date.now();
    const diff = now - timestamp * 1000;
    const minutes = Math.floor(diff / 60000);
    const hours = Math.floor(diff / 3600000);
    const days = Math.floor(diff / 86400000);

    if (minutes < 1) return "刚刚";
    if (minutes < 60) return `${minutes}分钟前`;
    if (hours < 24) return `${hours}小时前`;
    if (days < 7) return `${days}天前`;
    return formatDate(timestamp);
  }

  // 加载总体统计数据
  async function loadOverallStats() {
    try {
      const stats = await trpc.stats.getOverallStats.query();

      document.getElementById("total-posts")!.textContent =
        stats.content.totalPosts.toString();
      document.getElementById("published-posts")!.textContent =
        stats.content.publishedPosts.toString();
      document.getElementById("draft-posts")!.textContent =
        stats.content.draftPosts.toString();

      document.getElementById("total-memos")!.textContent =
        stats.content.totalMemos.toString();
      document.getElementById("public-memos")!.textContent =
        stats.content.publicMemos.toString();
      document.getElementById("private-memos")!.textContent =
        stats.content.privateMemos.toString();

      document.getElementById("total-comments")!.textContent =
        stats.engagement.totalComments.toString();
      document.getElementById("pending-comments")!.textContent =
        stats.engagement.pendingComments.toString();
      document.getElementById("approved-comments")!.textContent =
        stats.engagement.approvedComments.toString();

      document.getElementById("total-reactions")!.textContent =
        stats.engagement.totalReactions.toString();
      document.getElementById("total-users")!.textContent =
        stats.users.totalUsers.toString();
    } catch (error) {
      console.error("Failed to load overall stats:", error);
    }
  }

  // 加载活动日历
  async function loadActivityCalendar() {
    try {
      const year = parseInt(
        (document.getElementById("calendar-year") as HTMLSelectElement)
          ?.value || "2024",
      );
      const monthSelect = document.getElementById(
        "calendar-month",
      ) as HTMLSelectElement;
      const month = monthSelect?.value
        ? parseInt(monthSelect.value)
        : undefined;

      const params: { year: number; month?: number } = { year };
      if (month) {
        params.month = month;
      }

      const activities = await trpc.stats.getActivityCalendar.query(params);
      renderActivityCalendar(activities);
    } catch (error) {
      console.error("Failed to load activity calendar:", error);
      document.getElementById("activity-calendar-container")!.innerHTML =
        '<div class="text-center text-error">加载活动日历失败</div>';
    }
  }

  // 渲染活动日历
  function renderActivityCalendar(activities: any[]) {
    const container = document.getElementById("activity-calendar-container")!;

    if (activities.length === 0) {
      container.innerHTML =
        '<div class="text-center text-base-content/60">暂无活动数据</div>';
      return;
    }

    const year = parseInt(
      (document.getElementById("calendar-year") as HTMLSelectElement)?.value ||
        "2024",
    );
    const monthSelect = document.getElementById(
      "calendar-month",
    ) as HTMLSelectElement;
    const month = monthSelect?.value ? parseInt(monthSelect.value) : undefined;

    if (month) {
      // 月视图 - 显示日历网格
      renderMonthCalendar(activities, year, month, container);
    } else {
      // 年视图 - 显示月度汇总
      renderYearCalendar(activities, year, container);
    }
  }

  // 渲染年视图
  function renderYearCalendar(
    activities: any[],
    year: number,
    container: HTMLElement,
  ) {
    // 按月汇总数据
    const monthlyData: { [key: string]: any } = {};
    activities.forEach((activity) => {
      const monthKey = activity.date.substring(0, 7); // YYYY-MM
      if (!monthlyData[monthKey]) {
        monthlyData[monthKey] = {
          date: monthKey,
          total: 0,
          posts: 0,
          memos: 0,
          comments: 0,
          reactions: 0,
        };
      }
      monthlyData[monthKey].total += activity.total;
      monthlyData[monthKey].posts += activity.posts;
      monthlyData[monthKey].memos += activity.memos;
      monthlyData[monthKey].comments += activity.comments;
      monthlyData[monthKey].reactions += activity.reactions;
    });

    const months: any[] = [];
    for (let m = 1; m <= 12; m++) {
      const monthKey = `${year}-${m.toString().padStart(2, "0")}`;
      const data = monthlyData[monthKey] || {
        date: monthKey,
        total: 0,
        posts: 0,
        memos: 0,
        comments: 0,
        reactions: 0,
      };
      months.push(data);
    }

    const monthNames = [
      "1月",
      "2月",
      "3月",
      "4月",
      "5月",
      "6月",
      "7月",
      "8月",
      "9月",
      "10月",
      "11月",
      "12月",
    ];

    const monthCards = months
      .map((monthData, index) => {
        const level = getActivityLevel(monthData.total);
        const bgColor = getActivityColor(level);

        return `
        <div class="card ${bgColor} shadow-lg dashboard-card cursor-pointer"
             onclick="selectMonth(${index + 1})"
             title="${monthNames[index]}: ${monthData.total} 个活动">
          <div class="card-body p-4 text-center">
            <h3 class="font-bold text-lg">${monthNames[index]}</h3>
            <div class="text-3xl font-bold mt-2">${monthData.total}</div>
            <div class="text-xs mt-2 space-y-1">
              ${monthData.posts > 0 ? `<div class="badge badge-sm badge-outline">📝 ${monthData.posts}</div>` : ""}
              ${monthData.memos > 0 ? `<div class="badge badge-sm badge-outline">💭 ${monthData.memos}</div>` : ""}
              ${monthData.comments > 0 ? `<div class="badge badge-sm badge-outline">💬 ${monthData.comments}</div>` : ""}
              ${monthData.reactions > 0 ? `<div class="badge badge-sm badge-outline">❤️ ${monthData.reactions}</div>` : ""}
            </div>
          </div>
        </div>
      `;
      })
      .join("");

    container.innerHTML = `
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        ${monthCards}
      </div>
      <div class="mt-4 text-center">
        <div class="text-sm text-base-content/60 mb-2">点击月份查看详细日历</div>
        ${renderActivityLegend()}
      </div>
    `;
  }

  // 渲染月视图
  function renderMonthCalendar(
    activities: any[],
    year: number,
    month: number,
    container: HTMLElement,
  ) {
    const daysInMonth = new Date(year, month, 0).getDate();
    const firstDayOfWeek = new Date(year, month - 1, 1).getDay();

    const activityMap: { [key: string]: any } = {};
    activities.forEach((activity) => {
      activityMap[activity.date] = activity;
    });

    const days: string[] = [];

    // 添加空白天数（月初）
    for (let i = 0; i < firstDayOfWeek; i++) {
      days.push('<div class="h-12 w-12"></div>');
    }

    // 添加月份中的每一天
    for (let day = 1; day <= daysInMonth; day++) {
      const dateStr = `${year}-${month.toString().padStart(2, "0")}-${day.toString().padStart(2, "0")}`;
      const dayData = activityMap[dateStr];
      const level = dayData ? getActivityLevel(dayData.total) : 0;
      const bgColor = getActivityColor(level);

      const tooltip = dayData
        ? `${dateStr}: ${dayData.total} 个活动\\n📝 ${dayData.posts} 篇文章\\n💭 ${dayData.memos} 条闪念\\n💬 ${dayData.comments} 条评论\\n❤️ ${dayData.reactions} 个反应`
        : `${dateStr}: 无活动`;

      days.push(`
        <div class="h-12 w-12 rounded-lg border border-base-300 ${bgColor} flex items-center justify-center activity-cell cursor-pointer relative group"
             title="${tooltip}">
          <span class="text-sm font-medium">${day}</span>
          ${
            dayData && dayData.total > 0
              ? `
            <div class="absolute top-full left-1/2 transform -translate-x-1/2 mt-2 bg-base-100 border border-base-300 rounded-lg p-2 shadow-lg z-10 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none min-w-max">
              <div class="text-xs space-y-1">
                <div class="font-semibold">${dateStr}</div>
                <div>📝 文章: ${dayData.posts}</div>
                <div>💭 闪念: ${dayData.memos}</div>
                <div>💬 评论: ${dayData.comments}</div>
                <div>❤️ 反应: ${dayData.reactions}</div>
              </div>
            </div>
          `
              : ""
          }
        </div>
      `);
    }

    const monthName = new Date(year, month - 1).toLocaleDateString("zh-CN", {
      year: "numeric",
      month: "long",
    });

    container.innerHTML = `
      <div class="space-y-4">
        <div class="text-center">
          <h3 class="text-lg font-semibold">${monthName}</h3>
          <button class="btn btn-sm btn-outline mt-2" onclick="clearMonthSelection()">返回年视图</button>
        </div>

        <!-- 星期标题 -->
        <div class="grid grid-cols-7 gap-2 mb-4">
          ${["日", "一", "二", "三", "四", "五", "六"]
            .map(
              (day) =>
                `<div class="text-center text-sm font-medium text-base-content/60 h-8 flex items-center justify-center">${day}</div>`,
            )
            .join("")}
        </div>

        <!-- 日历网格 -->
        <div class="grid grid-cols-7 gap-2">
          ${days.join("")}
        </div>

        ${renderActivityLegend()}
      </div>
    `;
  }

  // 获取活动强度等级
  function getActivityLevel(total: number): number {
    if (total === 0) return 0;
    if (total <= 2) return 1;
    if (total <= 5) return 2;
    if (total <= 10) return 3;
    return 4;
  }

  // 获取活动颜色
  function getActivityColor(level: number): string {
    const colors = [
      "bg-base-200", // 无活动
      "bg-success/30", // 低活动
      "bg-success/50", // 中等活动
      "bg-success/70", // 高活动
      "bg-success", // 非常高活动
    ];
    return colors[level] || colors[0];
  }

  // 渲染活动强度图例
  function renderActivityLegend(): string {
    return `
      <div class="flex items-center justify-center gap-2 text-xs mt-4">
        <span class="text-base-content/60">活动强度:</span>
        <div class="flex items-center gap-1">
          <div class="w-3 h-3 rounded bg-base-200"></div>
          <span>无</span>
        </div>
        <div class="flex items-center gap-1">
          <div class="w-3 h-3 rounded bg-success/30"></div>
          <span>低</span>
        </div>
        <div class="flex items-center gap-1">
          <div class="w-3 h-3 rounded bg-success/50"></div>
          <span>中</span>
        </div>
        <div class="flex items-center gap-1">
          <div class="w-3 h-3 rounded bg-success/70"></div>
          <span>高</span>
        </div>
        <div class="flex items-center gap-1">
          <div class="w-3 h-3 rounded bg-success"></div>
          <span>很高</span>
        </div>
      </div>
    `;
  }

  // 加载趋势图
  async function loadTrendChart() {
    try {
      const days = parseInt(
        (document.getElementById("trend-days") as HTMLSelectElement)?.value ||
          "30",
      );
      const trends = await trpc.stats.getTrendStats.query({ days });
      renderTrendChart(trends);
    } catch (error) {
      console.error("Failed to load trend chart:", error);
      document.getElementById("trend-chart-container")!.innerHTML =
        '<div class="text-center text-error">加载趋势图失败</div>';
    }
  }

  // 渲染趋势图
  function renderTrendChart(trends: any) {
    const container = document.getElementById("trend-chart-container")!;

    const allDates = new Set([
      ...trends.posts.map((p: any) => p.date),
      ...trends.memos.map((m: any) => m.date),
      ...trends.comments.map((c: any) => c.date),
      ...trends.reactions.map((r: any) => r.date),
    ]);

    const sortedDates = Array.from(allDates).sort();

    if (sortedDates.length === 0) {
      container.innerHTML =
        '<div class="text-center text-base-content/60">暂无趋势数据</div>';
      return;
    }

    const chartData = sortedDates.map((date) => {
      const posts = trends.posts.find((p: any) => p.date === date)?.count || 0;
      const memos = trends.memos.find((m: any) => m.date === date)?.count || 0;
      const comments =
        trends.comments.find((c: any) => c.date === date)?.count || 0;
      const reactions =
        trends.reactions.find((r: any) => r.date === date)?.count || 0;
      const total = posts + memos + comments + reactions;

      return { date, posts, memos, comments, reactions, total };
    });

    const maxValue = Math.max(
      ...chartData.map((d) =>
        Math.max(d.posts, d.memos, d.comments, d.reactions),
      ),
    );
    const chartHeight = 200;

    // 创建堆叠柱状图
    const chartHtml = chartData
      .map((data, index) => {
        const barWidth = Math.max(100 / chartData.length - 1, 8);

        // 计算堆叠高度
        const postsHeight =
          maxValue > 0 ? (data.posts / maxValue) * chartHeight : 0;
        const memosHeight =
          maxValue > 0 ? (data.memos / maxValue) * chartHeight : 0;
        const commentsHeight =
          maxValue > 0 ? (data.comments / maxValue) * chartHeight : 0;
        const reactionsHeight =
          maxValue > 0 ? (data.reactions / maxValue) * chartHeight : 0;

        return `
        <div class="flex flex-col items-center group relative" style="width: ${barWidth}%">
          <!-- 堆叠柱状图 -->
          <div class="flex flex-col w-full relative" style="height: ${chartHeight}px;">
            ${
              data.reactions > 0
                ? `
              <div class="bg-accent rounded-t w-full trend-bar"
                   style="height: ${reactionsHeight}px;"
                   title="反应: ${data.reactions}"></div>
            `
                : ""
            }
            ${
              data.comments > 0
                ? `
              <div class="bg-secondary w-full trend-bar"
                   style="height: ${commentsHeight}px;"
                   title="评论: ${data.comments}"></div>
            `
                : ""
            }
            ${
              data.memos > 0
                ? `
              <div class="bg-success w-full trend-bar"
                   style="height: ${memosHeight}px;"
                   title="闪念: ${data.memos}"></div>
            `
                : ""
            }
            ${
              data.posts > 0
                ? `
              <div class="bg-primary rounded-b w-full trend-bar"
                   style="height: ${postsHeight}px;"
                   title="文章: ${data.posts}"></div>
            `
                : ""
            }
            ${
              data.total === 0
                ? `
              <div class="bg-base-300 w-full rounded" style="height: 4px;"></div>
            `
                : ""
            }
          </div>

          <!-- 日期标签 -->
          <div class="text-xs mt-2 transform -rotate-45 origin-left whitespace-nowrap">
            ${formatChartDate(data.date)}
          </div>

          <!-- 悬停提示 -->
          <div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 bg-base-100 border border-base-300 rounded-lg p-3 shadow-xl opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-10 min-w-max">
            <div class="text-sm space-y-2">
              <div class="font-semibold text-center border-b pb-1">${data.date}</div>
              <div class="grid grid-cols-2 gap-2 text-xs">
                <div class="flex items-center gap-1">
                  <div class="w-3 h-3 bg-primary rounded"></div>
                  <span>文章: ${data.posts}</span>
                </div>
                <div class="flex items-center gap-1">
                  <div class="w-3 h-3 bg-success rounded"></div>
                  <span>闪念: ${data.memos}</span>
                </div>
                <div class="flex items-center gap-1">
                  <div class="w-3 h-3 bg-secondary rounded"></div>
                  <span>评论: ${data.comments}</span>
                </div>
                <div class="flex items-center gap-1">
                  <div class="w-3 h-3 bg-accent rounded"></div>
                  <span>反应: ${data.reactions}</span>
                </div>
              </div>
              <div class="text-center font-semibold border-t pt-1">总计: ${data.total}</div>
            </div>
          </div>
        </div>
      `;
      })
      .join("");

    // 计算统计摘要
    const totalPosts = chartData.reduce((sum, d) => sum + d.posts, 0);
    const totalMemos = chartData.reduce((sum, d) => sum + d.memos, 0);
    const totalComments = chartData.reduce((sum, d) => sum + d.comments, 0);
    const totalReactions = chartData.reduce((sum, d) => sum + d.reactions, 0);

    container.innerHTML = `
      <div class="space-y-6">
        <!-- Y轴标签 -->
        <div class="relative">
          <div class="absolute left-0 top-0 bottom-16 w-8 flex flex-col justify-between text-xs text-base-content/60">
            <span>${maxValue}</span>
            <span>${Math.floor(maxValue * 0.75)}</span>
            <span>${Math.floor(maxValue * 0.5)}</span>
            <span>${Math.floor(maxValue * 0.25)}</span>
            <span>0</span>
          </div>

          <!-- 图表区域 -->
          <div class="ml-10 mr-2">
            <div class="flex items-end justify-between gap-1 border-l border-b border-base-300 pl-2 pb-2" style="height: ${chartHeight + 40}px;">
              ${chartHtml}
            </div>
          </div>
        </div>

        <!-- 图例 -->
        <div class="flex flex-wrap justify-center gap-4 text-sm">
          <div class="flex items-center gap-2">
            <div class="w-4 h-4 bg-primary rounded"></div>
            <span>文章</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="w-4 h-4 bg-success rounded"></div>
            <span>闪念</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="w-4 h-4 bg-secondary rounded"></div>
            <span>评论</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="w-4 h-4 bg-accent rounded"></div>
            <span>反应</span>
          </div>
        </div>

        <!-- 统计摘要 -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="bg-primary/10 rounded-lg p-3 text-center">
            <div class="text-primary font-bold text-xl">${totalPosts}</div>
            <div class="text-xs text-primary/70">总文章数</div>
          </div>
          <div class="bg-success/10 rounded-lg p-3 text-center">
            <div class="text-success font-bold text-xl">${totalMemos}</div>
            <div class="text-xs text-success/70">总闪念数</div>
          </div>
          <div class="bg-secondary/10 rounded-lg p-3 text-center">
            <div class="text-secondary font-bold text-xl">${totalComments}</div>
            <div class="text-xs text-secondary/70">总评论数</div>
          </div>
          <div class="bg-accent/10 rounded-lg p-3 text-center">
            <div class="text-accent font-bold text-xl">${totalReactions}</div>
            <div class="text-xs text-accent/70">总反应数</div>
          </div>
        </div>
      </div>
    `;
  }

  // 格式化图表日期
  function formatChartDate(dateStr: string): string {
    const date = new Date(dateStr);
    return date.toLocaleDateString("zh-CN", { month: "short", day: "numeric" });
  }

  // 加载所有数据
  async function loadAllData() {
    loadingIndicator.classList.remove("hidden");
    dashboardContent.classList.add("hidden");

    try {
      await Promise.all([
        loadOverallStats(),
        loadActivityCalendar(),
        loadTrendChart(),
      ]);
    } catch (error) {
      console.error("Failed to load dashboard data:", error);
    } finally {
      loadingIndicator.classList.add("hidden");
      dashboardContent.classList.remove("hidden");
    }
  }

  // 全局函数供HTML调用
  (window as any).selectMonth = function (month: number) {
    const monthSelect = document.getElementById(
      "calendar-month",
    ) as HTMLSelectElement;
    if (monthSelect) {
      monthSelect.value = month.toString();
      loadActivityCalendar();
    }
  };

  (window as any).clearMonthSelection = function () {
    const monthSelect = document.getElementById(
      "calendar-month",
    ) as HTMLSelectElement;
    if (monthSelect) {
      monthSelect.value = "";
      loadActivityCalendar();
    }
  };

  // 事件监听器
  refreshBtn.addEventListener("click", loadAllData);

  const calendarYear = document.getElementById(
    "calendar-year",
  ) as HTMLSelectElement;
  const calendarMonth = document.getElementById(
    "calendar-month",
  ) as HTMLSelectElement;
  const trendDays = document.getElementById("trend-days") as HTMLSelectElement;

  if (calendarYear) {
    calendarYear.addEventListener("change", loadActivityCalendar);
  }

  if (calendarMonth) {
    calendarMonth.addEventListener("change", loadActivityCalendar);
  }

  if (trendDays) {
    trendDays.addEventListener("change", loadTrendChart);
  }

  // 初始化
  initializeYearSelector();
  loadAllData();
</script>


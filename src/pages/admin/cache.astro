---
import ContentCacheView from "~/components/content-cache/ContentCacheView";
import Layout from "~/layouts/PageLayout.astro";
import { isAdminFromRequest, redirectToAdminLogin } from "~/lib/auth";

export const prerender = false;

// 权限检查
const isUserAdmin = await isAdminFromRequest(
  Astro.cookies,
  Astro.request.headers,
);

if (!isUserAdmin) {
  return redirectToAdminLogin();
}

const metadata = {
  title: "内容缓存管理",
  description: "查看和管理内容缓存状态",
  robots: {
    index: false,
    follow: false,
  },
};
---

<Layout metadata={metadata}>
  <div class="container mx-auto px-4 py-8">
    <div class="max-w-6xl mx-auto">
      <div class="flex justify-between items-center mb-6">
        <h1 class="text-3xl font-bold">内容缓存管理</h1>
        <a href="/admin" class="btn btn-outline">
          <svg
            class="w-4 h-4 mr-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          返回管理面板
        </a>
      </div>

      <!-- 说明区域 -->
      <div class="alert alert-info mb-8">
        <div>
          <h3 class="font-bold">缓存刷新说明</h3>
          <div class="text-sm mt-2">
            <p>
              <strong>智能刷新：</strong
              >只更新有变化的内容（基于文件修改时间和内容哈希），速度快，适合日常使用。
            </p>
            <p>
              <strong>强制刷新：</strong
              >重新处理所有内容，忽略变更检测，速度较慢，适合解决缓存问题或确保数据一致性。
            </p>
          </div>
        </div>
      </div>

      <!-- 缓存状态卡片 -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="card bg-base-100 shadow-xl">
          <div class="card-body">
            <h2 class="card-title text-primary">文章缓存</h2>
            <div class="stat">
              <div class="stat-value" id="posts-count">-</div>
              <div class="stat-desc">篇文章已缓存</div>
            </div>
            <div class="text-sm text-base-content/70">
              最后更新: <span id="posts-last-updated">-</span>
            </div>
          </div>
        </div>

        <div class="card bg-base-100 shadow-xl">
          <div class="card-body">
            <h2 class="card-title text-secondary">闪念缓存</h2>
            <div class="stat">
              <div class="stat-value" id="memos-count">-</div>
              <div class="stat-desc">条闪念已缓存</div>
            </div>
            <div class="text-sm text-base-content/70">
              最后更新: <span id="memos-last-updated">-</span>
            </div>
          </div>
        </div>

        <div class="card bg-base-100 shadow-xl">
          <div class="card-body">
            <h2 class="card-title text-accent">总计</h2>
            <div class="stat">
              <div class="stat-value" id="total-count">-</div>
              <div class="stat-desc">项内容已缓存</div>
            </div>
            <div class="text-sm text-base-content/70">
              最后更新: <span id="total-last-updated">-</span>
            </div>
          </div>
        </div>
      </div>

      <!-- 缓存刷新控制台 -->
      <ContentCacheView client:load />
    </div>
  </div>
</Layout>

<script>
  import { createTRPCClient, httpBatchLink } from "@trpc/client";
  import type { AppRouter } from "~/server/router";

  const trpc = createTRPCClient<AppRouter>({
    links: [
      httpBatchLink({
        url: "/api/trpc",
      }),
    ],
  });

  // 格式化日期
  function formatDate(date: Date | null): string {
    if (!date) return "-";
    return new Intl.DateTimeFormat("zh-CN", {
      year: "numeric",
      month: "2-digit",
      day: "2-digit",
      hour: "2-digit",
      minute: "2-digit",
    }).format(date);
  }

  // 加载缓存状态
  async function loadCacheStatus() {
    try {
      console.log("🔄 开始加载缓存状态...");
      const status = await trpc.contentCache.getStatus.query();

      document.getElementById("posts-count")!.textContent =
        status.posts.count.toString();
      document.getElementById("memos-count")!.textContent =
        status.memos.count.toString();
      document.getElementById("total-count")!.textContent =
        status.totalItems.toString();

      document.getElementById("posts-last-updated")!.textContent = formatDate(
        status.posts.lastUpdated ? new Date(status.posts.lastUpdated) : null,
      );
      document.getElementById("memos-last-updated")!.textContent = formatDate(
        status.memos.lastUpdated ? new Date(status.memos.lastUpdated) : null,
      );

      // 计算总的最后更新时间（取两者中较新的时间）
      const postsTime = status.posts.lastUpdated || 0;
      const memosTime = status.memos.lastUpdated || 0;
      const totalLastUpdated = Math.max(postsTime, memosTime);
      document.getElementById("total-last-updated")!.textContent = formatDate(
        totalLastUpdated ? new Date(totalLastUpdated) : null,
      );

      console.log("✅ 缓存状态加载完成:", {
        posts: status.posts.count,
        memos: status.memos.count,
        total: status.totalItems,
      });
    } catch (error) {
      console.error("Failed to load cache status:", error);
    }
  }

  // 监听缓存刷新完成事件
  function setupCacheRefreshListener() {
    console.log("🔧 设置缓存刷新完成事件监听器");
    // 监听来自 ContentCacheLogger 组件的缓存刷新完成事件
    window.addEventListener("cache-refresh-completed", () => {
      console.log("🎉 收到缓存刷新完成事件，重新加载缓存状态");
      loadCacheStatus();
    });
    console.log("✅ 缓存刷新完成事件监听器已设置");
  }

  // 页面可见性变化时重新加载缓存状态
  function setupVisibilityListener() {
    document.addEventListener("visibilitychange", () => {
      if (!document.hidden) {
        console.log("页面重新可见，重新加载缓存状态");
        loadCacheStatus();
      }
    });
  }

  // 将函数暴露到全局作用域，供React组件调用
  (window as any).refreshCacheStatus = loadCacheStatus;

  // 初始化
  loadCacheStatus();
  setupCacheRefreshListener();
  setupVisibilityListener();
</script>

---
import { Icon } from "astro-icon/components";
import Layout from "~/layouts/PageLayout.astro";
import { isAdminFromRequest, redirectToAdminLogin } from "~/lib/auth";

export const prerender = false;

// 权限检查
const isUserAdmin = await isAdminFromRequest(
  Astro.cookies,
  Astro.request.headers,
);

if (!isUserAdmin) {
  return redirectToAdminLogin();
}

const metadata = {
  title: "管理员操作界面",
  description: "管理员专用的操作界面",
  robots: {
    index: false,
    follow: false,
  },
};
---

<Layout metadata={metadata}>
  <div class="max-w-7xl mx-auto px-4 py-8">
    <!-- 页面标题 -->
    <div class="mb-8">
      <div class="flex justify-between items-center mb-4">
        <h1 class="text-4xl font-bold">
          <Icon name="tabler:settings" class="w-10 h-10 inline-block mr-2" />
          管理员操作界面
        </h1>
        <div class="flex gap-2">
          <button id="refresh-dashboard-btn" class="btn btn-primary">
            <Icon name="tabler:refresh" class="w-4 h-4 mr-1" />
            刷新数据
          </button>
          <button id="logout-btn" class="btn btn-outline btn-error">
            <Icon name="tabler:logout" class="w-4 h-4 mr-1" />
            登出
          </button>
        </div>
      </div>
      <p class="text-center text-muted">
        欢迎使用管理员操作界面，查看统计数据并选择您要执行的操作
      </p>
    </div>

    <!-- 仪表盘统计数据 -->
    <div id="dashboard-stats" class="mb-12">
      <!-- 加载状态 -->
      <div id="stats-loading" class="flex justify-center items-center py-8">
        <span class="loading loading-spinner loading-lg"></span>
        <span class="ml-2">正在加载统计数据...</span>
      </div>

      <!-- 统计卡片 -->
      <div id="stats-content" class="hidden">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
          <!-- 内容统计 -->
          <div
            class="card stat-card text-white shadow-xl"
            style="--color-start: #3b82f6; --color-end: #1d4ed8;"
          >
            <div class="card-body">
              <div class="flex items-center justify-between">
                <div>
                  <h3 class="text-lg font-semibold opacity-90">总文章数</h3>
                  <p id="total-posts" class="text-3xl font-bold">-</p>
                  <p class="text-sm opacity-75">
                    已发布: <span id="published-posts">-</span> | 草稿: <span
                      id="draft-posts">-</span
                    >
                  </p>
                </div>
                <Icon name="tabler:article" class="w-12 h-12 opacity-80" />
              </div>
            </div>
          </div>

          <div
            class="card stat-card text-white shadow-xl"
            style="--color-start: #10b981; --color-end: #047857;"
          >
            <div class="card-body">
              <div class="flex items-center justify-between">
                <div>
                  <h3 class="text-lg font-semibold opacity-90">总闪念数</h3>
                  <p id="total-memos" class="text-3xl font-bold">-</p>
                  <p class="text-sm opacity-75">
                    公开: <span id="public-memos">-</span> | 私有: <span
                      id="private-memos">-</span
                    >
                  </p>
                </div>
                <Icon name="tabler:notes" class="w-12 h-12 opacity-80" />
              </div>
            </div>
          </div>

          <div
            class="card stat-card text-white shadow-xl"
            style="--color-start: #8b5cf6; --color-end: #5b21b6;"
          >
            <div class="card-body">
              <div class="flex items-center justify-between">
                <div>
                  <h3 class="text-lg font-semibold opacity-90">总评论数</h3>
                  <p id="total-comments" class="text-3xl font-bold">-</p>
                  <p class="text-sm opacity-75">
                    待审: <span id="pending-comments">-</span> | 已批准: <span
                      id="approved-comments">-</span
                    >
                  </p>
                </div>
                <Icon
                  name="tabler:message-circle"
                  class="w-12 h-12 opacity-80"
                />
              </div>
            </div>
          </div>

          <div
            class="card stat-card text-white shadow-xl"
            style="--color-start: #f59e0b; --color-end: #d97706;"
          >
            <div class="card-body">
              <div class="flex items-center justify-between">
                <div>
                  <h3 class="text-lg font-semibold opacity-90">互动数据</h3>
                  <p id="total-reactions" class="text-3xl font-bold">-</p>
                  <p class="text-sm opacity-75">
                    用户数: <span id="total-users">-</span>
                  </p>
                </div>
                <Icon name="tabler:heart" class="w-12 h-12 opacity-80" />
              </div>
            </div>
          </div>
        </div>

        <!-- 快速链接到完整仪表盘 -->
        <div class="text-center mb-8">
          <a href="/admin/dashboard" class="btn btn-outline btn-primary">
            <Icon name="tabler:chart-line" class="w-4 h-4 mr-1" />
            查看完整仪表盘
          </a>
        </div>
      </div>
    </div>

    <!-- 操作卡片网格 -->
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto"
    >
      <!-- 文章向量化卡片 -->
      <div
        class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow"
      >
        <div class="card-body">
          <div class="flex items-center mb-4">
            <Icon name="mingcute:ai-line" class="w-8 h-8 text-primary mr-3" />
            <h2 class="card-title text-xl">文章向量化</h2>
          </div>
          <p class="text-muted mb-4">
            对博客文章进行向量化处理，用于智能搜索和相关文章推荐功能。
          </p>

          <!-- 向量化状态概览 -->
          <div
            id="vectorizationOverview"
            class="mb-4 p-3 bg-base-200 rounded-lg"
          >
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm font-medium">向量化状态</span>
              <span
                id="vectorizationStatusBadge"
                class="badge badge-ghost badge-sm">检查中...</span
              >
            </div>
            <div class="grid grid-cols-3 gap-2 text-xs">
              <div class="text-center">
                <div id="indexedCount" class="font-semibold text-success">
                  -
                </div>
                <div class="text-base-content/60">已索引</div>
              </div>
              <div class="text-center">
                <div id="mismatchCount" class="font-semibold text-warning">
                  -
                </div>
                <div class="text-base-content/60">需更新</div>
              </div>
              <div class="text-center">
                <div id="notIndexedCount" class="font-semibold text-error">
                  -
                </div>
                <div class="text-base-content/60">未索引</div>
              </div>
            </div>
          </div>

          <div class="card-actions justify-end">
            <a href="/admin/vectorize" class="btn btn-primary">
              <Icon name="tabler:play" class="w-4 h-4 mr-1" />
              开始向量化
            </a>
          </div>
        </div>
      </div>

      <!-- 缓存管理卡片 -->
      <div
        class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow"
      >
        <div class="card-body">
          <div class="flex items-center mb-4">
            <Icon name="tabler:database" class="w-8 h-8 text-success mr-3" />
            <h2 class="card-title text-xl">缓存管理</h2>
          </div>
          <p class="text-muted mb-4">
            查看和管理内容缓存状态，包括文章和闪念的缓存统计。支持手动刷新缓存以获取最新内容。
          </p>

          <!-- 缓存状态概览 -->
          <div id="cacheOverview" class="mb-4 p-3 bg-base-200 rounded-lg">
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm font-medium">缓存状态</span>
              <span id="cacheStatusBadge" class="badge badge-ghost badge-sm"
                >检查中...</span
              >
            </div>
            <div class="grid grid-cols-3 gap-2 text-xs">
              <div class="text-center">
                <div id="cachedPostsCount" class="font-semibold text-success">
                  -
                </div>
                <div class="text-base-content/60">文章</div>
              </div>
              <div class="text-center">
                <div id="cachedMemosCount" class="font-semibold text-info">
                  -
                </div>
                <div class="text-base-content/60">闪念</div>
              </div>
              <div class="text-center">
                <div id="totalCachedCount" class="font-semibold text-primary">
                  -
                </div>
                <div class="text-base-content/60">总计</div>
              </div>
            </div>
          </div>

          <div class="card-actions justify-end">
            <a href="/admin/cache" class="btn btn-success">
              <Icon name="tabler:refresh" class="w-4 h-4 mr-1" />
              管理缓存
            </a>
          </div>
        </div>
      </div>

      <!-- 文章管理卡片 -->
      <div
        class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow"
      >
        <div class="card-body">
          <div class="flex items-center mb-4">
            <Icon name="tabler:article" class="w-8 h-8 text-info mr-3" />
            <h2 class="card-title text-xl">文章管理</h2>
          </div>
          <p class="text-muted mb-4">
            查看和管理所有文章，包括草稿和已发布的文章。可以查看文章状态、发布日期等信息。
          </p>

          <!-- 文章状态概览 -->
          <div id="postsOverview" class="mb-4 p-3 bg-base-200 rounded-lg">
            <div class="mb-2">
              <span class="text-sm font-medium">文章统计</span>
            </div>
            <div class="grid grid-cols-3 gap-2 text-xs">
              <div class="text-center">
                <div
                  id="publishedPostsCount"
                  class="font-semibold text-success"
                >
                  -
                </div>
                <div class="text-base-content/60">已发布</div>
              </div>
              <div class="text-center">
                <div id="draftPostsCount" class="font-semibold text-warning">
                  -
                </div>
                <div class="text-base-content/60">草稿</div>
              </div>
              <div class="text-center">
                <div id="totalPostsCount" class="font-semibold text-info">
                  -
                </div>
                <div class="text-base-content/60">总计</div>
              </div>
            </div>
          </div>

          <div class="card-actions justify-end">
            <a href="/admin/posts" class="btn btn-info">
              <Icon name="tabler:list" class="w-4 h-4 mr-1" />
              管理文章
            </a>
          </div>
        </div>
      </div>

      <!-- 评论管理卡片 -->
      <div
        class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow"
      >
        <div class="card-body">
          <div class="flex items-center mb-4">
            <Icon
              name="tabler:message-circle"
              class="w-8 h-8 text-secondary mr-3"
            />
            <h2 class="card-title text-xl">评论管理</h2>
          </div>
          <p class="text-muted mb-4">
            管理博客评论，包括审核待审评论、删除不当评论、批量操作等功能。支持按状态筛选和搜索。
          </p>

          <!-- 评论状态概览 -->
          <div id="commentsOverview" class="mb-4 p-3 bg-base-200 rounded-lg">
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm font-medium">评论状态</span>
              <span id="commentsStatusBadge" class="badge badge-ghost badge-sm"
                >检查中...</span
              >
            </div>
            <div class="grid grid-cols-3 gap-2 text-xs">
              <div class="text-center">
                <div
                  id="approvedCommentsCount"
                  class="font-semibold text-success"
                >
                  -
                </div>
                <div class="text-base-content/60">已批准</div>
              </div>
              <div class="text-center">
                <div
                  id="pendingCommentsCount"
                  class="font-semibold text-warning"
                >
                  -
                </div>
                <div class="text-base-content/60">待审核</div>
              </div>
              <div class="text-center">
                <div
                  id="totalCommentsCount"
                  class="font-semibold text-secondary"
                >
                  -
                </div>
                <div class="text-base-content/60">总计</div>
              </div>
            </div>
          </div>

          <div class="card-actions justify-end">
            <a href="/admin/comments" class="btn btn-secondary">
              <Icon name="tabler:message-circle" class="w-4 h-4 mr-1" />
              管理评论
            </a>
          </div>
        </div>
      </div>

      <!-- tRPC API 文档卡片 -->
      <div
        class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow"
      >
        <div class="card-body">
          <div class="flex items-center mb-4">
            <Icon name="tabler:api" class="w-8 h-8 text-info mr-3" />
            <h2 class="card-title text-xl">API 文档</h2>
          </div>
          <p class="text-muted mb-4">
            查看所有可用的 API 接口文档，包含详细的参数说明和使用示例。
          </p>
          <div class="card-actions justify-end">
            <a href="/admin/trpc-docs" class="btn btn-info">
              <Icon name="tabler:book" class="w-4 h-4 mr-1" />
              查看文档
            </a>
          </div>
        </div>
      </div>

      <!-- 系统状态卡片 -->
      <div
        class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow"
      >
        <div class="card-body">
          <div class="flex items-center mb-4">
            <Icon name="tabler:activity" class="w-8 h-8 text-accent mr-3" />
            <h2 class="card-title text-xl">系统状态</h2>
          </div>
          <p class="text-muted mb-4">查看系统运行状态、性能指标和日志信息。</p>
          <div class="card-actions justify-end">
            <button class="btn btn-accent" disabled>
              <Icon name="tabler:chart-line" class="w-4 h-4 mr-1" />
              即将推出
            </button>
          </div>
        </div>
      </div>

      <!-- 内容管理卡片 -->
      <div
        class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow"
      >
        <div class="card-body">
          <div class="flex items-center mb-4">
            <Icon name="tabler:file-text" class="w-8 h-8 text-info mr-3" />
            <h2 class="card-title text-xl">内容管理</h2>
          </div>
          <p class="text-muted mb-4">
            管理博客文章、页面和其他内容，包括发布、编辑和删除操作。
          </p>
          <div class="card-actions justify-end">
            <button class="btn btn-info" disabled>
              <Icon name="tabler:edit" class="w-4 h-4 mr-1" />
              即将推出
            </button>
          </div>
        </div>
      </div>

      <!-- 用户管理卡片 -->
      <div
        class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow"
      >
        <div class="card-body">
          <div class="flex items-center mb-4">
            <Icon name="tabler:users" class="w-8 h-8 text-warning mr-3" />
            <h2 class="card-title text-xl">用户管理</h2>
          </div>
          <p class="text-muted mb-4">管理注册用户、权限设置和用户行为分析。</p>
          <div class="card-actions justify-end">
            <button class="btn btn-warning" disabled>
              <Icon name="tabler:user-cog" class="w-4 h-4 mr-1" />
              即将推出
            </button>
          </div>
        </div>
      </div>

      <!-- 设置卡片 -->
      <div
        class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow"
      >
        <div class="card-body">
          <div class="flex items-center mb-4">
            <Icon name="tabler:settings-cog" class="w-8 h-8 text-error mr-3" />
            <h2 class="card-title text-xl">系统设置</h2>
          </div>
          <p class="text-muted mb-4">
            配置系统参数、主题设置、SEO优化等全局设置。
          </p>
          <div class="card-actions justify-end">
            <button class="btn btn-error" disabled>
              <Icon name="tabler:adjustments" class="w-4 h-4 mr-1" />
              即将推出
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- 快速操作区域 -->
    <div class="mt-12 text-center">
      <div class="divider">快速操作</div>
      <div class="flex flex-wrap justify-center gap-4 mt-6">
        <a href="/blog" class="btn btn-outline btn-sm">
          <Icon name="tabler:arrow-left" class="w-4 h-4 mr-1" />
          返回博客
        </a>
        <a href="/" class="btn btn-outline btn-sm">
          <Icon name="tabler:home" class="w-4 h-4 mr-1" />
          返回首页
        </a>
      </div>
    </div>
  </div>

  <script>
    import { createTRPCClient, httpBatchLink } from "@trpc/client";
    import type { AppRouter } from "~/server/router";

    const trpc = createTRPCClient<AppRouter>({
      links: [
        httpBatchLink({
          url: "/api/trpc",
        }),
      ],
    });

    // 错误对话框处理函数
    function showError(message: string) {
      const errorModal = document.getElementById("errorModal");
      const errorMessage = document.getElementById("errorMessage");
      if (errorModal && errorMessage) {
        errorMessage.textContent = message;
        errorModal.classList.add("modal-open");
      }
    }

    function closeError() {
      const errorModal = document.getElementById("errorModal");
      if (errorModal) {
        errorModal.classList.remove("modal-open");
      }
    }

    // 绑定错误对话框关闭事件
    document
      .getElementById("closeErrorModal")
      ?.addEventListener("click", closeError);
    document.getElementById("errorModal")?.addEventListener("click", (e) => {
      if (e.target === document.getElementById("errorModal")) {
        closeError();
      }
    });

    // 加载仪表盘统计数据
    async function loadDashboardStats() {
      const statsLoading = document.getElementById("stats-loading");
      const statsContent = document.getElementById("stats-content");

      if (!statsLoading || !statsContent) return;

      try {
        statsLoading.classList.remove("hidden");
        statsContent.classList.add("hidden");

        const stats = await trpc.stats.getOverallStats.query();

        // 更新统计数据
        document.getElementById("total-posts")!.textContent =
          stats.content.totalPosts.toString();
        document.getElementById("published-posts")!.textContent =
          stats.content.publishedPosts.toString();
        document.getElementById("draft-posts")!.textContent =
          stats.content.draftPosts.toString();

        document.getElementById("total-memos")!.textContent =
          stats.content.totalMemos.toString();
        document.getElementById("public-memos")!.textContent =
          stats.content.publicMemos.toString();
        document.getElementById("private-memos")!.textContent =
          stats.content.privateMemos.toString();

        document.getElementById("total-comments")!.textContent =
          stats.engagement.totalComments.toString();
        document.getElementById("pending-comments")!.textContent =
          stats.engagement.pendingComments.toString();
        document.getElementById("approved-comments")!.textContent =
          stats.engagement.approvedComments.toString();

        document.getElementById("total-reactions")!.textContent =
          stats.engagement.totalReactions.toString();
        document.getElementById("total-users")!.textContent =
          stats.users.totalUsers.toString();

        statsLoading.classList.add("hidden");
        statsContent.classList.remove("hidden");
      } catch (error) {
        console.error("Failed to load dashboard stats:", error);
        statsLoading.innerHTML =
          '<div class="text-center text-error">加载统计数据失败</div>';
      }
    }

    // 登出功能
    document
      .getElementById("logout-btn")
      ?.addEventListener("click", async () => {
        try {
          const response = await fetch("/api/auth/logout", {
            method: "POST",
          });

          if (response.ok) {
            // 登出成功，重定向到登录页面
            window.location.href = "/admin/login";
          } else {
            showError("登出失败，请重试");
          }
        } catch (error) {
          console.error("登出错误:", error);
          showError("登出失败，请重试");
        }
      });

    // 刷新仪表盘数据
    document
      .getElementById("refresh-dashboard-btn")
      ?.addEventListener("click", loadDashboardStats);

    // 向量化状态概览功能
    async function updateVectorizationOverview() {
      try {
        const statusBadge = document.getElementById("vectorizationStatusBadge");
        const indexedCount = document.getElementById("indexedCount");
        const mismatchCount = document.getElementById("mismatchCount");
        const notIndexedCount = document.getElementById("notIndexedCount");

        if (
          !statusBadge ||
          !indexedCount ||
          !mismatchCount ||
          !notIndexedCount
        ) {
          return;
        }

        // 获取向量化状态
        const response = await fetch("/api/trpc/vectorization.getStatus");
        if (!response.ok) {
          throw new Error(`HTTP error! status: ${response.status}`);
        }

        const data = await response.json();
        const statusData = data.result?.data || {};

        // 统计各种状态的数量
        let indexed = 0;
        let mismatch = 0;
        let notIndexed = 0;

        // 正确处理API响应格式
        Object.values(statusData).forEach((statusInfo: any) => {
          const status = statusInfo.status || statusInfo;
          switch (status) {
            case "correct":
              indexed++;
              break;
            case "mismatch":
              mismatch++;
              break;
            case "notvectorized":
              notIndexed++;
              break;
          }
        });

        const total = indexed + mismatch + notIndexed;

        // 更新显示
        indexedCount.textContent = indexed.toString();
        mismatchCount.textContent = mismatch.toString();
        notIndexedCount.textContent = notIndexed.toString();

        // 更新状态徽章
        if (total === 0) {
          statusBadge.textContent = "无文章";
          statusBadge.className = "badge badge-ghost badge-sm";
        } else if (indexed === total) {
          statusBadge.textContent = "全部已索引";
          statusBadge.className = "badge badge-success badge-sm";
        } else if (notIndexed === 0 && mismatch > 0) {
          statusBadge.textContent = "需要更新";
          statusBadge.className = "badge badge-warning badge-sm";
        } else {
          statusBadge.textContent = "部分已索引";
          statusBadge.className = "badge badge-info badge-sm";
        }
      } catch (error) {
        console.error("获取向量化状态失败:", error);
        const statusBadge = document.getElementById("vectorizationStatusBadge");
        if (statusBadge) {
          statusBadge.textContent = "获取失败";
          statusBadge.className = "badge badge-error badge-sm";
        }
      }
    }

    // 缓存状态概览功能
    async function updateCacheOverview() {
      try {
        const statusBadge = document.getElementById("cacheStatusBadge");
        const postsCount = document.getElementById("cachedPostsCount");
        const memosCount = document.getElementById("cachedMemosCount");
        const totalCount = document.getElementById("totalCachedCount");

        if (!statusBadge || !postsCount || !memosCount || !totalCount) {
          return;
        }

        // 获取缓存状态
        const cacheData = await trpc.contentCache.getStatus.query();

        // 更新显示
        postsCount.textContent = (cacheData.posts?.count || 0).toString();
        memosCount.textContent = (cacheData.memos?.count || 0).toString();
        totalCount.textContent = (cacheData.totalItems || 0).toString();

        // 更新状态徽章
        const total = cacheData.totalItems || 0;
        if (total === 0) {
          statusBadge.textContent = "无缓存";
          statusBadge.className = "badge badge-ghost badge-sm";
        } else {
          statusBadge.textContent = "缓存正常";
          statusBadge.className = "badge badge-success badge-sm";
        }
      } catch (error) {
        console.error("获取缓存状态失败:", error);
        const statusBadge = document.getElementById("cacheStatusBadge");
        if (statusBadge) {
          statusBadge.textContent = "获取失败";
          statusBadge.className = "badge badge-error badge-sm";
        }
      }
    }

    // 文章状态概览功能
    async function updatePostsOverview() {
      try {
        const publishedCount = document.getElementById("publishedPostsCount");
        const draftCount = document.getElementById("draftPostsCount");
        const totalCount = document.getElementById("totalPostsCount");

        if (!publishedCount || !draftCount || !totalCount) {
          return;
        }

        // 获取统计数据
        const statsData = await trpc.stats.getOverallStats.query();

        // 更新显示
        const published = statsData.content?.publishedPosts || 0;
        const draft = statsData.content?.draftPosts || 0;
        const total = statsData.content?.totalPosts || 0;

        publishedCount.textContent = published.toString();
        draftCount.textContent = draft.toString();
        totalCount.textContent = total.toString();
      } catch (error) {
        console.error("获取文章统计失败:", error);
        // 静默处理错误，不显示错误状态
      }
    }

    // 评论状态概览功能
    async function updateCommentsOverview() {
      try {
        const statusBadge = document.getElementById("commentsStatusBadge");
        const approvedCount = document.getElementById("approvedCommentsCount");
        const pendingCount = document.getElementById("pendingCommentsCount");
        const totalCount = document.getElementById("totalCommentsCount");

        if (!statusBadge || !approvedCount || !pendingCount || !totalCount) {
          return;
        }

        // 获取评论统计
        const commentsData = await trpc.comments.getCommentStats.query();

        // 更新显示
        const approved = commentsData.byStatus?.approved || 0;
        const pending = commentsData.byStatus?.pending || 0;
        const total = commentsData.total || 0;

        approvedCount.textContent = approved.toString();
        pendingCount.textContent = pending.toString();
        totalCount.textContent = total.toString();

        // 更新状态徽章
        if (total === 0) {
          statusBadge.textContent = "无评论";
          statusBadge.className = "badge badge-ghost badge-sm";
        } else if (pending === 0) {
          statusBadge.textContent = "无待审核";
          statusBadge.className = "badge badge-success badge-sm";
        } else if (pending > 0) {
          statusBadge.textContent = `${pending}条待审核`;
          statusBadge.className = "badge badge-warning badge-sm";
        } else {
          statusBadge.textContent = "状态正常";
          statusBadge.className = "badge badge-info badge-sm";
        }
      } catch (error) {
        console.error("获取评论状态失败:", error);
        const statusBadge = document.getElementById("commentsStatusBadge");
        if (statusBadge) {
          statusBadge.textContent = "获取失败";
          statusBadge.className = "badge badge-error badge-sm";
        }
      }
    }

    // 页面加载完成后更新状态
    document.addEventListener("DOMContentLoaded", () => {
      loadDashboardStats();
      updateVectorizationOverview();
      updateCacheOverview();
      updatePostsOverview();
      updateCommentsOverview();

      // 每30秒更新一次状态
      setInterval(() => {
        updateVectorizationOverview();
        updateCacheOverview();
        updatePostsOverview();
        updateCommentsOverview();
      }, 30000);
    });
  </script>

  <style>
    /* 统计卡片渐变动画 */
    .stat-card {
      background: linear-gradient(135deg, var(--color-start), var(--color-end));
      position: relative;
      overflow: hidden;
      transition: all 0.3s ease;
    }

    .stat-card::before {
      content: "";
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(
        90deg,
        transparent,
        rgba(255, 255, 255, 0.2),
        transparent
      );
      transition: left 0.5s;
    }

    .stat-card:hover::before {
      left: 100%;
    }

    .stat-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
    }

    /* 卡片悬停效果 */
    .card {
      transition: all 0.3s ease;
    }

    .card:hover {
      transform: translateY(-2px);
    }

    /* 加载动画 */
    @keyframes pulse {
      0%,
      100% {
        opacity: 1;
      }
      50% {
        opacity: 0.5;
      }
    }

    .loading-pulse {
      animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }

    /* 响应式调整 */
    @media (max-width: 768px) {
      .stat-card .card-body {
        padding: 1rem;
      }

      .stat-card h3 {
        font-size: 1rem;
      }

      .stat-card p {
        font-size: 1.5rem;
      }
    }
  </style>

  <!-- 错误提示对话框 -->
  <div id="errorModal" class="modal">
    <div class="modal-box">
      <h3 class="font-bold text-lg text-error">操作失败</h3>
      <p class="py-4" id="errorMessage"></p>
      <div class="modal-action">
        <button id="closeErrorModal" class="btn">确定</button>
      </div>
    </div>
  </div>
</Layout>

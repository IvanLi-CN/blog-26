---
import Layout from '~/layouts/PageLayout.astro';
import { isAdminFromRequest, redirectToAdminLogin } from '~/lib/auth';

// 禁用预渲染，因为这是一个动态页面
export const prerender = false;

// 权限检查
const isUserAdmin = await isAdminFromRequest(
  Astro.cookies,
  Astro.request.headers,
);

if (!isUserAdmin) {
  return redirectToAdminLogin();
}

// 完整的 tRPC API 文档数据 - 基于实际的路由器结构
const apiDocumentation = {
  // 核心功能
  core: [
    {
      path: 'health',
      type: 'query',
      method: 'GET',
      auth: 'public',
      description: '健康检查接口，返回服务状态和时间戳',
      input: 'void',
      output: '{ status: string, timestamp: string }',
      example: 'trpc.health.useQuery()',
    },
    {
      path: 'me',
      type: 'query',
      method: 'GET',
      auth: 'public',
      description: '获取当前用户信息，未登录时返回 null',
      input: 'void',
      output: 'User | null',
      example: 'trpc.me.useQuery()',
    },
    {
      path: 'protected',
      type: 'query',
      method: 'GET',
      auth: 'protected',
      description: '受保护的示例接口，需要用户登录',
      input: '{ message: string }',
      output: '{ message: string, user: User }',
      example: 'trpc.protected.useQuery({ message: "hello" })',
    },
    {
      path: 'admin',
      type: 'mutation',
      method: 'POST',
      auth: 'admin',
      description: '管理员示例接口，需要管理员权限',
      input: '{ action: string }',
      output: '{ success: boolean, action: string, admin: string }',
      example: 'trpc.admin.useMutation()',
    },
  ],

  // 认证系统
  auth: [
    {
      path: 'auth.me',
      type: 'query',
      method: 'GET',
      auth: 'public',
      description: '获取当前认证用户信息',
      input: 'void',
      output: 'User | null',
      example: 'trpc.auth.me.useQuery()',
    },
    {
      path: 'auth.logout',
      type: 'mutation',
      method: 'POST',
      auth: 'public',
      description: '用户登出，清除认证状态',
      input: 'void',
      output: '{ success: boolean, message: string }',
      example: 'trpc.auth.logout.useMutation()',
    },
    {
      path: 'auth.sendVerificationCode',
      type: 'mutation',
      method: 'POST',
      auth: 'public',
      description: '发送邮箱验证码',
      input: '{ email: string, captchaResponse?: string }',
      output: '{ success: boolean, message: string }',
      example: 'trpc.auth.sendVerificationCode.useMutation()',
    },
    {
      path: 'auth.sendAdminCode',
      type: 'mutation',
      method: 'POST',
      auth: 'public',
      description: '发送管理员验证码',
      input: '{ email: string, captchaResponse?: string }',
      output: '{ success: boolean, message: string }',
      example: 'trpc.auth.sendAdminCode.useMutation()',
    },
    {
      path: 'auth.verifyCode',
      type: 'mutation',
      method: 'POST',
      auth: 'public',
      description: '验证邮箱验证码并登录',
      input: '{ email: string, code: string }',
      output: '{ success: boolean, user: User, token: string }',
      example: 'trpc.auth.verifyCode.useMutation()',
    },
  ],

  // 评论系统
  comments: [
    {
      path: 'comments.getComments',
      type: 'query',
      method: 'GET',
      auth: 'public',
      description: '获取文章评论列表，支持分页和嵌套回复',
      input: '{ slug: string, page?: number, limit?: number }',
      output: '{ comments: Comment[], totalPages: number, isAdmin: boolean }',
      example: 'trpc.comments.getComments.useQuery({ slug: "post-slug" })',
    },
    {
      path: 'comments.createComment',
      type: 'mutation',
      method: 'POST',
      auth: 'public',
      description: '创建新评论，支持回复和访客评论',
      input: '{ postSlug: string, content: string, parentId?: string, captchaResponse?: string, author?: { nickname: string, email: string } }',
      output: '{ success: boolean, commentId: string, message: string }',
      example: 'trpc.comments.createComment.useMutation()',
    },
    {
      path: 'comments.moderateComment',
      type: 'mutation',
      method: 'POST',
      auth: 'admin',
      description: '审核评论（批准或拒绝）',
      input: '{ commentId: string, status: "approved" | "rejected" }',
      output: '{ success: boolean, message: string }',
      example: 'trpc.comments.moderateComment.useMutation()',
    },
    {
      path: 'comments.editComment',
      type: 'mutation',
      method: 'POST',
      auth: 'protected',
      description: '编辑自己的评论（需登录）',
      input: '{ commentId: string, content: string }',
      output: '{ success: boolean, message: string }',
      example: 'trpc.comments.editComment.useMutation()',
    },
    {
      path: 'comments.deleteComment',
      type: 'mutation',
      method: 'POST',
      auth: 'protected',
      description: '删除自己的评论（需登录）',
      input: '{ commentId: string }',
      output: '{ success: boolean, message: string }',
      example: 'trpc.comments.deleteComment.useMutation()',
    },
  ],

  // 文章管理
  posts: [
    {
      path: 'posts.getAll',
      type: 'query',
      method: 'GET',
      auth: 'admin',
      description: '获取所有文章列表（仅管理员）',
      input: 'void',
      output: 'Post[]',
      example: 'trpc.posts.getAll.useQuery()',
    },
    {
      path: 'posts.getById',
      type: 'query',
      method: 'GET',
      auth: 'admin',
      description: '根据 ID 获取单个文章',
      input: '{ id: string }',
      output: 'Post',
      example: 'trpc.posts.getById.useQuery({ id: "post-id" })',
    },
    {
      path: 'posts.create',
      type: 'mutation',
      method: 'POST',
      auth: 'admin',
      description: '创建新文章',
      input: '{ slug: string, frontmatter: object, body: string, collection?: string, customPath?: string }',
      output: 'Post',
      example: 'trpc.posts.create.useMutation()',
    },
    {
      path: 'posts.update',
      type: 'mutation',
      method: 'POST',
      auth: 'admin',
      description: '更新文章内容',
      input: '{ id: string, frontmatter: object, body: string }',
      output: 'Post',
      example: 'trpc.posts.update.useMutation()',
    },
    {
      path: 'posts.delete',
      type: 'mutation',
      method: 'POST',
      auth: 'admin',
      description: '删除文章',
      input: '{ id: string }',
      output: '{ success: boolean, message: string }',
      example: 'trpc.posts.delete.useMutation()',
    },
  ],

  // 闪念管理
  memos: [
    {
      path: 'memos.getAll',
      type: 'query',
      method: 'GET',
      auth: 'public',
      description: '获取所有闪念（公开访问，管理员可见私有）',
      input: 'void',
      output: 'Memo[]',
      example: 'trpc.memos.getAll.useQuery()',
    },
    {
      path: 'memos.getMemos',
      type: 'query',
      method: 'GET',
      auth: 'public',
      description: '获取分页闪念列表（支持无限滚动）',
      input: '{ page: number, limit: number }',
      output: '{ memos: Memo[], hasMore: boolean, total: number }',
      example: 'trpc.memos.getMemos.useQuery({ page: 1, limit: 10 })',
    },
    {
      path: 'memos.create',
      type: 'mutation',
      method: 'POST',
      auth: 'admin',
      description: '创建新闪念（管理员专用）',
      input: '{ content: string, isPublic: boolean, attachments?: string[] }',
      output: 'Memo',
      example: 'trpc.memos.create.useMutation()',
    },
    {
      path: 'memos.update',
      type: 'mutation',
      method: 'POST',
      auth: 'admin',
      description: '更新闪念内容（管理员专用）',
      input: '{ id: string, content: string, isPublic: boolean, attachments?: string[] }',
      output: 'Memo',
      example: 'trpc.memos.update.useMutation()',
    },
    {
      path: 'memos.delete',
      type: 'mutation',
      method: 'POST',
      auth: 'admin',
      description: '删除闪念（管理员专用）',
      input: '{ id: string }',
      output: '{ success: boolean, message: string }',
      example: 'trpc.memos.delete.useMutation()',
    },
  ],

  // 搜索功能
  search: [
    {
      path: 'search.query',
      type: 'query',
      method: 'GET',
      auth: 'public',
      description: '基础搜索查询（RAG 增强）',
      input: '{ query: string }',
      output: '{ answer: string, sources: Source[] }',
      example: 'trpc.search.query.useQuery({ query: "搜索内容" })',
    },
    {
      path: 'search.streamQuery',
      type: 'mutation',
      method: 'POST',
      auth: 'public',
      description: '流式搜索查询',
      input: '{ query: string }',
      output: '{ success: boolean, result: string, message: string }',
      example: 'trpc.search.streamQuery.useMutation()',
    },
    {
      path: 'search.chat',
      type: 'mutation',
      method: 'POST',
      auth: 'public',
      description: '对话式搜索（带历史记录）',
      input: '{ query: string, history: ChatMessage[] }',
      output: '{ success: boolean, result: string, message: string }',
      example: 'trpc.search.chat.useMutation()',
    },
    {
      path: 'search.suggestions',
      type: 'query',
      method: 'GET',
      auth: 'public',
      description: '搜索建议',
      input: '{ query: string }',
      output: 'string[]',
      example: 'trpc.search.suggestions.useQuery({ query: "部分查询" })',
    },
  ],

  // 反应系统
  reactions: [
    {
      path: 'reactions.toggle',
      type: 'mutation',
      method: 'POST',
      auth: 'public',
      description: '切换反应（添加或删除）',
      input: '{ targetType: "post" | "comment", targetId: string, emoji: string, fingerprint?: string }',
      output: '{ reacted: boolean, count: number }',
      example: 'trpc.reactions.toggle.useMutation()',
    },
    {
      path: 'reactions.getReactions',
      type: 'query',
      method: 'GET',
      auth: 'public',
      description: '获取反应列表',
      input: '{ targetType: "post" | "comment", targetId: string, fingerprint?: string }',
      output: '{ reactions: Reaction[], userReactions: string[] }',
      example: 'trpc.reactions.getReactions.useQuery({ targetType: "post", targetId: "post-id" })',
    },
  ],

  // 向量化系统
  vectorization: [
    {
      path: 'vectorization.getStatus',
      type: 'query',
      method: 'GET',
      auth: 'admin',
      description: '获取向量化状态',
      input: '{ slugs?: string[] }',
      output: 'Record<string, { status: "correct" | "mismatch" | "notvectorized", errorMessage?: string }>',
      example: 'trpc.vectorization.getStatus.useQuery()',
    },
    {
      path: 'vectorization.startVectorization',
      type: 'mutation',
      method: 'POST',
      auth: 'admin',
      description: '开始向量化处理',
      input: 'void',
      output: '{ success: boolean, message: string }',
      example: 'trpc.vectorization.startVectorization.useMutation()',
    },
    {
      path: 'vectorization.getProgress',
      type: 'query',
      method: 'GET',
      auth: 'admin',
      description: '获取向量化进度',
      input: 'void',
      output: 'VectorizationProgress',
      example: 'trpc.vectorization.getProgress.useQuery()',
    },
    {
      path: 'vectorization.batchVectorize',
      type: 'mutation',
      method: 'POST',
      auth: 'admin',
      description: '批量向量化指定内容',
      input: '{ slugs: string[] }',
      output: '{ success: boolean, message: string }',
      example: 'trpc.vectorization.batchVectorize.useMutation()',
    },
  ],

  // 内容缓存
  contentCache: [
    {
      path: 'contentCache.getStatus',
      type: 'query',
      method: 'GET',
      auth: 'admin',
      description: '获取缓存状态统计',
      input: 'void',
      output: '{ posts: { count: number, lastUpdated: number | null }, memos: { count: number, lastUpdated: number | null }, totalItems: number }',
      example: 'trpc.contentCache.getStatus.useQuery()',
    },
    {
      path: 'contentCache.getPosts',
      type: 'query',
      method: 'GET',
      auth: 'public',
      description: '获取缓存的文章列表',
      input: '{ page?: number, limit?: number, type?: string }',
      output: '{ posts: CachedPost[], total: number, hasMore: boolean }',
      example: 'trpc.contentCache.getPosts.useQuery({ page: 1, limit: 10 })',
    },
    {
      path: 'contentCache.getMemos',
      type: 'query',
      method: 'GET',
      auth: 'public',
      description: '获取缓存的闪念列表',
      input: '{ page?: number, limit?: number }',
      output: '{ memos: CachedMemo[], total: number, hasMore: boolean }',
      example: 'trpc.contentCache.getMemos.useQuery({ page: 1, limit: 10 })',
    },
    {
      path: 'contentCache.refresh',
      type: 'mutation',
      method: 'POST',
      auth: 'admin',
      description: '手动触发缓存刷新（管理员专用）',
      input: 'void',
      output: '{ success: boolean, message: string }',
      example: 'trpc.contentCache.refresh.useMutation()',
    },
  ],


};

// 计算总数和统计信息
const totalProcedures = Object.values(apiDocumentation).reduce((total, category) => total + category.length, 0);

// 转换为展示格式
const allEndpoints = Object.entries(apiDocumentation).flatMap(([category, procedures]) =>
  procedures.map(procedure => ({
    path: procedure.path,
    method: procedure.method,
    summary: procedure.description,
    description: procedure.description,
    tags: [category],
    operationId: procedure.path.replace(/\./g, '_'),
    auth: procedure.auth,
    input: procedure.input,
    output: procedure.output,
    example: procedure.example,
  }))
);

// 按标签分组
const endpointsByTag = allEndpoints.reduce((acc, endpoint) => {
  const tag = endpoint.tags[0] || 'core';
  if (!acc[tag]) acc[tag] = [];
  acc[tag].push(endpoint);
  return acc;
}, {} as Record<string, typeof allEndpoints>);

// 中文标签映射
const tagNameMap: Record<string, string> = {
  core: '核心功能',
  auth: '认证系统',
  comments: '评论系统',
  posts: '文章管理',
  memos: '闪念管理',
  search: '搜索功能',
  reactions: '反应系统',
  vectorization: '向量化',
  contentCache: '内容缓存',
};

// 权限级别推断
function getAuthLevel(path: string): 'public' | 'protected' | 'admin' {
  if (path.includes('admin') || path.startsWith('posts.') || path.startsWith('vectorization.')) {
    return 'admin';
  }
  if (path.includes('protected') || path.includes('edit') || path.includes('delete')) {
    return 'protected';
  }
  return 'public';
}
---

<Layout
  metadata={{
    title: 'API 文档',
    description: '完整的 API 接口文档',
    robots: {
      index: false,
      follow: false,
    },
  }}
>
  <div class="container mx-auto px-4 py-8">
    <div class="max-w-6xl mx-auto">
      <!-- 页面标题 -->
      <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">API 文档</h1>
        <p class="text-gray-600">完整的 API 接口文档，包含所有可用的接口和详细说明</p>
        <div class="mt-4 grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="p-4 bg-blue-50 rounded-lg">
            <p class="text-sm text-blue-800">
              <strong>基础 URL:</strong> <code>/api/trpc</code><br>
              <strong>总计接口:</strong> {allEndpoints.length} 个
            </p>
          </div>
          <div class="p-4 bg-green-50 rounded-lg">
            <p class="text-sm text-green-800">
              <strong>文档来源:</strong> ✅ 基于实际路由器<br>
              <strong>维护方式:</strong> 手动精心维护
            </p>
          </div>
          <div class="p-4 bg-purple-50 rounded-lg">
            <p class="text-sm text-purple-800">
              <strong>分类数量:</strong> {Object.keys(endpointsByTag).length} 个<br>
              <strong>更新状态:</strong> 与代码同步
            </p>
          </div>
        </div>
      </div>

      <!-- 权限说明 -->
      <div class="mb-8">
        <h2 class="text-xl font-semibold mb-4">权限级别说明</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="p-4 bg-green-50 rounded-lg">
            <div class="flex items-center mb-2">
              <span class="inline-block w-3 h-3 bg-green-500 rounded-full mr-2"></span>
              <span class="font-medium text-green-800">Public</span>
            </div>
            <p class="text-sm text-green-700">无需认证，公开访问</p>
          </div>
          <div class="p-4 bg-yellow-50 rounded-lg">
            <div class="flex items-center mb-2">
              <span class="inline-block w-3 h-3 bg-yellow-500 rounded-full mr-2"></span>
              <span class="font-medium text-yellow-800">Protected</span>
            </div>
            <p class="text-sm text-yellow-700">需要用户登录</p>
          </div>
          <div class="p-4 bg-red-50 rounded-lg">
            <div class="flex items-center mb-2">
              <span class="inline-block w-3 h-3 bg-red-500 rounded-full mr-2"></span>
              <span class="font-medium text-red-800">Admin</span>
            </div>
            <p class="text-sm text-red-700">需要管理员权限</p>
          </div>
        </div>
      </div>

      <!-- API 分类展示 -->
      {Object.entries(endpointsByTag).map(([tag, endpoints]) => (
        <div class="mb-8">
          <h2 class="text-2xl font-semibold mb-4">
            {tagNameMap[tag] || tag} ({endpoints.length})
          </h2>
          <div class="space-y-4">
            {endpoints.map((endpoint) => {
              const authLevel = getAuthLevel(endpoint.path);
              const authColor = authLevel === 'admin' ? 'red' : authLevel === 'protected' ? 'yellow' : 'green';
              const methodColor = endpoint.method === 'POST' ? 'blue' : endpoint.method === 'PUT' ? 'orange' : endpoint.method === 'DELETE' ? 'red' : 'gray';

              return (
                <div class="border border-gray-200 rounded-lg p-4 bg-white">
                  <div class="flex items-center justify-between mb-3">
                    <div class="flex items-center space-x-3">
                      <span class={`inline-block px-2 py-1 text-xs font-medium rounded ${
                        methodColor === 'blue' ? 'bg-blue-100 text-blue-800' :
                        methodColor === 'orange' ? 'bg-orange-100 text-orange-800' :
                        methodColor === 'red' ? 'bg-red-100 text-red-800' :
                        'bg-gray-100 text-gray-800'
                      }`}>
                        {endpoint.method}
                      </span>
                      <code class="text-sm font-mono bg-gray-100 px-2 py-1 rounded cursor-pointer hover:bg-gray-200 transition-colors" onclick="selectText(this)" title="点击全选">
                        {endpoint.path}
                      </code>
                    </div>
                    <span class={`inline-block w-3 h-3 rounded-full ${
                      authColor === 'red' ? 'bg-red-500' :
                      authColor === 'yellow' ? 'bg-yellow-500' :
                      'bg-green-500'
                    }`} title={authLevel}></span>
                  </div>

                  <div class="mb-3">
                    <p class="text-sm text-gray-700 mb-2">
                      {endpoint.summary || endpoint.description || `${endpoint.path} 接口`}
                    </p>
                  </div>

                  <div class="mb-3">
                    <p class="font-medium text-gray-700 mb-1">权限级别:</p>
                    <span class={`text-xs px-2 py-1 rounded ${
                      authColor === 'red' ? 'bg-red-100 text-red-800' :
                      authColor === 'yellow' ? 'bg-yellow-100 text-yellow-800' :
                      'bg-green-100 text-green-800'
                    }`}>
                      {authLevel}
                    </span>
                  </div>

                  <div class="mt-3">
                    <p class="font-medium text-gray-700 mb-1 text-sm">输入参数:</p>
                    <code class="text-xs bg-gray-50 p-2 rounded block cursor-pointer hover:bg-gray-100 transition-colors" onclick="selectText(this)" title="点击全选">
                      {endpoint.input}
                    </code>
                  </div>

                  <div class="mt-3">
                    <p class="font-medium text-gray-700 mb-1 text-sm">返回类型:</p>
                    <code class="text-xs bg-gray-50 p-2 rounded block cursor-pointer hover:bg-gray-100 transition-colors" onclick="selectText(this)" title="点击全选">
                      {endpoint.output}
                    </code>
                  </div>

                  <div class="mt-3">
                    <p class="font-medium text-gray-700 mb-1 text-sm">使用示例:</p>
                    <code class="text-xs bg-gray-900 text-gray-100 p-2 rounded block cursor-pointer hover:bg-gray-800 transition-colors" onclick="selectText(this)" title="点击全选">
                      {endpoint.example}
                    </code>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      ))}





      <!-- 文档说明 -->
      <div class="mb-8">
        <h2 class="text-2xl font-semibold mb-4">关于此文档</h2>
        <div class="bg-blue-50 p-4 rounded-lg">
          <p class="text-sm text-blue-800 mb-2">
            <strong>✅ 特点:</strong>
          </p>
          <ul class="text-sm text-blue-700 mb-4 list-disc list-inside">
            <li>完整覆盖所有 tRPC API 接口</li>
            <li>详细的中文描述和使用说明</li>
            <li>清晰的权限级别标识</li>
            <li>实用的代码示例</li>
          </ul>
          <p class="text-sm text-blue-800 mb-2">
            <strong>📝 维护:</strong>
          </p>
          <ul class="text-sm text-blue-700 list-disc list-inside">
            <li>基于实际的 tRPC 路由器结构</li>
            <li>手动精心维护，确保准确性</li>
            <li>定期更新以保持与代码同步</li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- 全选功能脚本 -->
  <script is:inline>
    function selectText(element) {
      if (window.getSelection) {
        const selection = window.getSelection();
        const range = document.createRange();
        range.selectNodeContents(element);
        selection.removeAllRanges();
        selection.addRange(range);

        // 尝试复制到剪贴板
        const text = (element.textContent || element.innerText).trim();
        if (navigator.clipboard && window.isSecureContext) {
          // 使用现代 Clipboard API
          navigator.clipboard.writeText(text).then(() => {
            showCopyFeedback(element);
          }).catch(err => {
            console.log('复制失败:', err);
            fallbackCopy(element);
          });
        } else {
          // 降级到旧方法
          fallbackCopy(element);
        }
      }
    }

    function fallbackCopy(element) {
      try {
        document.execCommand('copy');
        showCopyFeedback(element);
      } catch (err) {
        console.log('复制失败:', err);
      }
    }

    function showCopyFeedback(element) {
      const originalBg = element.style.backgroundColor;
      const originalColor = element.style.color;
      element.style.backgroundColor = '#10b981';
      element.style.color = 'white';
      setTimeout(() => {
        element.style.backgroundColor = originalBg;
        element.style.color = originalColor;
      }, 200);
    }
  </script>
</Layout>

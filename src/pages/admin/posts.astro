---
import Layout from "~/layouts/Layout.astro";
import { isAdminFromRequest, redirectToAdminLogin } from "~/lib/auth";
import { fetchPosts } from "~/utils/blog";

export const prerender = false;

// Check if user is admin
const isUserAdmin =
  process.env.ADMIN_MODE === "true" ||
  (await isAdminFromRequest(Astro.cookies, Astro.request.headers));

if (!isUserAdmin) {
  return redirectToAdminLogin();
}

// Get all posts including drafts from both local collections and WebDAV
// Set ADMIN_MODE to true to include draft posts
process.env.ADMIN_MODE = "true";
const sortedPosts = await fetchPosts();

const metadata = {
  title: "文章管理 - 管理员面板",
  description: "管理所有文章，包括草稿和已发布的文章",
  robots: {
    index: false,
    follow: false,
  },
};
---

<Layout metadata={metadata}>
  <!-- Simple Admin Header -->
  <div class="bg-base-200 border-b border-base-300">
    <div class="max-w-7xl mx-auto px-4 py-3">
      <div class="flex justify-between items-center">
        <div class="flex items-center space-x-4">
          <a href="/admin" class="text-lg font-semibold hover:text-primary"
            >管理员面板</a
          >
          <span class="text-base-content/50">/</span>
          <span class="text-base-content/70">文章管理</span>
        </div>
        <a href="/admin" class="btn btn-ghost btn-sm">返回首页</a>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 py-8">
    <div class="mb-8 flex justify-between items-start">
      <div>
        <h1 class="text-3xl font-bold mb-2">文章管理</h1>
        <p class="text-base-content/70">管理所有文章，包括草稿和已发布的文章</p>
      </div>
      <div class="flex gap-2">
        <a href="/admin/posts/edit?new=true" class="btn btn-primary">
          <svg
            class="w-4 h-4 mr-2"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 4v16m8-8H4"></path>
          </svg>
          新建文章
        </a>
      </div>
    </div>

    <!-- Statistics -->
    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 mb-8"
      id="stats-cards"
    >
      <div
        class="card bg-base-100 shadow-xl cursor-pointer hover:shadow-2xl transition-shadow filter-card active"
        data-filter="all"
      >
        <div class="card-body p-6">
          <div class="flex items-center">
            <div class="p-2 bg-primary/10 rounded-lg">
              <svg
                class="w-6 h-6 text-primary"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                ></path>
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-base-content/70">总文章数</p>
              <p class="text-2xl font-semibold">
                {sortedPosts.length}
              </p>
            </div>
          </div>
        </div>
      </div>

      <div
        class="card bg-base-100 shadow-xl cursor-pointer hover:shadow-2xl transition-shadow filter-card"
        data-filter="published"
      >
        <div class="card-body p-6">
          <div class="flex items-center">
            <div class="p-2 bg-success/10 rounded-lg">
              <svg
                class="w-6 h-6 text-success"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-base-content/70">已发布</p>
              <p class="text-2xl font-semibold">
                {
                  sortedPosts.filter((p) => !p.draft && p.public !== false)
                    .length
                }
              </p>
            </div>
          </div>
        </div>
      </div>

      <div
        class="card bg-base-100 shadow-xl cursor-pointer hover:shadow-2xl transition-shadow filter-card"
        data-filter="draft"
      >
        <div class="card-body p-6">
          <div class="flex items-center">
            <div class="p-2 bg-warning/10 rounded-lg">
              <svg
                class="w-6 h-6 text-warning"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"
                ></path>
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-base-content/70">草稿</p>
              <p class="text-2xl font-semibold">
                {sortedPosts.filter((p) => p.draft).length}
              </p>
            </div>
          </div>
        </div>
      </div>

      <div
        class="card bg-base-100 shadow-xl cursor-pointer hover:shadow-2xl transition-shadow filter-card"
        data-filter="private"
      >
        <div class="card-body p-6">
          <div class="flex items-center">
            <div class="p-2 bg-error/10 rounded-lg">
              <svg
                class="w-6 h-6 text-error"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.878 9.878L3 3m6.878 6.878L21 21"
                ></path>
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-base-content/70">私有</p>
              <p class="text-2xl font-semibold">
                {
                  sortedPosts.filter((p) => !p.draft && p.public === false)
                    .length
                }
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="card bg-base-100 shadow-xl">
        <div class="card-body p-6">
          <div class="flex items-center">
            <div class="p-2 bg-secondary/10 rounded-lg">
              <svg
                class="w-6 h-6 text-secondary"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"
                ></path>
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-base-content/70">标签数</p>
              <p class="text-2xl font-semibold">
                {
                  new Set(
                    sortedPosts.flatMap(
                      (p) => p.tags?.map((t) => t.slug) || [],
                    ),
                  ).size
                }
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Posts Table -->
    <div class="card bg-base-100 shadow-xl overflow-hidden">
      <div class="card-body p-0">
        <div class="px-6 py-4 border-b border-base-300">
          <div class="flex justify-between items-center">
            <h2 class="text-lg font-semibold">所有文章</h2>
            <div class="flex items-center space-x-2">
              <div id="batchActions" class="hidden items-center space-x-2">
                <span class="text-sm text-base-content/70">
                  已选择 <span id="selectedCount">0</span> 篇文章
                </span>
                <button
                  id="batchVectorizeBtn"
                  class="btn btn-primary btn-sm"
                  disabled
                >
                  <svg
                    class="w-4 h-4 mr-1"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                  </svg>
                  批量向量化
                </button>
                <button id="clearSelectionBtn" class="btn btn-ghost btn-sm">
                  清除选择
                </button>
              </div>
            </div>
          </div>
        </div>

        <div class="overflow-x-auto">
          <table class="table table-zebra w-full">
            <thead>
              <tr>
                <th class="w-1/12">
                  <label class="cursor-pointer">
                    <input
                      type="checkbox"
                      id="selectAll"
                      class="checkbox checkbox-sm"
                    />
                  </label>
                </th>
                <th class="w-3/12">标题</th>
                <th class="w-3/12">状态/日期</th>
                <th class="w-2/12">标签</th>
                <th class="w-1/12">操作</th>
              </tr>
            </thead>
            <tbody>
              {
                sortedPosts.map((post) => {
                  const postStatus = post.draft
                    ? "draft"
                    : post.public === false
                      ? "private"
                      : "published";
                  return (
                    <tr class="hover post-row" data-status={postStatus}>
                      <td>
                        <label class="cursor-pointer">
                          <input
                            type="checkbox"
                            class="checkbox checkbox-sm post-checkbox"
                            data-slug={post.slug}
                          />
                        </label>
                      </td>
                      <td>
                        <div>
                          <div class="text-sm font-medium truncate">
                            {post.title}
                          </div>
                          {post.excerpt ? (
                            <div class="text-xs text-base-content/60 truncate">
                              {post.excerpt.substring(0, 60)}...
                            </div>
                          ) : (
                            <div class="text-xs text-base-content/40 italic">
                              无简介
                            </div>
                          )}
                          <div class="text-xs text-base-content/40 mt-1 flex items-center">
                            {post.id.startsWith("/") ? (
                              <span class="inline-flex items-center">
                                <svg
                                  class="w-3 h-3 mr-1 text-green-500"
                                  fill="currentColor"
                                  viewBox="0 0 20 20"
                                >
                                  <path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6zM14 9a1 1 0 00-1 1v6a1 1 0 001 1h2a1 1 0 001-1v-6a1 1 0 00-1-1h-2z" />
                                </svg>
                                WebDAV
                              </span>
                            ) : (
                              <span class="inline-flex items-center">
                                <svg
                                  class="w-3 h-3 mr-1 text-blue-500"
                                  fill="currentColor"
                                  viewBox="0 0 20 20"
                                >
                                  <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z" />
                                  <path
                                    fill-rule="evenodd"
                                    d="M4 5a2 2 0 012-2v1a1 1 0 102 0V3a2 2 0 012 2v6a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 2a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z"
                                    clip-rule="evenodd"
                                  />
                                </svg>
                                本地
                              </span>
                            )}
                            <span class="ml-2 truncate" title={post.id}>
                              {post.id.length > 50
                                ? post.id.substring(0, 50) + "..."
                                : post.id}
                            </span>
                          </div>
                        </div>
                      </td>
                      <td>
                        <div class="flex flex-col gap-1">
                          <div class="flex gap-1 items-center">
                            {post.draft ? (
                              <span class="badge badge-warning badge-sm">
                                草稿
                              </span>
                            ) : post.public === false ? (
                              <span class="badge badge-error badge-sm">
                                私有
                              </span>
                            ) : (
                              <span class="badge badge-success badge-sm">
                                已发布
                              </span>
                            )}
                          </div>
                          <div class="text-xs text-base-content/60">
                            {post.publishDate.toLocaleDateString("zh-CN", {
                              month: "short",
                              day: "numeric",
                            })}
                          </div>
                          <div>
                            <span
                              class="vectorization-status badge badge-xs badge-ghost"
                              data-slug={post.slug}
                              title="正在检查向量化状态..."
                            >
                              检查中
                            </span>
                          </div>
                        </div>
                      </td>
                      <td>
                        <div class="flex flex-wrap gap-1">
                          {post.tags?.map((tag) => (
                            <span class="badge badge-primary badge-outline badge-xs">
                              {tag.title.split("/").pop() || tag.title}
                            </span>
                          ))}
                        </div>
                      </td>
                      <td>
                        <div class="flex gap-1">
                          {post.id.startsWith("/") && (
                            <a
                              href={`/admin/posts/edit?id=${encodeURIComponent(post.id)}`}
                              class="btn btn-ghost btn-xs"
                              title="编辑文章"
                            >
                              <svg
                                class="w-3 h-3"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                              >
                                <path
                                  stroke-linecap="round"
                                  stroke-linejoin="round"
                                  stroke-width="2"
                                  d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
                                />
                              </svg>
                            </a>
                          )}
                          <button
                            class="btn btn-ghost btn-xs text-primary hover:bg-primary hover:text-primary-content quick-vectorize-btn"
                            title="快速向量化此文章"
                            data-slug={post.slug}
                            data-title={post.title}
                          >
                            <svg
                              class="w-3 h-3"
                              fill="none"
                              stroke="currentColor"
                              viewBox="0 0 24 24"
                            >
                              <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M13 10V3L4 14h7v7l9-11h-7z"
                              />
                            </svg>
                          </button>
                          <a
                            href={`/${post.permalink}`}
                            class="btn btn-ghost btn-xs"
                            target="_blank"
                            title="查看文章"
                          >
                            <svg
                              class="w-3 h-3"
                              fill="none"
                              stroke="currentColor"
                              viewBox="0 0 24 24"
                            >
                              <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
                              />
                              <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
                              />
                            </svg>
                          </a>
                          {post.id.startsWith("/") && (
                            <button
                              class="btn btn-ghost btn-xs text-error hover:bg-error hover:text-error-content delete-post-btn"
                              title="删除文章"
                              data-post-id={post.id}
                              data-post-title={post.title}
                            >
                              <svg
                                class="w-3 h-3"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                              >
                                <path
                                  stroke-linecap="round"
                                  stroke-linejoin="round"
                                  stroke-width="2"
                                  d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
                                />
                              </svg>
                            </button>
                          )}
                        </div>
                      </td>
                    </tr>
                  );
                })
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- 删除确认对话框 -->
  <div id="deleteModal" class="modal">
    <div class="modal-box">
      <h3 class="font-bold text-lg">确认删除文章</h3>
      <p class="py-4">
        您确定要删除文章 "<span id="deletePostTitle" class="font-semibold"
        ></span>" 吗？
      </p>
      <p class="text-sm text-warning mb-4">
        ⚠️ 此操作不可撤销，文章将被永久删除。
      </p>
      <div class="modal-action">
        <button id="confirmDelete" class="btn btn-error">
          <svg
            class="w-4 h-4 mr-2"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
            ></path>
          </svg>
          确认删除
        </button>
        <button id="cancelDelete" class="btn">取消</button>
      </div>
    </div>
  </div>

  <!-- 加载提示 -->
  <div id="loadingToast" class="toast toast-center hidden">
    <div class="alert alert-info">
      <span class="loading loading-spinner"></span>
      正在删除文章...
    </div>
  </div>

  <style>
    .filter-card.active {
      border: 2px solid hsl(var(--p));
      box-shadow:
        0 10px 15px -3px rgba(0, 0, 0, 0.1),
        0 4px 6px -2px rgba(0, 0, 0, 0.05);
    }
  </style>

  <script>
    import { trpcVanilla } from "~/lib/trpc";

    document.addEventListener("DOMContentLoaded", function () {
      const filterCards = document.querySelectorAll(".filter-card");
      const postRows = document.querySelectorAll(".post-row");

      // 删除功能相关元素
      const deleteModal = document.getElementById("deleteModal");
      const deletePostTitle = document.getElementById("deletePostTitle");
      const confirmDeleteBtn = document.getElementById("confirmDelete");
      const cancelDeleteBtn = document.getElementById("cancelDelete");
      const loadingToast = document.getElementById("loadingToast");
      let currentPostId = null;

      // 检查必要元素是否存在
      if (
        !deleteModal ||
        !deletePostTitle ||
        !confirmDeleteBtn ||
        !cancelDeleteBtn ||
        !loadingToast
      ) {
        console.error("删除功能相关元素未找到");
        return;
      }

      filterCards.forEach((card) => {
        card.addEventListener("click", function () {
          const filter = this.getAttribute("data-filter");

          // 更新活跃状态
          filterCards.forEach((c) => c.classList.remove("active"));
          this.classList.add("active");

          // 筛选文章行
          postRows.forEach((row) => {
            const postStatus = row.getAttribute("data-status");
            const htmlRow = row as HTMLElement;

            if (filter === "all") {
              htmlRow.style.display = "";
            } else if (filter === postStatus) {
              htmlRow.style.display = "";
            } else {
              htmlRow.style.display = "none";
            }
          });

          // 更新表格显示状态
          updateTableVisibility();
        });
      });

      function updateTableVisibility() {
        const visibleRows = Array.from(postRows).filter(
          (row) => (row as HTMLElement).style.display !== "none",
        );
        const tableBody = document.querySelector("tbody");

        if (visibleRows.length === 0) {
          // 如果没有可见行，显示空状态消息
          if (!document.querySelector(".empty-state")) {
            const emptyRow = document.createElement("tr");
            emptyRow.className = "empty-state";
            emptyRow.innerHTML = `
            <td colspan="6" class="px-6 py-12 text-center text-gray-500 dark:text-gray-400">
              <div class="flex flex-col items-center">
                <svg class="w-12 h-12 mb-4 text-gray-300 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
                <p class="text-lg font-medium">没有找到匹配的文章</p>
                <p class="text-sm">尝试选择其他筛选条件</p>
              </div>
            </td>
          `;
            tableBody?.appendChild(emptyRow);
          }
        } else {
          // 移除空状态消息
          const emptyState = document.querySelector(".empty-state");
          if (emptyState) {
            emptyState.remove();
          }
        }
      }

      // 获取文章向量化状态
      async function fetchVectorizationStatus() {
        try {
          // 收集所有文章的 slug
          const statusElements = document.querySelectorAll(
            ".vectorization-status",
          );
          const slugs = Array.from(statusElements)
            .map((el) => el.getAttribute("data-slug"))
            .filter((slug): slug is string => Boolean(slug));

          if (slugs.length === 0) return;

          // 发送请求获取向量化状态
          const statusData = await trpcVanilla.vectorization.getStatus.query({
            slugs,
          });

          // 更新每篇文章的向量化状态显示
          statusElements.forEach((element) => {
            const slug = element.getAttribute("data-slug");
            if (!slug || !statusData[slug]) return;

            const statusInfo = statusData[slug];
            const status = statusInfo.status || statusInfo; // 兼容旧格式
            const errorMessage = statusInfo.errorMessage;
            const statusElement = element as HTMLElement;

            // 根据状态设置样式和内容
            if (status === "correct") {
              statusElement.className =
                "vectorization-status badge badge-xs badge-ghost text-success";
              statusElement.textContent = "已索引";
              statusElement.title = "内容已成功向量化，可用于智能搜索";
            } else if (status === "mismatch") {
              statusElement.className =
                "vectorization-status badge badge-xs badge-ghost text-warning";
              statusElement.textContent = "需更新";
              statusElement.title = "向量化模型已更新，需要重新向量化此内容";
            } else {
              statusElement.className =
                "vectorization-status badge badge-xs badge-ghost text-error";
              statusElement.textContent = "未索引";
              // 如果有错误信息，显示在 title 中
              if (errorMessage) {
                statusElement.title = `向量化失败: ${errorMessage}`;
              } else {
                statusElement.title = "内容尚未向量化，无法用于智能搜索";
              }
            }
          });
        } catch (error) {
          console.error("获取向量化状态失败:", error);
          // 显示错误状态
          document
            .querySelectorAll(".vectorization-status")
            .forEach((element) => {
              const statusElement = element as HTMLElement;

              statusElement.className =
                "vectorization-status badge badge-xs badge-ghost text-error";
              statusElement.textContent = "获取失败";
              statusElement.title = "无法获取向量化状态，请刷新页面重试";
            });
        }
      }

      // 删除文章功能
      const deleteButtons = document.querySelectorAll(".delete-post-btn");
      deleteButtons.forEach((button) => {
        button.addEventListener("click", function () {
          currentPostId = this.getAttribute("data-post-id");
          const postTitle = this.getAttribute("data-post-title");

          deletePostTitle.textContent = postTitle;
          deleteModal.classList.add("modal-open");
        });
      });

      // 取消删除
      cancelDeleteBtn.addEventListener("click", function () {
        deleteModal.classList.remove("modal-open");
        currentPostId = null;
      });

      // 点击模态框背景关闭
      deleteModal.addEventListener("click", function (e) {
        if (e.target === deleteModal) {
          deleteModal.classList.remove("modal-open");
          currentPostId = null;
        }
      });

      // 确认删除
      confirmDeleteBtn.addEventListener("click", async function () {
        if (!currentPostId) return;

        try {
          // 显示加载状态
          loadingToast.classList.remove("hidden");
          (confirmDeleteBtn as HTMLButtonElement).disabled = true;
          confirmDeleteBtn.innerHTML =
            '<span class="loading loading-spinner loading-sm"></span> 删除中...';

          // 调用删除API
          await trpcVanilla.posts.delete.mutate({
            id: currentPostId,
          });

          // 删除成功，移除对应的行
          const postRow = document
            .querySelector(`[data-post-id="${currentPostId}"]`)
            ?.closest("tr");
          if (postRow) {
            postRow.remove();
          }

          // 关闭模态框
          deleteModal.classList.remove("modal-open");

          // 显示成功消息
          showToast("文章删除成功", "success");

          // 更新表格显示状态
          updateTableVisibility();
        } catch (error) {
          console.error("删除文章失败:", error);
          showToast((error as Error).message || "删除文章失败", "error");
        } finally {
          // 恢复按钮状态
          loadingToast.classList.add("hidden");
          (confirmDeleteBtn as HTMLButtonElement).disabled = false;
        }
      });

      // 页面加载完成后获取向量化状态
      fetchVectorizationStatus();

      // 显示提示消息的函数
      function showToast(message: string, type: string = "info") {
        const toast = document.createElement("div");
        toast.className = "toast toast-top toast-center";
        toast.innerHTML = `
          <div class="alert alert-${type}">
            <span>${message}</span>
          </div>
        `;

        document.body.appendChild(toast);

        setTimeout(() => {
          toast.remove();
        }, 3000);
      }

      // 批量选择功能
      const selectAllCheckbox = document.getElementById(
        "selectAll",
      ) as HTMLInputElement;
      const postCheckboxes = document.querySelectorAll(
        ".post-checkbox",
      ) as NodeListOf<HTMLInputElement>;
      const batchActions = document.getElementById(
        "batchActions",
      ) as HTMLElement;
      const selectedCount = document.getElementById(
        "selectedCount",
      ) as HTMLElement;
      const batchVectorizeBtn = document.getElementById(
        "batchVectorizeBtn",
      ) as HTMLButtonElement;
      const clearSelectionBtn = document.getElementById(
        "clearSelectionBtn",
      ) as HTMLButtonElement;

      // 更新批量操作界面
      function updateBatchActions() {
        const checkedBoxes = Array.from(postCheckboxes).filter(
          (cb) => cb.checked,
        );
        const count = checkedBoxes.length;

        if (count > 0) {
          batchActions.classList.remove("hidden");
          batchActions.classList.add("flex");
          selectedCount.textContent = count.toString();
          batchVectorizeBtn.disabled = false;
        } else {
          batchActions.classList.add("hidden");
          batchActions.classList.remove("flex");
          batchVectorizeBtn.disabled = true;
        }

        // 更新全选复选框状态
        if (count === 0) {
          selectAllCheckbox.indeterminate = false;
          selectAllCheckbox.checked = false;
        } else if (count === postCheckboxes.length) {
          selectAllCheckbox.indeterminate = false;
          selectAllCheckbox.checked = true;
        } else {
          selectAllCheckbox.indeterminate = true;
          selectAllCheckbox.checked = false;
        }
      }

      // 全选/取消全选
      selectAllCheckbox.addEventListener("change", () => {
        const isChecked = selectAllCheckbox.checked;
        postCheckboxes.forEach((checkbox) => {
          checkbox.checked = isChecked;
        });
        updateBatchActions();
      });

      // 单个复选框变化
      postCheckboxes.forEach((checkbox) => {
        checkbox.addEventListener("change", updateBatchActions);
      });

      // 清除选择
      clearSelectionBtn.addEventListener("click", () => {
        postCheckboxes.forEach((checkbox) => {
          checkbox.checked = false;
        });
        updateBatchActions();
      });

      // 批量向量化
      batchVectorizeBtn.addEventListener("click", async () => {
        const checkedBoxes = Array.from(postCheckboxes).filter(
          (cb) => cb.checked,
        );
        const slugs = checkedBoxes
          .map((cb) => cb.getAttribute("data-slug"))
          .filter((slug): slug is string => Boolean(slug));

        if (slugs.length === 0) {
          showToast("请选择要向量化的文章", "warning");
          return;
        }

        try {
          batchVectorizeBtn.disabled = true;
          batchVectorizeBtn.innerHTML =
            '<span class="loading loading-spinner loading-sm"></span> 启动中...';

          const result = await trpcVanilla.vectorization.batchVectorize.mutate({
            slugs,
          });

          showToast(result.message, "success");

          // 清除选择
          postCheckboxes.forEach((checkbox) => {
            checkbox.checked = false;
          });
          updateBatchActions();

          // 重新获取向量化状态
          setTimeout(() => {
            fetchVectorizationStatusWithUpdates();
          }, 1000);
        } catch (error) {
          console.error("批量向量化失败:", error);
          showToast("批量向量化启动失败", "error");
        } finally {
          batchVectorizeBtn.disabled = false;
          batchVectorizeBtn.innerHTML = `
            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
            批量向量化
          `;
        }
      });

      // 初始化批量操作界面
      updateBatchActions();

      // 实时状态更新功能
      let statusUpdateInterval: number | null = null;
      let isVectorizationRunning = false;

      // 检查是否有向量化进程正在运行
      function checkVectorizationStatus() {
        // 检查是否有状态显示为"处理中"的元素
        const processingElements = document.querySelectorAll(
          ".vectorization-status",
        );
        let hasProcessing = false;

        processingElements.forEach((element) => {
          const text = element.textContent?.toLowerCase() || "";
          if (
            text.includes("处理中") ||
            text.includes("启动中") ||
            text.includes("检查中")
          ) {
            hasProcessing = true;
          }
        });

        return hasProcessing;
      }

      // 启动实时状态更新
      function startStatusUpdates() {
        if (statusUpdateInterval) return;

        statusUpdateInterval = window.setInterval(() => {
          fetchVectorizationStatusWithUpdates();
        }, 3000); // 每3秒更新一次
      }

      // 停止实时状态更新
      function stopStatusUpdates() {
        if (statusUpdateInterval) {
          clearInterval(statusUpdateInterval);
          statusUpdateInterval = null;
        }
      }

      // 增强的向量化状态获取函数
      async function fetchVectorizationStatusWithUpdates() {
        await fetchVectorizationStatus();

        // 检查是否有向量化正在进行
        const wasRunning = isVectorizationRunning;
        isVectorizationRunning = checkVectorizationStatus();

        // 根据状态决定是否启动/停止实时更新
        if (isVectorizationRunning && !wasRunning) {
          console.log("检测到向量化进程，启动实时状态更新");
          startStatusUpdates();
        } else if (!isVectorizationRunning && wasRunning) {
          console.log("向量化进程完成，停止实时状态更新");
          stopStatusUpdates();
        }
      }

      // 页面可见性变化时的处理
      document.addEventListener("visibilitychange", () => {
        if (document.hidden) {
          // 页面隐藏时停止更新
          stopStatusUpdates();
        } else {
          // 页面显示时检查状态并可能重启更新
          fetchVectorizationStatusWithUpdates();
        }
      });

      // 页面卸载时清理
      window.addEventListener("beforeunload", () => {
        stopStatusUpdates();
      });

      // 初始检查
      setTimeout(() => {
        if (checkVectorizationStatus()) {
          startStatusUpdates();
        }
      }, 1000);

      // 快速向量化功能
      const quickVectorizeButtons = document.querySelectorAll(
        ".quick-vectorize-btn",
      );
      quickVectorizeButtons.forEach((button) => {
        button.addEventListener("click", async (e: Event) => {
          e.preventDefault();

          const btn = e.currentTarget as HTMLButtonElement;
          const slug = btn.getAttribute("data-slug");
          const title = btn.getAttribute("data-title");

          if (!slug) {
            showToast("无法获取文章信息", "error");
            return;
          }

          try {
            btn.disabled = true;
            btn.innerHTML =
              '<span class="loading loading-spinner loading-xs"></span>';

            await trpcVanilla.vectorization.batchVectorize.mutate({
              slugs: [slug],
            });

            showToast(`已启动文章"${title}"的向量化`, "success");

            // 重新获取向量化状态
            setTimeout(() => {
              fetchVectorizationStatusWithUpdates();
            }, 1000);
          } catch (error) {
            console.error("快速向量化失败:", error);
            showToast("向量化启动失败", "error");
          } finally {
            btn.disabled = false;
            btn.innerHTML = `
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            `;
          }
        });
      });
    });
  </script>
</Layout>

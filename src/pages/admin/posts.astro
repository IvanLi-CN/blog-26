---
import { getCollection } from "astro:content";
import Layout from "~/layouts/PageLayout.astro";
import { forbiddenResponse, isAdminFromCookies } from "~/lib/auth";
import { getNormalizedPost } from "~/utils/blog";

export const prerender = false;

// Check if user is admin
const isUserAdmin =
  process.env.ADMIN_MODE === "true" ||
  (await isAdminFromCookies(Astro.cookies));

if (!isUserAdmin) {
  return forbiddenResponse();
}

// Get all posts including drafts
const allPosts = await Promise.all([
  getCollection("post"),
  getCollection("notes"),
  getCollection("local-notes"),
]).then(([posts, notes, localNotes]) => [...posts, ...notes, ...localNotes]);

const normalizedPosts = await Promise.all(
  allPosts.map(async (post) => await getNormalizedPost(post)),
);

const sortedPosts = normalizedPosts.sort(
  (a, b) => b.publishDate.valueOf() - a.publishDate.valueOf(),
);

const metadata = {
  title: "文章管理 - 管理员面板",
  description: "管理所有文章，包括草稿和已发布的文章",
  robots: {
    index: false,
    follow: false,
  },
};
---

<Layout metadata={metadata}>
  <div class="max-w-7xl mx-auto px-4 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">
        文章管理
      </h1>
      <p class="text-gray-600 dark:text-gray-400">
        管理所有文章，包括草稿和已发布的文章
      </p>
    </div>

    <!-- Statistics -->
    <div class="grid grid-cols-1 md:grid-cols-5 gap-4 mb-8" id="stats-cards">
      <div
        class="bg-white dark:bg-gray-800 rounded-lg p-6 shadow-sm cursor-pointer hover:shadow-md transition-shadow filter-card active"
        data-filter="all"
      >
        <div class="flex items-center">
          <div class="p-2 bg-blue-100 dark:bg-blue-900 rounded-lg">
            <svg
              class="w-6 h-6 text-blue-600 dark:text-blue-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
              ></path>
            </svg>
          </div>
          <div class="ml-4">
            <p class="text-sm font-medium text-gray-600 dark:text-gray-400">
              总文章数
            </p>
            <p class="text-2xl font-semibold text-gray-900 dark:text-white">
              {sortedPosts.length}
            </p>
          </div>
        </div>
      </div>

      <div
        class="bg-white dark:bg-gray-800 rounded-lg p-6 shadow-sm cursor-pointer hover:shadow-md transition-shadow filter-card"
        data-filter="published"
      >
        <div class="flex items-center">
          <div class="p-2 bg-green-100 dark:bg-green-900 rounded-lg">
            <svg
              class="w-6 h-6 text-green-600 dark:text-green-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
          <div class="ml-4">
            <p class="text-sm font-medium text-gray-600 dark:text-gray-400">
              已发布
            </p>
            <p class="text-2xl font-semibold text-gray-900 dark:text-white">
              {sortedPosts.filter((p) => !p.draft && p.public !== false).length}
            </p>
          </div>
        </div>
      </div>

      <div
        class="bg-white dark:bg-gray-800 rounded-lg p-6 shadow-sm cursor-pointer hover:shadow-md transition-shadow filter-card"
        data-filter="draft"
      >
        <div class="flex items-center">
          <div class="p-2 bg-yellow-100 dark:bg-yellow-900 rounded-lg">
            <svg
              class="w-6 h-6 text-yellow-600 dark:text-yellow-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"
              ></path>
            </svg>
          </div>
          <div class="ml-4">
            <p class="text-sm font-medium text-gray-600 dark:text-gray-400">
              草稿
            </p>
            <p class="text-2xl font-semibold text-gray-900 dark:text-white">
              {sortedPosts.filter((p) => p.draft).length}
            </p>
          </div>
        </div>
      </div>

      <div
        class="bg-white dark:bg-gray-800 rounded-lg p-6 shadow-sm cursor-pointer hover:shadow-md transition-shadow filter-card"
        data-filter="private"
      >
        <div class="flex items-center">
          <div class="p-2 bg-orange-100 dark:bg-orange-900 rounded-lg">
            <svg
              class="w-6 h-6 text-orange-600 dark:text-orange-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.878 9.878L3 3m6.878 6.878L21 21"
              ></path>
            </svg>
          </div>
          <div class="ml-4">
            <p class="text-sm font-medium text-gray-600 dark:text-gray-400">
              私有
            </p>
            <p class="text-2xl font-semibold text-gray-900 dark:text-white">
              {sortedPosts.filter((p) => !p.draft && p.public === false).length}
            </p>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 rounded-lg p-6 shadow-sm">
        <div class="flex items-center">
          <div class="p-2 bg-purple-100 dark:bg-purple-900 rounded-lg">
            <svg
              class="w-6 h-6 text-purple-600 dark:text-purple-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"
              ></path>
            </svg>
          </div>
          <div class="ml-4">
            <p class="text-sm font-medium text-gray-600 dark:text-gray-400">
              标签数
            </p>
            <p class="text-2xl font-semibold text-gray-900 dark:text-white">
              {
                new Set(
                  sortedPosts.flatMap((p) => p.tags?.map((t) => t.slug) || []),
                ).size
              }
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Posts Table -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">
          所有文章
        </h2>
      </div>

      <div>
        <table
          class="w-full divide-y divide-gray-200 dark:divide-gray-700 table-fixed"
        >
          <thead class="bg-gray-50 dark:bg-gray-900">
            <tr>
              <th
                class="w-5/12 px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider"
              >
                标题
              </th>
              <th
                class="w-2/12 px-2 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider"
              >
                状态/日期
              </th>
              <th
                class="w-4/12 px-2 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider"
              >
                标签
              </th>
              <th
                class="w-1/12 px-2 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider"
              >
                操作
              </th>
            </tr>
          </thead>
          <tbody
            class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700"
          >
            {
              sortedPosts.map((post) => {
                const postStatus = post.draft
                  ? "draft"
                  : post.public === false
                    ? "private"
                    : "published";
                return (
                  <tr
                    class="hover:bg-gray-50 dark:hover:bg-gray-700 post-row"
                    data-status={postStatus}
                  >
                    <td class="px-4 py-4">
                      <div>
                        <div class="text-sm font-medium text-gray-900 dark:text-white truncate">
                          {post.title}
                        </div>
                        {post.excerpt ? (
                          <div class="text-xs text-gray-500 dark:text-gray-400 truncate">
                            {post.excerpt.substring(0, 60)}...
                          </div>
                        ) : (
                          <div class="text-xs text-gray-400 dark:text-gray-500 italic">
                            无简介
                          </div>
                        )}
                      </div>
                    </td>
                    <td class="px-2 py-4">
                      <div class="flex flex-col gap-1">
                        {post.draft ? (
                          <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200 w-fit">
                            草稿
                          </span>
                        ) : post.public === false ? (
                          <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-orange-100 text-orange-800 dark:bg-orange-900 dark:text-orange-200 w-fit">
                            私有
                          </span>
                        ) : (
                          <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200 w-fit">
                            已发布
                          </span>
                        )}
                        <div class="text-xs text-gray-500 dark:text-gray-400">
                          {post.publishDate.toLocaleDateString("zh-CN", {
                            month: "short",
                            day: "numeric",
                          })}
                        </div>
                      </div>
                    </td>
                    <td class="px-2 py-4">
                      <div class="flex flex-wrap gap-1">
                        {post.tags?.map((tag) => (
                          <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200">
                            {tag.title.split("/").pop() || tag.title}
                          </span>
                        ))}
                      </div>
                    </td>
                    <td class="px-2 py-4 text-xs">
                      <a
                        href={`/${post.permalink}`}
                        class="text-blue-600 hover:text-blue-900 dark:text-blue-400 dark:hover:text-blue-300"
                        target="_blank"
                        title="查看文章"
                      >
                        查看
                      </a>
                    </td>
                  </tr>
                );
              })
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</Layout>

<style>
  @reference "tailwindcss";

  .filter-card.active {
    @apply border-2 border-blue-500 shadow-lg;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const filterCards = document.querySelectorAll(".filter-card");
    const postRows = document.querySelectorAll(".post-row");

    filterCards.forEach((card) => {
      card.addEventListener("click", function () {
        const filter = this.getAttribute("data-filter");

        // 更新活跃状态
        filterCards.forEach((c) => c.classList.remove("active"));
        this.classList.add("active");

        // 筛选文章行
        postRows.forEach((row) => {
          const postStatus = row.getAttribute("data-status");
          const htmlRow = row as HTMLElement;

          if (filter === "all") {
            htmlRow.style.display = "";
          } else if (filter === postStatus) {
            htmlRow.style.display = "";
          } else {
            htmlRow.style.display = "none";
          }
        });

        // 更新表格显示状态
        updateTableVisibility();
      });
    });

    function updateTableVisibility() {
      const visibleRows = Array.from(postRows).filter(
        (row) => (row as HTMLElement).style.display !== "none",
      );
      const tableBody = document.querySelector("tbody");

      if (visibleRows.length === 0) {
        // 如果没有可见行，显示空状态消息
        if (!document.querySelector(".empty-state")) {
          const emptyRow = document.createElement("tr");
          emptyRow.className = "empty-state";
          emptyRow.innerHTML = `
            <td colspan="5" class="px-6 py-12 text-center text-gray-500 dark:text-gray-400">
              <div class="flex flex-col items-center">
                <svg class="w-12 h-12 mb-4 text-gray-300 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
                <p class="text-lg font-medium">没有找到匹配的文章</p>
                <p class="text-sm">尝试选择其他筛选条件</p>
              </div>
            </td>
          `;
          tableBody?.appendChild(emptyRow);
        }
      } else {
        // 移除空状态消息
        const emptyState = document.querySelector(".empty-state");
        if (emptyState) {
          emptyState.remove();
        }
      }
    }
  });
</script>

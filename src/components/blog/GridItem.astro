---
import { APP_BLOG } from "astrowind:config";
import Image from "~/components/common/Image.astro";
import type { Post } from "~/types";

import { getPermalink } from "~/utils/permalinks";

export interface Props {
  post: Post;
}

const { post } = Astro.props;
// 直接使用 post.image，不通过 findImage 处理
const image = post.image;

const link = APP_BLOG?.post?.isEnabled
  ? getPermalink(post.permalink, "post")
  : "";
---

<article
  class="mb-6 transition-all duration-300 hover:shadow-lg hover:-translate-y-2 rounded-lg p-4 hover:bg-base-100/50 group"
>
  <div
    class="relative md:h-64 rounded shadow-lg mb-6 overflow-hidden transition-all duration-300 group-hover:shadow-xl"
  >
    {
      image &&
        (link ? (
          <a href={link}>
            <Image
              src={image}
              class="w-full md:h-full rounded object-cover shadow-lg bg-gray-400 dark:bg-slate-700 transition-transform duration-300 group-hover:scale-110 max-h-64 md:max-h-72 lg:max-h-80"
              widths={[400, 900]}
              width={400}
              sizes="(max-width: 900px) 400px, 900px"
              alt={post.title}
              aspectRatio="16:9"
              layout="cover"
              loading="lazy"
              decoding="async"
              displayWidth={400}
              displayHeight={225}
              dataSource={post.dataSource}
            />
          </a>
        ) : (
          <Image
            src={image}
            class="w-full md:h-full rounded object-cover shadow-lg bg-gray-400 dark:bg-slate-700 transition-transform duration-300 group-hover:scale-110 max-h-64 md:max-h-72 lg:max-h-80"
            widths={[400, 900]}
            width={400}
            sizes="(max-width: 900px) 400px, 900px"
            alt={post.title}
            aspectRatio="16:9"
            layout="cover"
            loading="lazy"
            decoding="async"
            displayWidth={400}
            displayHeight={225}
            dataSource={post.dataSource}
          />
        ))
    }
  </div>

  <h3 class="text-xl sm:text-2xl font-bold leading-tight mb-2 font-heading">
    {
      link ? (
        <a
          class="inline-block hover:text-primary transition-all duration-300 group-hover:translate-x-1"
          href={link}
        >
          {post.title}
        </a>
      ) : (
        post.title
      )
    }
  </h3>

  <p class="text-opacity-80 text-lg font-light">{post.excerpt}</p>
</article>

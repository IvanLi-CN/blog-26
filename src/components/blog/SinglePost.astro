---
import { Icon } from "astro-icon/components";
import ArticleLicense from "~/components/blog/ArticleLicense.astro";
import PostReactions from "~/components/blog/PostReactions";
import PostTags from "~/components/blog/Tags.astro";
import CommentSectionWithProvider from "~/components/comments/CommentSectionWithProvider";
import Image from "~/components/common/Image.astro";
import PostStatus from "~/components/common/PostStatus.astro";
import SocialShare from "~/components/common/SocialShare.astro";

import type { Post } from "~/types";
import { getPermalink } from "~/utils/permalinks";
import { getFormattedDate } from "~/utils/utils";

export interface Props {
  post: Post;
  url: string | URL;
}

const { post, url } = Astro.props;

// 从 Astro.locals 获取管理员状态
const isUserAdmin = Astro.locals.isAdmin || false;
---

<section class="py-8 sm:py-16 lg:py-20 mx-auto">
  <article>
    <header class={post.image ? "" : ""}>
      <div
        class="flex justify-between flex-col sm:flex-row max-w-3xl mx-auto mt-0 mb-2 px-4 sm:px-6 sm:items-center"
      >
        <p>
          <Icon
            name="tabler:clock"
            class="w-4 h-4 inline-block -mt-0.5 dark:text-gray-400"
          />
          <time datetime={String(post.publishDate)} class="inline-block"
            >{getFormattedDate(post.publishDate)}</time
          >
          {
            post.author && (
              <>
                {" "}
                ·{" "}
                <Icon
                  name="tabler:user"
                  class="w-4 h-4 inline-block -mt-0.5 dark:text-gray-400"
                />
                <span class="inline-block">{post.author}</span>
              </>
            )
          }
          {
            post.category && (
              <>
                {" "}
                ·{" "}
                <a
                  class="hover:underline inline-block"
                  href={getPermalink(post.category.slug, "category")}
                >
                  {post.category.title}
                </a>
              </>
            )
          }
          {
            post.readingTime && (
              <>
                &nbsp;· <span>{post.readingTime}</span> min read
              </>
            )
          }
        </p>

        <!-- 向量化状态（仅显示已正确向量化的内容） -->
        {post.vectorizationStatus === 'correct' && (
          <div class="vectorization-status-container">
            <div
              class="vectorization-status opacity-70 hover:opacity-100 transition-opacity"
              title="内容已成功向量化，可用于智能搜索"
            >
              <!-- 正确向量化图标 -->
              <Icon
                name="mingcute:ai-line"
                class="w-4 h-4 text-base-content/60"
              />
            </div>
          </div>
        )}
      </div>

      <div class="px-4 sm:px-6 max-w-3xl mx-auto">
        <div class="flex items-start justify-between gap-4 mb-4">
          <h1
            class="text-4xl md:text-5xl font-bold leading-tighter tracking-tighter font-heading flex-grow"
          >
            {post.title}
          </h1>
          <PostStatus post={post} size="md" className="flex-shrink-0 mt-2" />
        </div>
      </div>

      {
        isUserAdmin && (
          <div class="max-w-3xl mx-auto mt-4 px-4 sm:px-6">
            <div class="bg-blue-50 dark:bg-blue-900/20 border-l-4 border-blue-500 p-4 mb-6 rounded-r-lg">
              <div class="flex items-center gap-3">
                <Icon
                  name="tabler:shield-check"
                  class="w-5 h-5 text-blue-600 dark:text-blue-400"
                />
                <span class="text-sm font-semibold text-blue-800 dark:text-blue-200">
                  管理员视图
                </span>
                <div class="ml-auto">
                  {post.draft ? (
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200 border border-yellow-300 dark:border-yellow-700">
                      草稿
                    </span>
                  ) : post.public === false ? (
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-orange-100 text-orange-800 dark:bg-orange-900 dark:text-orange-200 border border-orange-300 dark:border-orange-700">
                      私有
                    </span>
                  ) : (
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200 border border-green-300 dark:border-green-700">
                      已发布
                    </span>
                  )}
                </div>
              </div>
            </div>
          </div>
        )
      }

      <p
        class="max-w-3xl mx-auto mt-4 mb-8 px-4 sm:px-6 text-md font-serif font-light text-justify"
      >
        {post.excerpt}
      </p>

      {
        post.image ? (
          <Image
            src={post.image}
            class="max-w-full lg:max-w-[900px] mx-auto mb-6 sm:rounded-md bg-gray-400 dark:bg-slate-700"
            widths={[400, 900]}
            sizes="(max-width: 900px) 400px, 900px"
            alt={post?.excerpt || ""}
            width={900}
            height={506}
            loading="eager"
            decoding="async"
            displayWidth={900}
            displayHeight={506}
            dataSource={post.dataSource}
          />
        ) : (
          <div class="max-w-3xl mx-auto px-4 sm:px-6">
            <div class="border-t dark:border-slate-700" />
          </div>
        )
      }
    </header>
    <div
      class="mx-auto px-6 sm:px-6 max-w-3xl prose prose-md xl:text-lg dark:prose-invert dark:prose-headings:text-slate-300 prose-headings:font-heading prose-headings:leading-tighter prose-headings:tracking-tighter prose-headings:font-bold prose-a:text-primary dark:prose-a:text-blue-400 prose-img:rounded-md prose-img:shadow-lg mt-8 prose-headings:scroll-mt-[80px] prose-li:my-0"
    >
      <slot />
    </div>
    <div class="mx-auto px-6 sm:px-6 max-w-3xl mt-8">
      <!-- 许可证信息 -->
      <ArticleLicense
        author={post.author || "Ivan Li"}
        year={new Date(post.publishDate).getFullYear()}
      />

      <!-- 标签单独一行 -->
      <div class="mb-4 mt-6">
        <PostTags tags={post.tags} class="flex gap-1 flex-wrap" />
      </div>
      <!-- 表态和分享在同一行，两端对齐 -->
      <div class="flex justify-between items-center">
        <div class="flex items-center">
          <PostReactions postSlug={post.slug} client:load />
        </div>
        <div class="flex items-center">
          <SocialShare
            url={url}
            text={post.title}
            class="text-gray-500 dark:text-slate-600"
          />
        </div>
      </div>
    </div>
  </article>
  <div class="max-w-3xl mx-auto px-4 sm:px-6">
    <CommentSectionWithProvider postSlug={post.slug} client:idle />
  </div>
</section>



---
import type { HTMLAttributes } from "astro/types";
import { isSupportedImageFormat } from "~/lib/image-optimizer";
import { findImage } from "~/utils/images";
import {
  astroAsseetsOptimizer,
  getImagesOptimized,
  type ImageProps,
  isUnpicCompatible,
  unpicOptimizer,
} from "~/utils/images-optimization";

type Props = ImageProps & {
  displayWidth?: number;
  displayHeight?: number;
  dataSource?: "local" | "webdav" | "database" | string;
};
type ImageType = {
  src: string;
  attributes: HTMLAttributes<"img">;
};

const props = Astro.props;

if (props.alt === undefined || props.alt === null) {
  throw new Error();
}

if (typeof props.width === "string") {
  props.width = parseInt(props.width);
}

if (typeof props.height === "string") {
  props.height = parseInt(props.height);
}

if (!props.loading) {
  props.loading = "lazy";
}

if (!props.decoding) {
  props.decoding = "async";
}

// 强制使用统一文件服务以确保水印功能
let processedImage: string | ImageMetadata | undefined | null;

// 如果有数据源标识，优先使用统一文件服务
if (props.dataSource && typeof props.src === "string") {
  if (props.src.startsWith("./assets/")) {
    // 将相对路径转换为统一的files路径格式：/files/<source>/<path>
    const relativePath = props.src.replace("./", "");
    processedImage = `/files/${props.dataSource}/${relativePath}`;
  } else if (props.src.startsWith("~/assets/images/")) {
    // 将 ~/assets/images/ 路径转换为统一文件服务路径
    const relativePath = props.src.replace("~/assets/images/", "assets/");
    processedImage = `/files/${props.dataSource}/${relativePath}`;
  } else {
    processedImage = props.src;
  }
} else {
  // 没有数据源标识时，使用原有的 findImage 逻辑
  try {
    processedImage = await findImage(props.src);
  } catch (error) {
    console.warn(`Image not found: ${props.src}`, error);
    processedImage = null;
  }
}

let image: ImageType | undefined = undefined;
let shouldRender = true;

// 如果图片为 null 或 undefined，不渲染任何内容
if (!processedImage) {
  shouldRender = false;
}

if (shouldRender && typeof processedImage === "string") {
  // 检查是否使用统一的files服务
  const shouldUseFilesService = (() => {
    // 如果已经是/files/路径，直接使用
    if (processedImage.startsWith("/files/")) {
      return true;
    }

    // 绝对URL直接返回false，不需要特殊处理
    if (
      processedImage.startsWith("http://") ||
      processedImage.startsWith("https://")
    ) {
      return false;
    }

    // ~/assets/ 路径始终使用本地assets处理
    if (processedImage.startsWith("~/assets/")) {
      return false;
    }

    // /images/ 等public目录路径使用本地处理
    if (
      processedImage.startsWith("/images/") ||
      processedImage.startsWith("/favicon") ||
      processedImage.startsWith("/robots") ||
      processedImage.startsWith("/sitemap")
    ) {
      return false;
    }

    // 对于相对路径，如果有数据源标识，使用files服务
    if (
      processedImage.startsWith("./") ||
      (!processedImage.startsWith("/") && !processedImage.startsWith("~/"))
    ) {
      return props.dataSource !== undefined;
    }

    return false;
  })();

  if (shouldUseFilesService && isSupportedImageFormat(processedImage)) {
    // 构建统一的files服务URL
    let filesPath = processedImage;

    // 如果不是/files/路径，需要构建
    if (!processedImage.startsWith("/files/")) {
      if (processedImage.startsWith("./")) {
        const relativePath = processedImage.substring(2);
        filesPath = `/files/${props.dataSource}/${relativePath}`;
      } else {
        filesPath = `/files/${props.dataSource}/${processedImage}`;
      }
    }

    // 构建优化 URL
    const params = new URLSearchParams();
    // 使用单一尺寸参数，取宽度和高度中的较大值
    const size = Math.max(
      typeof props.width === "number"
        ? props.width
        : parseInt(props.width || "0"),
      typeof props.height === "number"
        ? props.height
        : parseInt(props.height || "0"),
    );
    // 如果没有指定尺寸，使用默认值1200
    params.set("s", (size > 0 ? size : 1200).toString());
    params.set("q", "85");
    params.set("f", "webp");
    params.set("dpr", "1"); // 默认1x像素倍率

    const optimizedSrc = `${filesPath}?${params.toString()}`;

    // 生成响应式 srcset
    const breakpoints = [320, 480, 640, 768, 1024, 1280, 1536, 1920];
    const widthNum =
      typeof props.width === "number"
        ? props.width
        : typeof props.width === "string"
          ? parseInt(props.width)
          : undefined;
    const validBreakpoints = widthNum
      ? breakpoints.filter((bp) => bp <= widthNum)
      : breakpoints;

    const srcsetEntries = validBreakpoints.map((bp) => {
      const bpParams = new URLSearchParams();
      bpParams.set("s", bp.toString());
      bpParams.set("q", "85");
      bpParams.set("f", "webp");
      bpParams.set("dpr", "1");
      return `${filesPath}?${bpParams.toString()} ${bp}w`;
    });

    image = {
      src: optimizedSrc,
      attributes: {
        ...props,
        src: undefined,
        srcset: srcsetEntries.join(", "),
        sizes:
          props.sizes ||
          "(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw",
      },
    };
  } else if (
    (processedImage.startsWith("http://") ||
      processedImage.startsWith("https://")) &&
    isUnpicCompatible(processedImage)
  ) {
    image = await getImagesOptimized(processedImage, props, unpicOptimizer);
  } else {
    image = {
      src: processedImage,
      attributes: { ...props, src: undefined },
    };
  }
} else if (processedImage) {
  image = await getImagesOptimized(
    processedImage,
    props,
    astroAsseetsOptimizer,
  );
}
---

{
  !shouldRender || !image ? (
    <Fragment />
  ) : (
    <img src={image.src} referrerpolicy="no-referrer" {...image.attributes} />
  )
}

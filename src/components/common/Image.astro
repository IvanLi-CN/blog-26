---
import type { HTMLAttributes } from "astro/types";
import { isSupportedImageFormat } from "~/lib/image-optimizer";
import { findImage } from "~/utils/images";
import {
  astroAsseetsOptimizer,
  getImagesOptimized,
  type ImageProps,
  isUnpicCompatible,
  unpicOptimizer,
} from "~/utils/images-optimization";

type Props = ImageProps & {
  displayWidth?: number;
  displayHeight?: number;
};
type ImageType = {
  src: string;
  attributes: HTMLAttributes<"img">;
};

const props = Astro.props;

if (props.alt === undefined || props.alt === null) {
  throw new Error();
}

if (typeof props.width === "string") {
  props.width = parseInt(props.width);
}

if (typeof props.height === "string") {
  props.height = parseInt(props.height);
}

if (!props.loading) {
  props.loading = "lazy";
}

if (!props.decoding) {
  props.decoding = "async";
}

const _image = await findImage(props.src);

let image: ImageType | undefined = undefined;

if (typeof _image === "string") {
  // 检查是否为 WebDAV 图片（相对路径或 /files/ 路径）
  const isWebDAVImage =
    !_image.startsWith("http://") &&
    !_image.startsWith("https://") &&
    !_image.startsWith("~/assets/");

  if (isWebDAVImage && isSupportedImageFormat(_image)) {
    // 使用我们的优化端点处理 WebDAV 图片
    let imagePath = _image;
    if (_image.startsWith("./")) {
      imagePath = _image.substring(2);
    } else if (_image.startsWith("/files/")) {
      imagePath = _image.substring(7);
    } else if (_image.startsWith("/")) {
      imagePath = _image.substring(1);
    }

    // 构建优化 URL
    const params = new URLSearchParams();
    // 使用单一尺寸参数，取宽度和高度中的较大值
    const size = Math.max(
      typeof props.width === "number" ? props.width : parseInt(props.width || "0"),
      typeof props.height === "number" ? props.height : parseInt(props.height || "0")
    );
    // 如果没有指定尺寸，使用默认值1200
    params.set("s", (size > 0 ? size : 1200).toString());
    params.set("q", "85");
    params.set("f", "webp");
    params.set("dpr", "1"); // 默认1x像素倍率

    const optimizedSrc = `/api/render-image/${imagePath}?${params.toString()}`;

    // 生成响应式 srcset
    const breakpoints = [320, 480, 640, 768, 1024, 1280, 1536, 1920];
    const widthNum =
      typeof props.width === "number"
        ? props.width
        : typeof props.width === "string"
          ? parseInt(props.width)
          : undefined;
    const validBreakpoints = widthNum
      ? breakpoints.filter((bp) => bp <= widthNum)
      : breakpoints;

    const srcsetEntries = validBreakpoints.map((bp) => {
      const bpParams = new URLSearchParams();
      bpParams.set("s", bp.toString());
      bpParams.set("q", "85");
      bpParams.set("f", "webp");
      bpParams.set("dpr", "1");
      return `/api/render-image/${imagePath}?${bpParams.toString()} ${bp}w`;
    });

    image = {
      src: optimizedSrc,
      attributes: {
        ...props,
        src: undefined,
        srcset: srcsetEntries.join(", "),
        sizes:
          props.sizes ||
          "(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw",
      },
    };
  } else if (
    (_image.startsWith("http://") || _image.startsWith("https://")) &&
    isUnpicCompatible(_image)
  ) {
    image = await getImagesOptimized(_image, props, unpicOptimizer);
  } else {
    image = {
      src: _image,
      attributes: { ...props, src: undefined },
    };
  }
} else if (_image) {
  image = await getImagesOptimized(_image, props, astroAsseetsOptimizer);
}
---

{
  !image ? (
    <Fragment />
  ) : (
    <img src={image.src} referrerpolicy="no-referrer" {...image.attributes} />
  )
}

---
import { UI } from "astrowind:config";

const { theme: defaultTheme = "system" } = UI;

const darkThemes = [
  "dark",
  "synthwave",
  "halloween",
  "forest",
  "black",
  "luxury",
  "dracula",
  "night",
  "coffee",
  "dim",
  "sunset",
  "abyss",
];
---

<script
  is:inline
  define:vars={{ defaultTheme, darkThemes }}
>
  function applyTheme(theme, defaultTheme, darkThemes) {
    const d = document.documentElement;
    let currentTheme = theme;

    if (theme === "system") {
      currentTheme = window.matchMedia("(prefers-color-scheme: dark)").matches
        ? "dark"
        : "light";
    }
    d.dataset.theme = currentTheme;

    const isDark = darkThemes.includes(currentTheme);

    document.querySelectorAll(".theme-controller").forEach((controller) => {
      controller.checked = isDark;
    });
  }

  function attachThemeToggleListeners(defaultTheme, darkThemes) {
    document.querySelectorAll('[id^="theme-toggle-"]').forEach((container) => {
      container
        .querySelectorAll("[data-set-theme]")
        .forEach((link) => {
          if (link.dataset.listenerAttached) return;
          link.dataset.listenerAttached = "true";
          link.addEventListener("click", (event) => {
            event.preventDefault();
            const newTheme = link.getAttribute("data-set-theme");
            localStorage.setItem("theme", newTheme);
            applyTheme(newTheme, defaultTheme, darkThemes);
            document.activeElement?.blur();
          });
        });

      const swap = container.querySelector(".swap");
      const checkbox = container.querySelector("input.theme-controller");
      if (swap && checkbox) {
        if (swap.dataset.listenerAttached) return;
        swap.dataset.listenerAttached = "true";
        swap.addEventListener("click", (event) => {
          if (event.target.closest(".dropdown-content")) return;
          const newTheme = checkbox.checked ? "dark" : "light";
          localStorage.setItem("theme", newTheme);
          applyTheme(newTheme, defaultTheme, darkThemes);
        });
      }
    });
  }

  // Apply theme immediately to prevent FOUC
  const theme = localStorage.getItem("theme") || defaultTheme;
  applyTheme(theme, defaultTheme, darkThemes);

  // Attach listeners on initial page load
  document.addEventListener('DOMContentLoaded', () => {
    attachThemeToggleListeners(defaultTheme, darkThemes);
  });
  
  // Re-apply and re-attach on page transitions
  document.addEventListener("astro:after-swap", () => {
    const theme = localStorage.getItem("theme") || defaultTheme;
    applyTheme(theme, defaultTheme, darkThemes);
    attachThemeToggleListeners(defaultTheme, darkThemes);
  });
</script>

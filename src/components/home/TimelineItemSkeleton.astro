---
import { Icon } from "astro-icon/components";

interface Props {
  isLast?: boolean;
}

const { isLast = false } = Astro.props;
---

<div class="timeline-item relative flex items-start gap-4 pb-8">
  <!-- 时间线主轴和节点 -->
  <div class="flex flex-col items-center relative">
    <!-- 时间线节点（加载状态） -->
    <div class="flex items-center justify-center w-10 h-10 rounded-full bg-base-200 border-2 border-base-300 flex-shrink-0 z-10 relative animate-pulse">
      <div class="w-5 h-5 bg-base-300 rounded-full"></div>
    </div>
    
    <!-- 时间线主轴（连接线） -->
    {!isLast && (
      <div class="w-0.5 h-32 bg-base-300 opacity-30 absolute top-10 left-1/2 transform -translate-x-1/2"></div>
    )}
  </div>

  <!-- 内容区域（加载状态） -->
  <div class="flex-1 min-w-0">
    <!-- 时间和类型信息（加载状态） -->
    <div class="flex items-center gap-2 mb-2">
      <div class="h-4 bg-base-300 rounded w-20 animate-pulse"></div>
      <div class="h-5 bg-base-300 rounded w-12 animate-pulse"></div>
    </div>

    <!-- 内容卡片（加载状态） -->
    <div class="card bg-base-100 shadow-sm border border-base-200">
      <div class="card-body p-4">
        <!-- 骨架屏占位内容 -->
        <div class="h-20 bg-base-200 rounded mb-2 animate-pulse"></div>
        <div class="h-3 bg-base-300 rounded w-3/4 mb-1 animate-pulse"></div>
        <div class="h-3 bg-base-300 rounded w-1/2 animate-pulse"></div>
      </div>
    </div>
  </div>
</div>

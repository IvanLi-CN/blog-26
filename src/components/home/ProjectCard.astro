---
interface Props {
  project: any;
}

const { project } = Astro.props;
---

<div class="card bg-base-100 shadow-sm hover:shadow-md transition-all duration-200 hover:-translate-y-0.5">
  <div class="card-body p-3">
    <h3 class="card-title text-sm mb-1 line-clamp-1">
      <a href={`/${project.slug}`} class="hover:text-primary transition-colors">
        {project.title}
      </a>
    </h3>

    {project.tags && project.tags.length > 0 && (
      <span class="badge badge-outline badge-xs">
        {typeof project.tags[0] === 'string' ? project.tags[0] : project.tags[0].title}
      </span>
    )}
  </div>
</div>

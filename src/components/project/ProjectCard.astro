---
import { Icon } from "astro-icon/components";
import type { Post } from "~/types";
import { findImage } from "~/utils/images";
import { getPermalink } from "~/utils/permalinks";

export interface Props {
  project: Post;
}

const { project } = Astro.props;

const image = await findImage(project.image);
const imageUrl = typeof image === 'string' ? image : image?.src;
const link = getPermalink(project.permalink, "post");
---

<div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow duration-300 h-full flex flex-col">
  {imageUrl && (
    <figure class="aspect-video overflow-hidden">
      <img
        src={imageUrl}
        alt={project.title}
        class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
      />
    </figure>
  )}

  <div class="card-body flex-grow flex flex-col">
    <h2 class="card-title text-lg">
      {project.title}
    </h2>
    
    {project.excerpt && (
      <p class="text-sm text-base-content/70 line-clamp-3 flex-grow">
        {project.excerpt}
      </p>
    )}

    <div class="card-actions justify-between items-center mt-auto pt-4">
      <div class="flex flex-wrap gap-1">
        {project.tags?.slice(0, 2).map((tag) => (
          <div class="badge badge-outline badge-sm">
            {(typeof tag === 'string' ? tag : tag.title).split('/').pop()}
          </div>
        ))}
      </div>
      
      <a href={link} class="btn btn-primary btn-sm">
        查看详情
        <Icon name="tabler:arrow-right" class="w-4 h-4" />
      </a>
    </div>
  </div>
</div>

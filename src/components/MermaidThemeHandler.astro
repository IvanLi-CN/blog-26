---
// Mermaid 主题切换处理组件
---

<script>
  // 暗色主题列表
  const darkThemes = [
    'dark', 'night', 'synthwave', 'halloween', 'forest', 'black',
    'luxury', 'dracula', 'coffee', 'dim', 'sunset', 'abyss'
  ];

  // 存储所有 Mermaid 图表的原始状态
  const mermaidElements = new Map();

  function initializeMermaidElements() {
    // 查找所有包含 Mermaid 图表的 picture 元素
    const pictures = document.querySelectorAll('picture');

    pictures.forEach((picture, index) => {
      const darkSource = picture.querySelector('source[media*="prefers-color-scheme: dark"]');
      const lightImg = picture.querySelector('img');

      // 检查是否是 Mermaid 图表（通过检查是否有暗色主题的 source）
      if (darkSource && lightImg) {
        const elementId = `mermaid-${index}`;

        // 保存原始状态
        mermaidElements.set(elementId, {
          originalPicture: picture.cloneNode(true),
          currentElement: picture,
          darkSrc: darkSource.getAttribute('srcset'),
          lightAlt: lightImg.alt || '',
          lightWidth: lightImg.width,
          lightHeight: lightImg.height,
          parentNode: picture.parentNode
        });

        // 给元素添加标识
        picture.setAttribute('data-mermaid-id', elementId);
      }
    });


  }

  function updateMermaidTheme() {
    const currentTheme = document.documentElement.getAttribute('data-theme') || 'light';
    const isDarkTheme = darkThemes.includes(currentTheme);



    mermaidElements.forEach((data, elementId) => {
      const currentElement = document.querySelector(`[data-mermaid-id="${elementId}"]`) ||
                           document.querySelector(`img[data-mermaid-id="${elementId}"]`);

      if (!currentElement) {
        return;
      }

      if (isDarkTheme) {
        // 切换到暗色主题
        if (currentElement.tagName === 'PICTURE') {
          // 创建暗色 img 元素
          const darkImg = document.createElement('img');
          darkImg.src = data.darkSrc;
          darkImg.alt = data.lightAlt;
          darkImg.width = data.lightWidth;
          darkImg.height = data.lightHeight;
          darkImg.style.maxWidth = '100%';
          darkImg.style.height = 'auto';
          darkImg.setAttribute('data-mermaid-id', elementId);

          // 替换元素
          data.parentNode.replaceChild(darkImg, currentElement);
          data.currentElement = darkImg;
        }
      } else {
        // 切换到亮色主题
        if (currentElement.tagName === 'IMG') {
          // 恢复原始 picture 元素
          const newPicture = data.originalPicture.cloneNode(true);
          newPicture.setAttribute('data-mermaid-id', elementId);

          // 替换元素
          data.parentNode.replaceChild(newPicture, currentElement);
          data.currentElement = newPicture;
        }
      }
    });
  }

  // 页面加载时初始化
  document.addEventListener('DOMContentLoaded', () => {
    initializeMermaidElements();
    updateMermaidTheme();
  });

  // 监听主题变化
  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      if (mutation.type === 'attributes' && mutation.attributeName === 'data-theme') {
        updateMermaidTheme();
      }
    });
  });

  // 开始观察 html 元素的 data-theme 属性变化
  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['data-theme']
  });
</script>

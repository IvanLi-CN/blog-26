---
import "@fontsource-variable/inter";
import "highlight.js/styles/github.css";
import "../styles/milkdown.css";

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: "Inter Variable";
    --aw-font-serif: "Inter Variable";
    --aw-font-heading: "Inter Variable";

    --aw-color-primary: rgb(1 97 239);
    --aw-color-secondary: rgb(1 84 207);
    --aw-color-accent: rgb(109 40 217);

    --aw-color-text-heading: rgb(0 0 0);
    --aw-color-text-default: rgb(16 16 16);
    --aw-color-text-muted: rgb(16 16 16 / 66%);
    --aw-color-bg-page: rgb(255 255 255);

    --aw-color-bg-page-dark: rgb(3 6 32);

    ::selection {
      background-color: lavender;
    }
  }

  .dark {
    --aw-font-sans: "Inter Variable";
    --aw-font-serif: "Inter Variable";
    --aw-font-heading: "Inter Variable";

    --aw-color-primary: rgb(1 97 239);
    --aw-color-secondary: rgb(1 84 207);
    --aw-color-accent: rgb(109 40 217);

    --aw-color-text-heading: rgb(247, 248, 248);
    --aw-color-text-default: rgb(229 236 246);
    --aw-color-text-muted: rgb(229 236 246 / 66%);
    --aw-color-bg-page: rgb(3 6 32);

    ::selection {
      background-color: black;
      color: snow;
    }
  }

  /* 代码块样式 - 强制移除所有边框和阴影，包括 prose 类的样式 */
  pre,
  pre code,
  .hljs,
  pre.hljs,
  code[class*="language-"],
  pre[class*="language-"],
  .highlight,
  .highlight pre,
  .highlight code,
  .prose pre,
  .prose pre code,
  .prose .hljs,
  .prose code[class*="language-"],
  .prose pre[class*="language-"] {
    border: none !important;
    border-radius: 6px !important;
    box-shadow: none !important;
    outline: none !important;
    margin: 1rem 0 !important;
    padding: 1rem !important;
    background: #f6f8fa !important;
  }

  /* 深色主题下的代码块样式 - 使用更高优先级，包括 prose 类 */
  .dark pre,
  .dark pre code,
  .dark .hljs,
  .dark pre.hljs,
  .dark .prose pre,
  .dark .prose pre code,
  .dark .prose .hljs,
  .dark .prose code[class*="language-"],
  .dark .prose pre[class*="language-"] {
    background: #161b22 !important;
    color: #e6edf3 !important;
    border: none !important;
    box-shadow: none !important;
    outline: none !important;
  }

  /* 行内代码在深色主题下的样式 */
  .dark :not(pre) > code {
    background: rgba(110, 118, 129, 0.4) !important;
    color: #e6edf3 !important;
    padding: 0.2em 0.4em !important;
    border-radius: 3px !important;
  }

  /* 深色主题下的语法高亮 */
  .dark .hljs-keyword,
  .dark .hljs-selector-tag,
  .dark .hljs-literal,
  .dark .hljs-section,
  .dark .hljs-link {
    color: #ff7b72 !important;
  }

  .dark .hljs-string,
  .dark .hljs-title,
  .dark .hljs-name,
  .dark .hljs-type,
  .dark .hljs-attribute,
  .dark .hljs-symbol,
  .dark .hljs-bullet,
  .dark .hljs-addition,
  .dark .hljs-variable,
  .dark .hljs-template-tag,
  .dark .hljs-template-variable {
    color: #a5d6ff !important;
  }

  .dark .hljs-comment,
  .dark .hljs-quote,
  .dark .hljs-deletion,
  .dark .hljs-meta {
    color: #8b949e !important;
  }

  .dark .hljs-number,
  .dark .hljs-regexp {
    color: #79c0ff !important;
  }

  .dark .hljs-function,
  .dark .hljs-class,
  .dark .hljs-title.class_ {
    color: #d2a8ff !important;
  }

  .dark .hljs-built_in,
  .dark .hljs-doctag {
    color: #ffa657 !important;
  }

  /* 强制覆盖所有可能的代码块背景 */
  .dark pre[class*="language-"],
  .dark code[class*="language-"],
  .dark .hljs-*,
  .dark [class*="hljs"] {
    background: #161b22 !important;
  }

  /* 特别针对 prose 类的代码块样式覆盖 */
  .prose pre {
    background-color: #f6f8fa !important;
    border: none !important;
    border-radius: 6px !important;
    box-shadow: none !important;
  }

  .dark .prose pre {
    background-color: #161b22 !important;
    border: none !important;
    border-radius: 6px !important;
    box-shadow: none !important;
  }

  /* 确保行内代码也没有边框 */
  .prose code {
    border: none !important;
    box-shadow: none !important;
  }

  .dark .prose code {
    border: none !important;
    box-shadow: none !important;
  }

  /* 确保 markdown 预览组件中的代码块样式 */
  .markdown-preview pre,
  .markdown-preview .hljs,
  .markdown-preview code {
    border: none !important;
    box-shadow: none !important;
    outline: none !important;
  }

  .dark .markdown-preview pre,
  .dark .markdown-preview .hljs,
  .dark .markdown-preview code {
    background: #161b22 !important;
    color: #e6edf3 !important;
    border: none !important;
    box-shadow: none !important;
    outline: none !important;
  }

  /* 自定义行内代码样式 */

  .inline-code {
    background: rgba(175, 184, 193, 0.2);
    color: #24292f;
    padding: 0.2em 0.4em;
    border-radius: 3px;
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Consolas,
      "Liberation Mono", Menlo, monospace;
    font-size: 0.875em;
  }

  .dark .inline-code {
    background: rgba(110, 118, 129, 0.4) !important;
    color: #e6edf3 !important;
  }

  /* 表格样式 */
  .markdown-table {
    min-width: 100%;
    border-collapse: collapse;
    border: 1px solid #d1d5db;
    background: #ffffff;
  }

  .dark .markdown-table {
    border-color: #4b5563 !important;
    background: #1f2937 !important;
  }

  .markdown-table-head {
    background: #f9fafb;
  }

  .dark .markdown-table-head {
    background: #374151 !important;
  }

  .markdown-table-body {
    background: #ffffff;
  }

  .dark .markdown-table-body {
    background: #1f2937 !important;
  }

  .markdown-table-row {
    border-bottom: 1px solid #d1d5db;
  }

  .dark .markdown-table-row {
    border-bottom-color: #4b5563 !important;
  }

  .markdown-table-header {
    border: 1px solid #d1d5db;
    padding: 0.75rem 1rem;
    text-align: left;
    font-weight: 600;
    color: #111827;
  }

  .dark .markdown-table-header {
    border-color: #4b5563 !important;
    color: #f9fafb !important;
  }

  .markdown-table-cell {
    border: 1px solid #d1d5db;
    padding: 0.75rem 1rem;
    color: #374151;
  }

  .dark .markdown-table-cell {
    border-color: #4b5563 !important;
    color: #d1d5db !important;
  }

  /* ===== 响应式图片尺寸控制系统 ===== */

  /* 基础样式：闪念和文章内容中的图片 */
  .prose img.content-image,
  .prose img[data-lightbox="true"],
  img.content-image,
  /* 闪念页面中的图片 */
  img.max-w-full,
  img[alt*="图片"],
  img[alt*="测试"],
  img[src*="picsum"] {
    max-width: 100% !important;
    height: auto !important;
    object-fit: contain !important;
    /* 默认移动端最大高度 */
    max-height: 40vmin !important;
    /* 图片居中显示 */
    display: block !important;
    margin-left: auto !important;
    margin-right: auto !important;
  }

  /* 小屏幕 (640px - 767px): 35vmin */
  @media (min-width: 640px) and (max-width: 767px) {
    .prose img.content-image,
    .prose img[data-lightbox="true"],
    img.content-image,
    img.max-w-full,
    img[alt*="图片"],
    img[alt*="测试"],
    img[src*="picsum"] {
      max-height: 35vmin !important;
    }
  }

  /* 平板端 (768px - 1023px): 30vmin */
  @media (min-width: 768px) and (max-width: 1023px) {
    .prose img.content-image,
    .prose img[data-lightbox="true"],
    img.content-image,
    img.max-w-full,
    img[alt*="图片"],
    img[alt*="测试"],
    img[src*="picsum"] {
      max-height: 30vmin !important;
    }
  }

  /* 大屏幕 (1024px - 1279px): 25vmin */
  @media (min-width: 1024px) and (max-width: 1279px) {
    .prose img.content-image,
    .prose img[data-lightbox="true"],
    img.content-image,
    img.max-w-full,
    img[alt*="图片"],
    img[alt*="测试"],
    img[src*="picsum"] {
      max-height: 25vmin !important;
    }
  }

  /* 超大屏幕 (≥1280px): 20vmin */
  @media (min-width: 1280px) {
    .prose img.content-image,
    .prose img[data-lightbox="true"],
    img.content-image,
    img.max-w-full,
    img[alt*="图片"],
    img[alt*="测试"],
    img[src*="picsum"] {
      max-height: 20vmin !important;
    }
  }

  /* ===== 长文本和URL溢出处理 ===== */

  /* 全局prose容器长文本处理 */
  .prose {
    overflow-wrap: anywhere !important;
    word-wrap: break-word !important;
    /* 确保容器不会被内容撑开 */
    min-width: 0 !important;
    /* 移除 max-width: 100% 以允许 Tailwind 的 max-w-* 类正常工作 */
  }

  /* prose中的链接特殊处理 */
  .prose a {
    overflow-wrap: anywhere !important;
    word-wrap: break-word !important;
    word-break: break-word !important;
    /* 确保长URL能够换行 */
    hyphens: auto !important;
    /* 防止链接撑开容器 */
    max-width: 100% !important;
    display: inline-block !important;
  }

  /* prose中的段落、列表项、表格单元格文本处理 */
  .prose p,
  .prose li,
  .prose td,
  .prose th,
  .prose div {
    overflow-wrap: anywhere !important;
    word-wrap: break-word !important;
    /* 确保所有文本内容都能正确换行 */
    hyphens: auto !important;
  }

  /* 特别处理代码块中的长文本（但保持代码的可读性） */
  .prose code:not(pre code) {
    overflow-wrap: anywhere !important;
    word-wrap: break-word !important;
    /* 行内代码也需要能够换行 */
    white-space: pre-wrap !important;
  }

  /* memo-content特殊处理（时间线中的闪念内容） */
  .memo-content {
    overflow-wrap: anywhere !important;
    word-wrap: break-word !important;
    /* 确保闪念内容不会溢出 */
    max-width: 100% !important;
    min-width: 0 !important;
  }

  .memo-content a {
    overflow-wrap: anywhere !important;
    word-wrap: break-word !important;
    word-break: break-word !important;
    /* 闪念中的链接特殊处理 */
    max-width: 100% !important;
    display: inline-block !important;
  }

  /* 响应式处理：移动端更激进的换行策略 */
  @media (max-width: 640px) {
    .prose a {
      word-break: break-all !important;
      /* 移动端对长URL使用更激进的断行策略 */
    }

    .memo-content a {
      word-break: break-all !important;
    }
  }
</style>

---
import { existsSync } from "node:fs";
import { readFile } from "node:fs/promises";
import { resolve } from "node:path";
import Icon from "@/components/ui/Icon";
import { resolveImagePath } from "@/lib/image-utils";
import type { PublicPostRecord } from "@/public-site/snapshot";
import { toPublicAssetUrl } from "../lib/runtime-urls";

interface Props {
  post: PublicPostRecord;
}

const { post } = Astro.props as Props;
const source = (post.dataSource?.includes("local") ? "local" : "webdav") as "local" | "webdav";

function firstNonEmptyString(values: unknown[]): string | null {
  for (const value of values) {
    if (typeof value === "string" && value.trim().length > 0) {
      return value.trim();
    }
  }
  return null;
}

function isExternalUrl(value: string) {
  return /^https?:\/\//.test(value.trim());
}

function normalizeWikiImageTarget(target: string) {
  return target
    .split("|")[0]
    .trim()
    .replace(/^。\//u, "./")
    .replace(/^\.。\//u, "./");
}

function extractCoverCandidate(record: PublicPostRecord) {
  const metadata = record.metadata as Record<string, unknown>;
  const metadataImages = Array.isArray(metadata.images) ? metadata.images : [];
  const frontmatterImage = firstNonEmptyString([record.image, ...metadataImages]);
  if (frontmatterImage) return frontmatterImage;

  const markdownImage = record.body.match(/!\[[^\]]*\]\(([^)]+)\)/)?.[1];
  if (markdownImage?.trim() && !isExternalUrl(markdownImage)) return markdownImage.trim();

  const wikiImage = record.body.match(/!\[\[([^\]]+)\]\]/)?.[1];
  if (wikiImage?.trim()) return normalizeWikiImageTarget(wikiImage);

  return null;
}

function resolveRelativeAssetPath(imagePath: string, markdownFilePath: string) {
  const clean = imagePath.trim();
  if (!clean) return null;

  if (clean.startsWith("/")) {
    return clean.replace(/^\/+/, "");
  }

  const normalizedFilePath = markdownFilePath.replace(/\\/g, "/");
  const markdownDir = normalizedFilePath.includes("/")
    ? normalizedFilePath.slice(0, normalizedFilePath.lastIndexOf("/"))
    : "";

  const baseSegments = markdownDir.split("/").filter(Boolean);
  const pathSegments = clean.replace(/\\/g, "/").split("/");

  if (!clean.startsWith("./") && !clean.startsWith("../")) {
    return [...baseSegments, ...pathSegments.filter(Boolean)].join("/");
  }

  for (const segment of pathSegments) {
    if (!segment || segment === ".") continue;
    if (segment === "..") {
      baseSegments.pop();
      continue;
    }
    baseSegments.push(segment);
  }

  return baseSegments.join("/");
}

function decodeAssetPath(path: string) {
  try {
    return decodeURIComponent(path);
  } catch {
    return path;
  }
}

function getMimeType(filePath: string) {
  const lower = filePath.toLowerCase();
  if (lower.endsWith(".png")) return "image/png";
  if (lower.endsWith(".jpg") || lower.endsWith(".jpeg")) return "image/jpeg";
  if (lower.endsWith(".gif")) return "image/gif";
  if (lower.endsWith(".webp")) return "image/webp";
  if (lower.endsWith(".svg")) return "image/svg+xml";
  return "application/octet-stream";
}

async function resolveCardImageSrc(record: PublicPostRecord, contentSource: "local" | "webdav") {
  const coverCandidate = extractCoverCandidate(record);
  if (!coverCandidate || isExternalUrl(coverCandidate)) {
    return null;
  }

  const markdownFilePath = record.filePath || `blog/${record.slug}.md`;

  if (contentSource === "local") {
    const contentBasePath = process.env.LOCAL_CONTENT_BASE_PATH?.trim();
    const relativeAssetPath = resolveRelativeAssetPath(coverCandidate, markdownFilePath);

    if (contentBasePath && relativeAssetPath) {
      const absoluteBasePath = resolve(contentBasePath);
      const absoluteAssetPath = resolve(absoluteBasePath, decodeAssetPath(relativeAssetPath));

      if (absoluteAssetPath.startsWith(absoluteBasePath) && existsSync(absoluteAssetPath)) {
        const buffer = await readFile(absoluteAssetPath);
        return `data:${getMimeType(absoluteAssetPath)};base64,${buffer.toString("base64")}`;
      }
    }
  }

  return toPublicAssetUrl(resolveImagePath(coverCandidate, contentSource, markdownFilePath));
}

const imageSrc = await resolveCardImageSrc(post, source);
const hasCover = Boolean(imageSrc);
const excerpt = post.excerpt?.trim() || "";
const articleClass = "min-w-0 self-start";
const linkClass =
  "nature-panel nature-hover-lift nature-hover-surface flex min-h-0 overflow-hidden p-0 transition-all duration-300 [--nature-hover-border-color:rgba(var(--nature-accent-rgb),0.42)] [--nature-hover-lift-offset:-0.25rem] [--nature-hover-shadow:0_20px_44px_rgba(8,21,16,0.14)] flex-col md:grid md:aspect-[12/5] md:grid-cols-[40%_1fr] md:grid-rows-1 lg:flex lg:aspect-square lg:flex-col lg:grid-cols-none";
const mediaClass =
  "relative aspect-[16/9] overflow-hidden border-b border-[rgba(var(--nature-border-rgb),0.68)] bg-[linear-gradient(135deg,rgba(var(--nature-accent-rgb),0.18),rgba(var(--nature-secondary-rgb),0.12))] md:h-full md:min-h-0 md:aspect-auto md:border-b-0 md:border-r lg:basis-[44%] lg:border-r-0 lg:border-b";
const placeholderClass =
  "relative flex h-full w-full flex-col justify-between overflow-hidden p-4 text-[color:var(--nature-text-soft)] md:p-3 lg:p-4";
const bodyClass = "flex min-h-0 flex-col justify-start gap-3 p-4 md:flex-1 md:gap-2 md:p-4 lg:p-4";
const titleClass =
  "line-clamp-2 shrink-0 text-base font-semibold leading-6 text-[color:var(--nature-text)] transition-colors duration-200 group-hover:text-[color:var(--nature-accent-strong)] md:text-[1.125rem] md:leading-6 lg:text-base lg:leading-6";
const excerptClass =
  "line-clamp-2 text-sm leading-6 text-[color:var(--nature-text-soft)] md:line-clamp-2 md:leading-5 lg:line-clamp-3 lg:leading-6";
---

<article class={articleClass} itemprop="isRelatedTo" itemscope itemtype="https://schema.org/Article">
  <a class="nature-hover-hitbox group block" href={`/posts/${post.slug}`} itemprop="url">
    <div class={linkClass}>
      {hasCover ? (
        <div class={mediaClass}>
          <img
            src={imageSrc}
            alt={post.title}
            class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.04]"
            loading="lazy"
            decoding="async"
            itemprop="image"
          />
        </div>
      ) : (
        <div class={`${mediaClass} hidden md:block`}>
          <div class={placeholderClass}>
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(255,255,255,0.28),transparent_38%),linear-gradient(135deg,rgba(var(--nature-accent-rgb),0.22),rgba(var(--nature-secondary-rgb),0.12))]" />
            <div class="absolute inset-x-4 bottom-4 z-0 space-y-2 opacity-70">
              <div class="h-2 rounded-full bg-white/55" />
              <div class="h-2 w-3/4 rounded-full bg-white/35" />
              <div class="h-2 w-1/2 rounded-full bg-white/25" />
            </div>
            <Icon
              name="tabler:article"
              className="absolute -right-3 -top-3 h-20 w-20 text-[color:var(--nature-accent-strong)]/10 md:h-14 md:w-14 lg:h-20 lg:w-20"
            />
          </div>
        </div>
      )}

      <div class={bodyClass}>
        <h3 class={titleClass} itemprop="headline">{post.title}</h3>

        <p class={excerptClass} itemprop="description">{excerpt}</p>
      </div>
    </div>
  </a>
</article>

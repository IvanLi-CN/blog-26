---
import Icon from "@/components/ui/Icon";
import MarkdownRenderer from "@/components/common/MarkdownRenderer";
import PostReactions from "@/components/blog/PostReactions";
import CommentSectionWithProvider from "@/components/comments/CommentSectionWithProvider";
import { resolveImagePath } from "@/lib/image-utils";
import { calculateReadingTime, formatReadingTime } from "@/lib/reading-time";
import type { PublicPostRecord } from "@/public-site/snapshot";
import BaseLayout from "../../layouts/BaseLayout.astro";
import TagBadge from "../../components/TagBadge.astro";
import RelatedPostCard from "../../components/RelatedPostCard.astro";
import { formatAbsoluteDate, formatDateTime } from "../../lib/format";
import { getRelatedPosts, getSnapshot } from "../../lib/public-site";
import { toPublicAssetUrl } from "../../lib/runtime-urls";

export async function getStaticPaths() {
  const snapshot = await getSnapshot();
  return snapshot.posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props as { post: PublicPostRecord };
const snapshot = await getSnapshot();
const relatedPosts = getRelatedPosts(snapshot, post.slug);
const imageSrc = toPublicAssetUrl(resolveImagePath(
  post.image || undefined,
  (post.dataSource?.includes("local") ? "local" : "webdav") as "local" | "webdav",
  post.filePath || `blog/${post.slug}.md`
));
const absoluteImageSrc = imageSrc
  ? imageSrc.startsWith("http")
    ? imageSrc
    : new URL(imageSrc, snapshot.site.url).toString()
  : undefined;
const readingTime = formatReadingTime(calculateReadingTime(post.body || ""));
const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.title,
  description: post.excerpt ?? undefined,
  datePublished: post.publishDate,
  dateModified: post.updateDate ?? post.publishDate,
  author: {
    "@type": "Person",
    name: post.author || snapshot.site.author.name,
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": `${snapshot.site.url}/posts/${post.slug}`,
  },
  image: absoluteImageSrc,
};
---
<BaseLayout
  pathname={`/posts/${post.slug}`}
  title={`${post.title} - ${snapshot.site.title}`}
  description={post.excerpt ?? snapshot.site.description}
  image={absoluteImageSrc ?? post.image ?? snapshot.site.images.default}
>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <section class="nature-reading-container py-10 lg:py-14">
    <article>
      <header class="space-y-6">
        <div class="nature-surface px-6 py-7 sm:px-8">
          <div class="flex flex-wrap items-center gap-3 text-sm text-[color:var(--nature-text-soft)]">
            <span class="nature-chip nature-chip-info gap-1">
              <Icon name="tabler:clock" className="h-3.5 w-3.5" />
              <time dateTime={post.publishDate} title={formatDateTime(post.publishDate)}>
                {formatAbsoluteDate(post.publishDate)}
              </time>
            </span>
            {post.updateDate && (
              <span class="text-xs italic text-[color:var(--nature-text-faint)]">
                编辑于 {formatAbsoluteDate(post.updateDate)}
              </span>
            )}
            <span class="nature-chip gap-1">
              <Icon name="tabler:user" className="h-3.5 w-3.5" />
              {post.author || snapshot.site.author.name}
            </span>
            {post.category && <span class="nature-chip nature-chip-accent">{post.category}</span>}
            <span class="nature-chip gap-1">
              <Icon name="tabler:hourglass" className="h-3.5 w-3.5" />
              {readingTime}
            </span>
          </div>

          <h1 class="mt-5 font-heading text-4xl font-semibold leading-tight tracking-[-0.05em] text-[color:var(--nature-text)] md:text-5xl">
            {post.title}
          </h1>

          {post.excerpt && <p class="nature-muted mt-5 max-w-3xl text-base sm:text-lg">{post.excerpt}</p>}

          {post.tags.length > 0 && (
            <div class="mt-5 flex flex-wrap gap-2">
              {post.tags.map((tag) => (
                <TagBadge tag={tag} iconMap={snapshot.tags.tagIconMap} iconSvgMap={snapshot.tags.tagIconSvgMap} />
              ))}
            </div>
          )}
        </div>

        {imageSrc ? (
          <div class="overflow-hidden rounded-[2rem] border border-[rgba(var(--nature-border-rgb),0.72)] bg-[rgba(var(--nature-surface-rgb),0.78)] p-3 shadow-[0_18px_40px_rgba(8,21,16,0.12)]">
            <img src={imageSrc} class="max-h-[60vh] w-full rounded-[1.5rem] object-contain" alt={post.title} loading="lazy" />
          </div>
        ) : (
          <div class="nature-divider" />
        )}
      </header>

      <div class="nature-panel mt-8 px-6 py-7 sm:px-8">
        <MarkdownRenderer
          client:load
          content={post.body}
          variant="article"
          enableMath={true}
          enableMermaid={true}
          enableCodeFolding={true}
          articlePath={post.filePath || `blog/${post.slug}.md`}
          contentSource={(post.dataSource?.includes("local") ? "local" : "webdav") as "local" | "webdav"}
        />
      </div>

      <div class="nature-panel-soft mt-8 flex items-center justify-between gap-4 px-6 py-5">
        <div>
          <div class="nature-kicker">Feedback</div>
          <p class="nature-muted mt-2 text-sm">如果这篇文章对你有帮助，欢迎留下反应或评论。</p>
        </div>
        <PostReactions client:load postSlug={post.slug} />
      </div>

      <CommentSectionWithProvider client:load postSlug={post.slug} />
    </article>
  </section>

  {relatedPosts.length > 0 && (
    <section class="nature-container px-6 pb-12 sm:pb-16 lg:pb-20">
      <div class="space-y-6 border-t border-[rgba(var(--nature-border-rgb),0.72)] pt-8">
        <div class="flex items-center gap-3">
          <Icon name="tabler:article" className="h-6 w-6 text-[color:var(--nature-accent-strong)]" />
          <h2 class="font-heading text-2xl font-semibold text-[color:var(--nature-text)]">相关文章</h2>
        </div>
        <div class="grid items-start gap-6 md:grid-cols-2 lg:grid-cols-4">
          {relatedPosts.map((relatedPost) => (
            <RelatedPostCard post={relatedPost} />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MemoCard from "../../components/MemoCard.astro";
import { PublicMemoComposerIsland } from "../../components/PublicMemoAuthoring";
import { getSnapshot } from "../../lib/public-site";
import { isLocalContentEnabled } from "@/config/paths";
import { getServerLocalMemoRootPath } from "@/lib/memo-paths";

const snapshot = await getSnapshot();
const localSourceEnabled = isLocalContentEnabled();
const localMemoRootPath = localSourceEnabled ? getServerLocalMemoRootPath() : undefined;
---
<BaseLayout pathname="/memos" title="Memos - Ivan's Blog" description="浏览所有公开 Memos">
  <section class="nature-container px-6 py-8 sm:py-12 lg:py-16">
    <div class="mb-8 text-center sm:mb-12">
      <span class="nature-kicker justify-center">Flow Notes</span>
      <h1 class="nature-title mt-4 text-4xl sm:text-5xl lg:text-6xl">Memos</h1>
      <p class="nature-muted mx-auto mt-4 max-w-2xl text-base sm:text-lg">
        记录想法、灵感和日常思考的快速笔记
      </p>
    </div>

    <PublicMemoComposerIsland
      client:load
      localSourceEnabled={localSourceEnabled}
      localMemoRootPath={localMemoRootPath}
    />

    {snapshot.memos.length > 0 ? (
      <div
        class="memos-list nature-timeline"
        data-testid="memos-timeline"
        data-public-memos-static-list
      >
        {snapshot.memos.map((memo, index) => (
          <MemoCard
            memo={memo}
            isLast={index === snapshot.memos.length - 1}
            iconMap={snapshot.tags.tagIconMap}
            iconSvgMap={snapshot.tags.tagIconSvgMap}
          />
        ))}
      </div>
    ) : (
      <div class="nature-empty">
        <p>暂无公开 Memos</p>
      </div>
    )}
  </section>
</BaseLayout>
